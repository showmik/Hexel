<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         Core palette — warm paper feel
         ═══════════════════════════════════════════════════════════ -->
    <Color x:Key="Color.Background">#F5F3EF</Color>
    <Color x:Key="Color.PanelBackground">#FFFFFF</Color>
    <Color x:Key="Color.PanelBorder">#E2DDD6</Color>
    <Color x:Key="Color.CanvasBackground">#3A3A4A</Color>
    <Color x:Key="Color.TextMain">#1E1E2E</Color>
    <Color x:Key="Color.TextMuted">#6E6E80</Color>
    <Color x:Key="Color.TextInverse">#F5F3EF</Color>
    <Color x:Key="Color.CodeTxt">#4A5568</Color>
    <Color x:Key="Color.PrimaryAccent">#7C5CFC</Color>
    <Color x:Key="Color.SelectionBackground">#6366F1</Color>
    <Color x:Key="Color.Danger">#DC4A3D</Color>
    <Color x:Key="Color.Warning">#D4A017</Color>
    <Color x:Key="Color.OledBackground">#FFFFFF</Color>
    <Color x:Key="Color.OledForeground">#2D6A8A</Color>
    <Color x:Key="Color.InvertButtonBackground">#2563EB</Color>
    <Color x:Key="Color.ClearButtonBackground">#DC4A3D</Color>
    <Color x:Key="Color.CopyButtonBackground">#16A34A</Color>
    <Color x:Key="Color.ThumbBackground">#D6D1CA</Color>
    <Color x:Key="Color.ScrollBar">#E8E4DE</Color>

    <!-- ═══════════════════════════════════════════════════════════
         UI-shell palette
         ═══════════════════════════════════════════════════════════ -->
    <Color x:Key="Color.MenuBarBackground">#FFFCF8</Color>
    <Color x:Key="Color.MenuItemHover">#EDE9E3</Color>
    <Color x:Key="Color.StatusBarBackground">#F0ECE6</Color>
    <Color x:Key="Color.ToolbarBackground">#FAF8F5</Color>
    <Color x:Key="Color.ToolSidebarBackground">#F0ECE6</Color>
    <Color x:Key="Color.ToolSidebarActive">#E2DDD6</Color>
    <Color x:Key="Color.Separator">#DDD8D0</Color>

    <!-- ═══════════════════════════════════════════════════════════
         Control specific palette
         ═══════════════════════════════════════════════════════════ -->
    <Color x:Key="Color.ButtonBackground">#E2DDD6</Color>
    <Color x:Key="Color.ButtonText">#1E1E2E</Color>
    <Color x:Key="Color.TextBoxBackground">#F5F3EF</Color>
    <Color x:Key="Color.TextBoxBorder">#E2DDD6</Color>
    <Color x:Key="Color.TextBoxText">#1E1E2E</Color>
    <Color x:Key="Color.TextBoxFocusBorder">#7C5CFC</Color>
    <Color x:Key="Color.ComboBoxBackground">#F5F3EF</Color>
    <Color x:Key="Color.ComboBoxBorder">#E2DDD6</Color>
    <Color x:Key="Color.ComboBoxText">#1E1E2E</Color>
    <Color x:Key="Color.ComboBoxDropDownBackground">#FFFFFF</Color>
    <Color x:Key="Color.ComboBoxDropDownBorder">#E2DDD6</Color>
    <Color x:Key="Color.ContextMenuBackground">#FFFFFF</Color>
    <Color x:Key="Color.ContextMenuBorder">#E2DDD6</Color>
    <Color x:Key="Color.ToolTipBackground">#FFFFFF</Color>
    <Color x:Key="Color.ToolTipBorder">#E2DDD6</Color>
    <Color x:Key="Color.ToolTipText">#1E1E2E</Color>
    <Color x:Key="Color.MenuPopupBackground">#FFFFFF</Color>
    <Color x:Key="Color.MenuPopupBorder">#E2DDD6</Color>
    <Color x:Key="Color.ToolButtonHover">#E2DDD6</Color>
    <Color x:Key="Color.ToolButtonCheckedBackground">#6366F1</Color>
    <Color x:Key="Color.ToolButtonCheckedBorder">#7C5CFC</Color>
    <Color x:Key="Color.StatusBarBorder">#E2DDD6</Color>

    <!-- ═══════════════════════════════════════════════════════════
         New semantic tokens
         ═══════════════════════════════════════════════════════════ -->
    <Color x:Key="Color.TextOnAccent">#FFFFFF</Color>
    <Color x:Key="Color.BrandGradientStart">#6366F1</Color>
    <Color x:Key="Color.BrandGradientEnd">#8B5CF6</Color>
    <Color x:Key="Color.CrosshairStroke">#CC333333</Color>
    <Color x:Key="Color.LassoFill">#40D4A017</Color>
    <Color x:Key="Color.BrushCursorEdge">#DD333333</Color>
    <Color x:Key="Color.BrushCursorFill">#40333333</Color>
    <Color x:Key="Color.InputBackground">#F8F6F2</Color>
    <Color x:Key="Color.ShadowColor">#3D3D3D</Color>
    <Color x:Key="Color.SurfaceOverlay">#E8E4DE</Color>
    <Color x:Key="Color.Success">#16A34A</Color>

    <!-- ═══════════════════════════════════════════════════════════
         Brushes
         ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="Theme.InvertButtonBackgroundBrush"
                     Color="{StaticResource Color.InvertButtonBackground}" />
    <SolidColorBrush x:Key="Theme.ClearButtonBackgroundBrush"
                     Color="{StaticResource Color.ClearButtonBackground}" />
    <SolidColorBrush x:Key="Theme.CopyButtonBackgroundBrush"
                     Color="{StaticResource Color.CopyButtonBackground}" />
    <SolidColorBrush x:Key="Theme.BackgroundBrush"
                     Color="{StaticResource Color.Background}" />
    <SolidColorBrush x:Key="Theme.PanelBackgroundBrush"
                     Color="{StaticResource Color.PanelBackground}" />
    <LinearGradientBrush x:Key="Theme.RightSidebarBackgroundBrush" StartPoint="0,0" EndPoint="0.8,1">
        <GradientStop Color="#F7F5F0" Offset="0" />
        <GradientStop Color="#F7F5F0" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="Theme.PanelBorderBrush"
                     Color="{StaticResource Color.PanelBorder}" />
    <SolidColorBrush x:Key="Theme.CanvasBackgroundBrush"
                     Color="{StaticResource Color.CanvasBackground}" />

    <SolidColorBrush x:Key="Theme.TextMainBrush"
                     Color="{StaticResource Color.TextMain}" />
    <SolidColorBrush x:Key="Theme.TextMutedBrush"
                     Color="{StaticResource Color.TextMuted}" />
    <SolidColorBrush x:Key="Theme.TextInverseBrush"
                     Color="{StaticResource Color.TextInverse}" />
    <SolidColorBrush x:Key="Theme.CodeTxtBrush"
                     Color="{StaticResource Color.CodeTxt}" />

    <SolidColorBrush x:Key="Theme.ThumbBackgroundBrush"
                     Color="{StaticResource Color.ThumbBackground}" />
    <SolidColorBrush x:Key="Theme.ScrollBarBrush"
                     Color="{StaticResource Color.ScrollBar}" />

    <SolidColorBrush x:Key="Theme.PrimaryAccentBrush"
                     Color="{StaticResource Color.PrimaryAccent}" />
    <SolidColorBrush x:Key="Theme.SelectionBackgroundBrush"
                     Color="{StaticResource Color.SelectionBackground}" />

    <SolidColorBrush x:Key="Theme.DangerBrush"
                     Color="{StaticResource Color.Danger}" />
    <SolidColorBrush x:Key="Theme.WarningBrush"
                     Color="{StaticResource Color.Warning}" />

    <SolidColorBrush x:Key="Theme.OledOffBrush"
                     Color="{StaticResource Color.OledBackground}" />
    <SolidColorBrush x:Key="Theme.OledOnBrush"
                     Color="{StaticResource Color.OledForeground}" />

    <!-- UI shell brushes -->
    <SolidColorBrush x:Key="Theme.MenuBarBackgroundBrush"
                     Color="{StaticResource Color.MenuBarBackground}" />
    <SolidColorBrush x:Key="Theme.MenuItemHoverBrush"
                     Color="{StaticResource Color.MenuItemHover}" />
    <SolidColorBrush x:Key="Theme.StatusBarBackgroundBrush"
                     Color="{StaticResource Color.StatusBarBackground}" />
    <SolidColorBrush x:Key="Theme.ToolbarBackgroundBrush"
                     Color="{StaticResource Color.ToolbarBackground}" />
    <SolidColorBrush x:Key="Theme.ToolSidebarBackgroundBrush"
                     Color="{StaticResource Color.ToolSidebarBackground}" />
    <SolidColorBrush x:Key="Theme.ToolSidebarActiveBrush"
                     Color="{StaticResource Color.ToolSidebarActive}" />
    <SolidColorBrush x:Key="Theme.SeparatorBrush"
                     Color="{StaticResource Color.Separator}" />

    <!-- Control specific brushes -->
    <SolidColorBrush x:Key="Theme.ButtonBackgroundBrush" Color="{StaticResource Color.ButtonBackground}" />
    <SolidColorBrush x:Key="Theme.ButtonTextBrush" Color="{StaticResource Color.ButtonText}" />
    <SolidColorBrush x:Key="Theme.TextBoxBackgroundBrush" Color="{StaticResource Color.TextBoxBackground}" />
    <SolidColorBrush x:Key="Theme.TextBoxBorderBrush" Color="{StaticResource Color.TextBoxBorder}" />
    <SolidColorBrush x:Key="Theme.TextBoxTextBrush" Color="{StaticResource Color.TextBoxText}" />
    <SolidColorBrush x:Key="Theme.TextBoxFocusBorderBrush" Color="{StaticResource Color.TextBoxFocusBorder}" />
    <SolidColorBrush x:Key="Theme.ComboBoxBackgroundBrush" Color="{StaticResource Color.ComboBoxBackground}" />
    <SolidColorBrush x:Key="Theme.ComboBoxBorderBrush" Color="{StaticResource Color.ComboBoxBorder}" />
    <SolidColorBrush x:Key="Theme.ComboBoxTextBrush" Color="{StaticResource Color.ComboBoxText}" />
    <SolidColorBrush x:Key="Theme.ComboBoxDropDownBackgroundBrush" Color="{StaticResource Color.ComboBoxDropDownBackground}" />
    <SolidColorBrush x:Key="Theme.ComboBoxDropDownBorderBrush" Color="{StaticResource Color.ComboBoxDropDownBorder}" />
    <SolidColorBrush x:Key="Theme.ContextMenuBackgroundBrush" Color="{StaticResource Color.ContextMenuBackground}" />
    <SolidColorBrush x:Key="Theme.ContextMenuBorderBrush" Color="{StaticResource Color.ContextMenuBorder}" />
    <SolidColorBrush x:Key="Theme.ToolTipBackgroundBrush" Color="{StaticResource Color.ToolTipBackground}" />
    <SolidColorBrush x:Key="Theme.ToolTipBorderBrush" Color="{StaticResource Color.ToolTipBorder}" />
    <SolidColorBrush x:Key="Theme.ToolTipTextBrush" Color="{StaticResource Color.ToolTipText}" />
    <SolidColorBrush x:Key="Theme.MenuPopupBackgroundBrush" Color="{StaticResource Color.MenuPopupBackground}" />
    <SolidColorBrush x:Key="Theme.MenuPopupBorderBrush" Color="{StaticResource Color.MenuPopupBorder}" />
    <SolidColorBrush x:Key="Theme.ToolButtonHoverBrush" Color="{StaticResource Color.ToolButtonHover}" />
    <SolidColorBrush x:Key="Theme.ToolButtonCheckedBackgroundBrush" Color="{StaticResource Color.ToolButtonCheckedBackground}" />
    <SolidColorBrush x:Key="Theme.ToolButtonCheckedBorderBrush" Color="{StaticResource Color.ToolButtonCheckedBorder}" />
    <SolidColorBrush x:Key="Theme.StatusBarBorderBrush" Color="{StaticResource Color.StatusBarBorder}" />

    <!-- New semantic brushes -->
    <SolidColorBrush x:Key="Theme.TextOnAccentBrush"
                     Color="{StaticResource Color.TextOnAccent}" />
    <SolidColorBrush x:Key="Theme.BrandGradientStartBrush"
                     Color="{StaticResource Color.BrandGradientStart}" />
    <SolidColorBrush x:Key="Theme.BrandGradientEndBrush"
                     Color="{StaticResource Color.BrandGradientEnd}" />
    <SolidColorBrush x:Key="Theme.CrosshairStrokeBrush"
                     Color="{StaticResource Color.CrosshairStroke}" />
    <SolidColorBrush x:Key="Theme.LassoFillBrush"
                     Color="{StaticResource Color.LassoFill}" />
    <SolidColorBrush x:Key="Theme.InputBackgroundBrush"
                     Color="{StaticResource Color.InputBackground}" />
    <SolidColorBrush x:Key="Theme.SurfaceOverlayBrush"
                     Color="{StaticResource Color.SurfaceOverlay}" />
    <SolidColorBrush x:Key="Theme.SuccessBrush"
                     Color="{StaticResource Color.Success}" />

    <!-- ═══════════════════════════════════════════════════════════
         Syntax highlighting (light-mode palette, VS Code Light inspired)
         ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="Syntax.KeywordBrush"  Color="#0000FF"/>
    <SolidColorBrush x:Key="Syntax.LiteralBrush"  Color="#098658"/>
    <SolidColorBrush x:Key="Syntax.CommentBrush"  Color="#008000"/>
    <SolidColorBrush x:Key="Syntax.IdentifierBrush" Color="#001080"/>
    <SolidColorBrush x:Key="Syntax.PunctuationBrush" Color="#393A34"/>

</ResourceDictionary>

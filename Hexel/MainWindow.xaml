<Window x:Class="Hexel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:Hexel.Core"
        xmlns:vm="clr-namespace:Hexel.ViewModels"
        xmlns:views="clr-namespace:Hexel.Views"
        Title="Hexel"
        MinHeight="650"
        MinWidth="950"
        Height="780"
        Width="1150"
        Background="{DynamicResource Theme.BackgroundBrush}"
        FontFamily="{DynamicResource Theme.MainFont}"
        WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <KeyBinding Key="Z"
                    Modifiers="Ctrl"
                    Command="{Binding ActiveDocument.UndoCommand}" />
        <KeyBinding Key="Y"
                    Modifiers="Ctrl"
                    Command="{Binding ActiveDocument.RedoCommand}" />
        <KeyBinding Key="S"
                    Modifiers="Ctrl"
                    Command="{Binding SaveCommand}" />
        <KeyBinding Key="S"
                    Modifiers="Ctrl+Shift"
                    Command="{Binding SaveAsCommand}" />
        <KeyBinding Key="N"
                    Modifiers="Ctrl"
                    Command="{Binding NewCanvasCommand}" />
        <KeyBinding Key="O"
                    Modifiers="Ctrl"
                    Command="{Binding OpenCommand}" />
        <KeyBinding Key="W"
                    Modifiers="Ctrl"
                    Command="{Binding CloseTabCommand}" />
        <KeyBinding Key="OemPlus"
                    Modifiers="Ctrl"
                    Command="{x:Static NavigationCommands.IncreaseZoom}" />
        <KeyBinding Key="OemMinus"
                    Modifiers="Ctrl"
                    Command="{x:Static NavigationCommands.DecreaseZoom}" />
        <KeyBinding Key="D0"
                    Modifiers="Ctrl"
                    Command="{x:Static NavigationCommands.Zoom}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             MENU BAR
             ═══════════════════════════════════════════════════════════════ -->
        <Menu Grid.Row="0">
            <!-- ── File ── -->
            <MenuItem Header="_File">
                <MenuItem Header="_New Canvas"
                          Command="{Binding NewCanvasCommand}"
                          InputGestureText="Ctrl+N" />
                <MenuItem Header="_Open"
                          Command="{Binding OpenCommand}"
                          InputGestureText="Ctrl+O" />
                <Separator Style="{StaticResource MenuSeparatorStyle}" />
                <MenuItem Header="_Save"
                          Command="{Binding SaveCommand}"
                          InputGestureText="Ctrl+S" />
                <MenuItem Header="Save _As..."
                          Command="{Binding SaveAsCommand}"
                          InputGestureText="Ctrl+Shift+S" />
                <Separator Style="{StaticResource MenuSeparatorStyle}" />
                <MenuItem Header="_Close Tab"
                          Command="{Binding CloseTabCommand}"
                          InputGestureText="Ctrl+W" />
            </MenuItem>

            <!-- ── Edit ── -->
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo"
                          Command="{Binding ActiveDocument.UndoCommand}"
                          InputGestureText="Ctrl+Z" />
                <MenuItem Header="_Redo"
                          Command="{Binding ActiveDocument.RedoCommand}"
                          InputGestureText="Ctrl+Y" />
                <Separator Style="{StaticResource MenuSeparatorStyle}" />
                <MenuItem Header="_Invert"
                          Command="{Binding ActiveDocument.InvertCommand}" />
                <MenuItem Header="_Clear Canvas"
                          Command="{Binding ActiveDocument.ClearCommand}" />
                <Separator Style="{StaticResource MenuSeparatorStyle}" />
                <MenuItem Header="Copy _HEX"
                          Command="{Binding ActiveDocument.CopyHexCommand}" />
            </MenuItem>

            <!-- ── Image ── -->
            <MenuItem Header="_Image">
                <MenuItem Header="Canvas _Size..."
                          Command="{Binding ResizeCanvasCommand}" />
            </MenuItem>

            <!-- ── View ── -->
            <MenuItem Header="_View">
                <MenuItem Header="Show _Grid"
                          IsCheckable="True"
                          IsChecked="{Binding ActiveDocument.ShowGridLines}" />
                <Separator Style="{StaticResource MenuSeparatorStyle}" />
                <MenuItem Header="Zoom _In"
                          Command="{x:Static NavigationCommands.IncreaseZoom}"
                          InputGestureText="Ctrl++" />
                <MenuItem Header="Zoom _Out"
                          Command="{x:Static NavigationCommands.DecreaseZoom}"
                          InputGestureText="Ctrl+-" />
                <MenuItem Header="_Reset Zoom"
                          Command="{x:Static NavigationCommands.Zoom}"
                          InputGestureText="Ctrl+0" />
            </MenuItem>

            <!-- ── Selection ── -->
            <MenuItem Header="_Selection">
                <MenuItem Header="_Delete Selection"
                          Command="{Binding ActiveDocument.DeleteSelectionCommand}"
                          InputGestureText="Del" />
            </MenuItem>
        </Menu>

        <!-- ═══════════════════════════════════════════════════════════════
             TAB BAR
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{DynamicResource Theme.MenuBarBackgroundBrush}"
                BorderBrush="{DynamicResource Theme.SeparatorBrush}"
                BorderThickness="0,0,0,1"
                Padding="4,0">
            <StackPanel Orientation="Horizontal">
                <ItemsControl ItemsSource="{Binding OpenDocuments}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="TabBorder"
                                    Padding="10,6"
                                    Margin="0,4,2,4"
                                    CornerRadius="6"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="Tab_MouseLeftButtonDown">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource Theme.ToolSidebarActiveBrush}" />
                                            </DataTrigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsMouseOver" Value="True" />
                                                </MultiTrigger.Conditions>
                                                <Setter Property="Background" Value="{DynamicResource Theme.MenuItemHoverBrush}" />
                                            </MultiTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="{DynamicResource Theme.TextMainBrush}"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Margin="0,0,8,0" />
                                    <Button Content="✕"
                                            FontSize="10"
                                            Padding="2,0"
                                            MinWidth="16" MinHeight="16"
                                            VerticalAlignment="Center"
                                            Cursor="Hand"
                                            Click="TabClose_Click"
                                            Tag="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="Foreground" Value="{DynamicResource Theme.TextMutedBrush}" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    CornerRadius="3"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center" />
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource Theme.DangerBrush}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- New tab button -->
                <Button Content="+"
                        FontSize="14"
                        FontWeight="Bold"
                        Padding="8,4"
                        Margin="4,4"
                        VerticalAlignment="Center"
                        Command="{Binding NewCanvasCommand}"
                        ToolTip="New canvas (Ctrl+N)">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{DynamicResource Theme.TextMutedBrush}" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Theme.MenuItemHoverBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource Theme.TextMainBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT AREA
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2"
              DataContext="{Binding ActiveDocument}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="2" />
                <ColumnDefinition Width="400"
                                  MinWidth="300"
                                  MaxWidth="600" />
            </Grid.ColumnDefinitions>

            <views:ToolSidebarPanel Grid.Column="0" />

            <views:CanvasPanel x:Name="Canvas" Grid.Column="1" 
                               Margin="15,20,20,20"
                               ZoomInClicked="BtnZoomIn_Click"
                               ZoomOutClicked="BtnZoomOut_Click"
                               ZoomResetClicked="BtnZoomReset_Click" />

            <GridSplitter Grid.Column="2"
                          Width="2"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource Theme.PanelBackgroundBrush}"
                          Cursor="SizeWE" />

            <views:SidebarPanel Grid.Column="3" Margin="15,20,20,20" />
        </Grid>
        <!-- /Main content -->

        <views:StatusBarPanel Grid.Row="3" DataContext="{Binding ActiveDocument}" />

        <!-- ═══════════════════════════════════════════════════════════════
             EMPTY WORKSPACE STATE
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Grid.RowSpan="2">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasOpenDocument}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE131;" 
                           FontFamily="Segoe MDL2 Assets" 
                           FontSize="48" 
                           Foreground="{DynamicResource Theme.TextMutedBrush}" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,16" />
                <TextBlock Text="No Document Open" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource Theme.TextMainBrush}" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,8" />
                <TextBlock Text="Press Ctrl+N to create a new canvas, or Ctrl+O to open a file." 
                           Foreground="{DynamicResource Theme.TextMutedBrush}" 
                           HorizontalAlignment="Center" />
                <Button Content="New Canvas" 
                        Command="{Binding NewCanvasCommand}" 
                        Margin="0,24,0,0" 
                        HorizontalAlignment="Center" 
                        Padding="24,10" 
                        Style="{StaticResource ModernButtonStyle}" />
            </StackPanel>
        </Grid>

    </Grid>
</Window>
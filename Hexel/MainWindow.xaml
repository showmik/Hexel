<Window x:Class="Hexel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ESP32 Sprite Studio"
        MinHeight="600"
        MinWidth="900"
        Height="750"
        Width="1100"
        Background="#1E1E1E">

    <Window.Resources>
        <Style x:Key="HeaderStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="#00FFCC" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Margin"
                    Value="0,0,0,5" />
        </Style>

        <Style TargetType="Path"
               x:Key="StrokedToolIconStyle">
            <Setter Property="Stroke"
                    Value="#888888" />
            <Setter Property="Fill"
                    Value="Transparent" />
            <Setter Property="Width"
                    Value="18" />
            <Setter Property="Height"
                    Value="18" />
            <Setter Property="Stretch"
                    Value="Uniform" />
            <Setter Property="StrokeThickness"
                    Value="1.5" />
            <Setter Property="StrokeStartLineCap"
                    Value="Round" />
            <Setter Property="StrokeEndLineCap"
                    Value="Round" />
            <Setter Property="StrokeLineJoin"
                    Value="Round" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                             Value="True">
                    <Setter Property="Stroke"
                            Value="#00FFCC" />
                </DataTrigger>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Stroke"
                            Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconToolButtonStyle"
               TargetType="RadioButton">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderBrush"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Padding"
                    Value="6" />
            <Setter Property="Margin"
                    Value="0,0,5,0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#2A2A2A" />
                            </Trigger>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#333333" />
                                <Setter Property="BorderBrush"
                                        Value="#555555" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="380"
                              MinWidth="250"
                              MaxWidth="600" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0"
              Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,15">

                <TextBlock Text="Canvas Size:"
                           Style="{StaticResource HeaderStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <ComboBox x:Name="CmbGridSize"
                          Width="100"
                          SelectionChanged="CmbGridSize_SelectionChanged"
                          Padding="5,2">
                    <ComboBoxItem Content="2x2"
                                  Tag="2" />
                    <ComboBoxItem Content="4x4"
                                  Tag="4" />
                    <ComboBoxItem Content="8x8"
                                  Tag="8" />
                    <ComboBoxItem Content="16x16"
                                  Tag="16"
                                  IsSelected="True" />
                    <ComboBoxItem Content="24x24"
                                  Tag="24" />
                    <ComboBoxItem Content="32x32"
                                  Tag="32" />
                </ComboBox>

                <TextBlock Text="Tool:"
                           Style="{StaticResource HeaderStyle}"
                           VerticalAlignment="Center"
                           Margin="20,0,10,0" />

                <RadioButton x:Name="RbPencil"
                             Style="{StaticResource IconToolButtonStyle}"
                             GroupName="Tools"
                             IsChecked="True"
                             Checked="Tool_Checked"
                             Tag="Pencil"
                             ToolTip="Pencil Tool (B)">
                    <RadioButton.Content>
                        <Path Style="{StaticResource StrokedToolIconStyle}"
                              Data="M3.40979 23.0017V12.4402l5.0521 2.7261 3.53861 -2.5275 3.5386 2.5275 5.0511 -2.7261v10.5615 M3.41949 12.4388 11.1783 1.42699c0.4028 -0.571599 1.2503 -0.571599 1.6531 0l7.7588 11.01181 M8.46191 15.1663v7.8354 M15.5391 15.1663v7.8354 M7.55359 6.57275h8.89381" />
                    </RadioButton.Content>
                </RadioButton>

                <RadioButton x:Name="RbFill"
                             Style="{StaticResource IconToolButtonStyle}"
                             GroupName="Tools"
                             Checked="Tool_Checked"
                             Tag="Fill"
                             ToolTip="Fill Bucket (G)">
                    <RadioButton.Content>
                        <Path Style="{StaticResource StrokedToolIconStyle}"
                              Data="M45 39.3999c0 3.0928 -2.2386 5.6 -5 5.6s-5 -2.5072 -5 -5.6c0 -2.8526 2.3065 -5.7051 3.7864 -7.2418 0.6738 -0.6997 1.7534 -0.6997 2.4272 0C42.6935 33.6948 45 36.5473 45 39.3999Z M4.61826 9.7989c0.54387 -0.77989 1.54378 -0.98039 2.45947 -0.72608C9.9592 9.87308 16.6614 11.789 23.008 14.0004c1.436 0.5003 2.3292 1.9896 1.9345 3.4582 -0.3947 1.4687 -1.9151 2.3131 -3.4095 2.0306 -6.6053 -1.2489 -13.37034 -2.931 -16.26708 -3.6744 -0.92053 -0.2363 -1.68594 -0.9084 -1.76585 -1.855 -0.05162 -0.6113 -0.03039 -1.3674 0.18788 -2.1796 0.21827 -0.8122 0.57907 -1.4776 0.93031 -1.9813Z M9.49611 16.867c-1.69888 2.1041 -3.50226 4.3976 -5.33812 6.8245 -1.51733 2.0058 -1.56961 4.7519 0.00334 6.7144 1.16214 1.45 2.68002 3.2177 4.44771 4.9854 1.76766 1.7677 3.53536 3.2856 4.98536 4.4477 1.9625 1.573 4.7085 1.5207 6.7143 0.0034 8.3622 -6.3258 15.1404 -12.2659 18.0434 -14.8746 0.8424 -0.757 0.8624 -2.0546 0.0616 -2.8555L21.8879 5.58631c-0.8009 -0.80084 -2.0985 -0.78085 -2.8555 0.06155 -1.0907 1.21386 -2.7639 3.10521 -4.8042 5.50654" />
                    </RadioButton.Content>
                </RadioButton>

                <RadioButton x:Name="RbMarquee"
                             Style="{StaticResource IconToolButtonStyle}"
                             GroupName="Tools"
                             Checked="Tool_Checked"
                             Tag="Marquee"
                             ToolTip="Marquee Select (M)">
                    <RadioButton.Content>
                        <Path Style="{StaticResource StrokedToolIconStyle}"
                              StrokeDashArray="2,2"
                              Data="M 2,2 L 16,2 L 16,16 L 2,16 Z" />
                    </RadioButton.Content>
                </RadioButton>
            </StackPanel>

            <Viewbox Grid.Row="1"
                     Stretch="Uniform"
                     Margin="10">
                <Border BorderBrush="#444"
                        BorderThickness="2"
                        Background="#111">
                    <Grid Width="400"
                          Height="400">
                        <UniformGrid x:Name="PixelGrid"
                                     Background="#333" />

                        <Canvas>
                            <Rectangle x:Name="MarqueeOverlay"
                                       Stroke="Yellow"
                                       StrokeThickness="2"
                                       StrokeDashArray="4,4"
                                       Visibility="Hidden"
                                       IsHitTestVisible="False" />
                        </Canvas>
                    </Grid>
                </Border>
            </Viewbox>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,15,0,0">
                <Button Content="Undo"
                        Width="70"
                        Height="35"
                        Margin="0,0,10,0"
                        Background="#555555"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="BtnUndo_Click"
                        Cursor="Hand" />

                <Button Content="Redo"
                        Width="70"
                        Height="35"
                        Margin="0,0,15,0"
                        Background="#555555"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="BtnRedo_Click"
                        Cursor="Hand" />
                <Button Content="Invert"
                        Width="80"
                        Height="35"
                        Margin="0,0,15,0"
                        Background="#8844FF"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="BtnInvert_Click"
                        Cursor="Hand" />
                <Button Content="Clear Grid"
                        Width="120"
                        Height="35"
                        Margin="0,0,15,0"
                        Background="#FF4444"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="BtnClear_Click"
                        Cursor="Hand" />
                <Button Content="Copy HEX to Clipboard"
                        Width="180"
                        Height="35"
                        Background="#007ACC"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="BtnCopy_Click"
                        Cursor="Hand" />
            </StackPanel>
        </Grid>

        <GridSplitter Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      Background="#333"
                      Cursor="SizeWE" />

        <Grid Grid.Column="2"
              Margin="15,20,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="*" />
                <RowDefinition Height="15" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="OLED Preview (128x64):"
                           Style="{StaticResource HeaderStyle}" />
                <Border x:Name="OledBorder"
                        BorderBrush="#555"
                        BorderThickness="2"
                        Background="#050505"
                        Width="256"
                        Height="128"
                        HorizontalAlignment="Left"
                        CornerRadius="3">
                    <Grid>
                        <Border BorderBrush="#111"
                                BorderThickness="1"
                                Margin="0" />
                        <UniformGrid x:Name="PreviewGrid"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Background="#000000" />
                    </Grid>
                </Border>
                <TextBlock Text="*Sprite size shown relative to total screen area"
                           Foreground="#888"
                           FontSize="11"
                           Margin="0,3,0,0" />
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="Edit Binary to Update Grid:"
                           Style="{StaticResource HeaderStyle}" />
                <TextBox Grid.Row="1"
                         x:Name="TxtBinary"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         FontFamily="Consolas"
                         Background="#0A0A0A"
                         Foreground="#00FFCC"
                         BorderBrush="#444"
                         Padding="10"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="TxtBinary_TextChanged" />
            </Grid>

            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="Edit ESP32 HEX Array:"
                           Style="{StaticResource HeaderStyle}" />
                <TextBox Grid.Row="1"
                         x:Name="TxtHex"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         FontFamily="Consolas"
                         Background="#0A0A0A"
                         Foreground="#00FFCC"
                         BorderBrush="#444"
                         Padding="10"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="TxtHex_TextChanged" />
            </Grid>
        </Grid>
    </Grid>
</Window>
<Window x:Class="Hexel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ESP32 Sprite Studio"
        MinHeight="650"
        MinWidth="950"
        Height="780"
        Width="1150"
        Background="{DynamicResource Theme.BackgroundBrush}"
        FontFamily="{DynamicResource Theme.MainFont}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2" />
            <ColumnDefinition Width="400"
                              MinWidth="300"
                              MaxWidth="600" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0"
              Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource PanelStyle}"
                    Margin="0,0,0,15"
                    Padding="20,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                Grid.Column="0"
                                Margin="0,0,30,0">
                        <TextBlock Text="CANVAS SIZE"
                                   Style="{StaticResource HeaderStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   FontSize="11" />
                        <ComboBox x:Name="CmbGridSize"
                                  Width="100"
                                  SelectionChanged="CmbGridSize_SelectionChanged"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  Padding="8,4"
                                  Background="{DynamicResource Theme.BackgroundBrush}"
                                  Foreground="{DynamicResource Theme.TextMainBrush}"
                                  BorderBrush="{DynamicResource Theme.PanelBorderBrush}">
                            <ComboBoxItem Content="2x2"
                                          Tag="2" />
                            <ComboBoxItem Content="4x4"
                                          Tag="4" />
                            <ComboBoxItem Content="8x8"
                                          Tag="8" />
                            <ComboBoxItem Content="16x16"
                                          Tag="16"
                                          IsSelected="True" />
                            <ComboBoxItem Content="24x24"
                                          Tag="24" />
                            <ComboBoxItem Content="32x32"
                                          Tag="32" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Grid.Column="1">
                        <TextBlock Text="TOOLS"
                                   Style="{StaticResource HeaderStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   FontSize="11" />
                        <RadioButton x:Name="RbPencil"
                                     Style="{StaticResource IconToolButtonStyle}"
                                     GroupName="Tools"
                                     IsChecked="True"
                                     Checked="Tool_Checked"
                                     Tag="Pencil"
                                     ToolTip="Pencil Tool (P)">
                            <RadioButton.Content>
                                <Path Style="{StaticResource StrokedToolIconStyle}"
                                      Data="M3.40979 23.0017V12.4402l5.0521 2.7261 3.53861 -2.5275 3.5386 2.5275 5.0511 -2.7261v10.5615 M3.41949 12.4388 11.1783 1.42699c0.4028 -0.571599 1.2503 -0.571599 1.6531 0l7.7588 11.01181 M8.46191 15.1663v7.8354 M15.5391 15.1663v7.8354 M7.55359 6.57275h8.89381" />
                            </RadioButton.Content>
                        </RadioButton>
                        <RadioButton x:Name="RbLine"
                                     Style="{StaticResource IconToolButtonStyle}"
                                     GroupName="Tools"
                                     Checked="Tool_Checked"
                                     Tag="Line"
                                     ToolTip="Line Tool (L)">
                            <RadioButton.Content>
                                <Path Style="{StaticResource StrokedToolIconStyle}"
                                      Data="M4 14L14 4" />
                            </RadioButton.Content>
                        </RadioButton>
                        <RadioButton x:Name="RbFill"
                                     Style="{StaticResource IconToolButtonStyle}"
                                     GroupName="Tools"
                                     Checked="Tool_Checked"
                                     Tag="Fill"
                                     ToolTip="Fill Bucket (F)">
                            <RadioButton.Content>
                                <Path Style="{StaticResource StrokedToolIconStyle}"
                                      Data="M45 39.3999c0 3.0928 -2.2386 5.6 -5 5.6s-5 -2.5072 -5 -5.6c0 -2.8526 2.3065 -5.7051 3.7864 -7.2418 0.6738 -0.6997 1.7534 -0.6997 2.4272 0C42.6935 33.6948 45 36.5473 45 39.3999Z M4.61826 9.7989c0.54387 -0.77989 1.54378 -0.98039 2.45947 -0.72608C9.9592 9.87308 16.6614 11.789 23.008 14.0004c1.436 0.5003 2.3292 1.9896 1.9345 3.4582 -0.3947 1.4687 -1.9151 2.3131 -3.4095 2.0306 -6.6053 -1.2489 -13.37034 -2.931 -16.26708 -3.6744 -0.92053 -0.2363 -1.68594 -0.9084 -1.76585 -1.855 -0.05162 -0.6113 -0.03039 -1.3674 0.18788 -2.1796 0.21827 -0.8122 0.57907 -1.4776 0.93031 -1.9813Z M9.49611 16.867c-1.69888 2.1041 -3.50226 4.3976 -5.33812 6.8245 -1.51733 2.0058 -1.56961 4.7519 0.00334 6.7144 1.16214 1.45 2.68002 3.2177 4.44771 4.9854 1.76766 1.7677 3.53536 3.2856 4.98536 4.4477 1.9625 1.573 4.7085 1.5207 6.7143 0.0034 8.3622 -6.3258 15.1404 -12.2659 18.0434 -14.8746 0.8424 -0.757 0.8624 -2.0546 0.0616 -2.8555L21.8879 5.58631c-0.8009 -0.80084 -2.0985 -0.78085 -2.8555 0.06155 -1.0907 1.21386 -2.7639 3.10521 -4.8042 5.50654" />
                            </RadioButton.Content>
                        </RadioButton>
                        <RadioButton x:Name="RbMarquee"
                                     Style="{StaticResource IconToolButtonStyle}"
                                     GroupName="Tools"
                                     Checked="Tool_Checked"
                                     Tag="Marquee"
                                     ToolTip="Marquee Select (M)">
                            <RadioButton.Content>
                                <Path Style="{StaticResource StrokedToolIconStyle}"
                                      StrokeDashArray="2,2"
                                      Data="M 2,2 L 16,2 L 16,16 L 2,16 Z" />
                            </RadioButton.Content>
                        </RadioButton>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Grid.Column="3">
                        <TextBlock Text="ZOOM"
                                   Style="{StaticResource HeaderStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   FontSize="11" />
                        <Button Content="-"
                                Width="28"
                                Height="28"
                                Margin="0,0,8,0"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="BtnZoomOut_Click"
                                Padding="0" />
                        <Slider x:Name="ZoomSlider"
                                Width="100"
                                Minimum="0.5"
                                Maximum="5.0"
                                Value="1.0"
                                TickFrequency="0.1"
                                IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"
                                ToolTip="Zoom Canvas (Ctrl+Scroll)" />
                        <Button Content="+"
                                Width="28"
                                Height="28"
                                Margin="8,0,8,0"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="BtnZoomIn_Click"
                                Padding="0" />
                        <Button Content="Reset"
                                Height="28"
                                Padding="12,0"
                                Margin="5,0,0,0"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="BtnZoomReset_Click" />
                        <TextBlock Text="{Binding Value, ElementName=ZoomSlider, StringFormat={}{0:F1}x}"
                                   Foreground="{DynamicResource Theme.PrimaryAccentBrush}"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   Width="35" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource PanelStyle}"
                    Padding="0"
                    ClipToBounds="True">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Background="{DynamicResource Theme.BackgroundBrush}"
                              PreviewMouseWheel="ScrollViewer_PreviewMouseWheel"
                              PreviewMouseDown="ScrollViewer_PreviewMouseDown"
                              PreviewMouseMove="ScrollViewer_PreviewMouseMove"
                              PreviewMouseUp="ScrollViewer_PreviewMouseUp">
                    <Border BorderBrush="{DynamicResource Theme.PanelBackgroundBrush}"
                            BorderThickness="4"
                            Background="{DynamicResource Theme.CanvasBackgroundBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            CornerRadius="4">
                        <Border.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding Value, ElementName=ZoomSlider}"
                                            ScaleY="{Binding Value, ElementName=ZoomSlider}" />
                        </Border.LayoutTransform>

                        <Grid Width="400"
                              Height="400"
                              x:Name="PixelGridContainer">
                            <ItemsControl ItemsSource="{Binding PixelBrushes}"
                                          AlternationCount="100000">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="{Binding SpriteState.Size}"
                                                     Columns="{Binding SpriteState.Size}"
                                                     Background="{DynamicResource Theme.BackgroundBrush}" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding}"
                                                BorderBrush="{DynamicResource Theme.BackgroundBrush}"
                                                BorderThickness="1"
                                                Tag="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}}"
                                                MouseDown="Pixel_Interaction"
                                                MouseEnter="Pixel_Interaction" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Canvas IsHitTestVisible="False"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch">
                                <Rectangle x:Name="MarqueeOverlay"
                                           Stroke="#FCD34D"
                                           StrokeThickness="2"
                                           StrokeDashArray="4,4"
                                           Visibility="Hidden"
                                           IsHitTestVisible="False" />
                            </Canvas>
                        </Grid>
                    </Border>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource PanelStyle}"
                    Margin="0,15,0,0"
                    Padding="12">
                <Grid>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left">
                        <Button Content="Undo"
                                Width="80"
                                Margin="0,0,10,0"
                                Style="{StaticResource ModernButtonStyle}"
                                Command="{Binding UndoCommand}" />
                        <Button Content="Redo"
                                Width="80"
                                Margin="0,0,15,0"
                                Style="{StaticResource ModernButtonStyle}"
                                Command="{Binding RedoCommand}" />
                        <Button Content="Invert"
                                Width="90"
                                Margin="0,0,15,0"
                                Style="{StaticResource ModernButtonStyle}"
                                Background="#8B5CF6"
                                Command="{Binding InvertCommand}" />
                        <Button Content="Clear Grid"
                                Width="100"
                                Style="{StaticResource ModernButtonStyle}"
                                Background="#EF4444"
                                Command="{Binding ClearCommand}" />
                    </StackPanel>

                    <Button Content="Copy HEX to Clipboard"
                            Width="190"
                            HorizontalAlignment="Right"
                            Style="{StaticResource ModernButtonStyle}"
                            Background="#0284C7"
                            Click="BtnCopy_Click" />
                </Grid>
            </Border>
        </Grid>

        <GridSplitter Grid.Column="1"
                      Width="2"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource Theme.PanelBackgroundBrush}"
                      Cursor="SizeWE" />

        <Grid Grid.Column="2"
              Margin="15,20,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="15" />
                <RowDefinition Height="*" />
                <RowDefinition Height="15" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="OLED PREVIEW (128x64)"
                               Style="{StaticResource HeaderStyle}" />
                    <Border x:Name="OledBorder"
                            BorderBrush="{DynamicResource Theme.BackgroundBrush}"
                            BorderThickness="4"
                            Background="{DynamicResource Theme.CanvasBackgroundBrush}"
                            Width="256"
                            Height="128"
                            HorizontalAlignment="Left"
                            CornerRadius="6">
                        <Grid x:Name="PreviewGridContainer"
                              Background="{DynamicResource Theme.OledOffBrush}">
                            <ItemsControl x:Name="PreviewItemsControl"
                                          ItemsSource="{Binding PreviewBrushes}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="{Binding SpriteState.Size}"
                                                     Columns="{Binding SpriteState.Size}" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Rectangle Fill="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                    <TextBlock Text="*Sprite size shown relative to total screen area"
                               Foreground="{DynamicResource Theme.TextMutedBrush}"
                               FontSize="11"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="EDIT BINARY TO UPDATE GRID"
                               Style="{StaticResource HeaderStyle}" />

                    <Border Grid.Row="1"
                            Background="{DynamicResource Theme.BackgroundBrush}"
                            CornerRadius="6"
                            BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                            BorderThickness="1"
                            Padding="2">
                        <TextBox x:Name="TxtBinary"
                                 Text="{Binding TxtBinary, UpdateSourceTrigger=PropertyChanged, Delay=400}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 FontFamily="{DynamicResource Theme.CodeFont}"
                                 FontSize="13"
                                 Background="Transparent"
                                 Foreground="{DynamicResource Theme.PrimaryAccentBrush}"
                                 BorderThickness="0"
                                 Padding="10"
                                 VerticalScrollBarVisibility="Auto" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="4"
                    Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="EDIT ESP32 HEX ARRAY"
                               Style="{StaticResource HeaderStyle}" />

                    <Border Grid.Row="1"
                            Background="{DynamicResource Theme.BackgroundBrush}"
                            CornerRadius="6"
                            BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                            BorderThickness="1"
                            Padding="2">
                        <TextBox x:Name="TxtHex"
                                 Text="{Binding TxtHex, UpdateSourceTrigger=PropertyChanged, Delay=400}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 FontFamily="{DynamicResource Theme.CodeFont}"
                                 FontSize="13"
                                 Background="Transparent"
                                 Foreground="{DynamicResource Theme.PrimaryAccentBrush}"
                                 BorderThickness="0"
                                 Padding="10"
                                 VerticalScrollBarVisibility="Auto" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
<Window x:Class="Hexel.Views.NewCanvasDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:Hexel.Core"
        xmlns:vm="clr-namespace:Hexel.ViewModels"
        Title="New Canvas"
        Width="380" Height="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Theme.BackgroundBrush}"
        FontFamily="{DynamicResource Theme.MainFont}"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="False"
        core:WindowChromeHelper.ForceRoundedCorners="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="34"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="5"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderThickness="{x:Static core:WindowChromeHelper.FallbackBorderThickness}" BorderBrush="{DynamicResource Theme.PanelBorderBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Border Grid.Row="0" Background="{DynamicResource Theme.MenuBarBackgroundBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                               Foreground="{DynamicResource Theme.TextMutedBrush}"
                               FontSize="12" VerticalAlignment="Center"
                               Margin="12,0,0,0" IsHitTestVisible="False"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Click="CaptionClose_Click" ToolTip="Close" Width="46" Height="34"
                                Style="{StaticResource CaptionCloseButtonStyle}">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="CREATE NEW CANVAS"
                   Style="{StaticResource HeaderStyle}"
                   FontSize="14"
                   Margin="0,0,0,20" />

        <!-- Preset dropdown -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock Text="Preset"
                       Foreground="{DynamicResource Theme.TextMainBrush}"
                       VerticalAlignment="Center"
                       Width="60" />
            <ComboBox x:Name="PresetComboBox"
                      Width="220"
                      Height="28"
                      Style="{StaticResource ModernComboBoxStyle}"
                      ItemsSource="{x:Static vm:MainViewModel.DisplayPresets}"
                      SelectionChanged="Preset_SelectionChanged" />
        </StackPanel>

        <!-- Width x Height -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock Text="Size"
                       Foreground="{DynamicResource Theme.TextMainBrush}"
                       VerticalAlignment="Center"
                       Width="60" />
            <TextBox x:Name="TxtWidth"
                     Text="16"
                     Width="80" Height="28"
                     Style="{StaticResource ModernTextBoxStyle}"
                     PreviewTextInput="NumberOnly"
                     Margin="0,0,8,0" />
            <TextBlock Text="×"
                       Foreground="{DynamicResource Theme.TextMutedBrush}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <TextBox x:Name="TxtHeight"
                     Text="16"
                     Width="80" Height="28"
                     Style="{StaticResource ModernTextBoxStyle}"
                     PreviewTextInput="NumberOnly" />
            <TextBlock Text="px"
                       Foreground="{DynamicResource Theme.TextMutedBrush}"
                       VerticalAlignment="Center"
                       Margin="6,0,0,0" />
        </StackPanel>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Width="80" Height="30"
                    Style="{StaticResource ModernButtonStyle}"
                    Margin="0,0,8,0"
                    Click="Cancel_Click" />
            <Button Content="Create"
                    Width="80" Height="30"
                    Style="{StaticResource ModernButtonStyle}"
                    Click="Create_Click"
                    IsDefault="True" />
        </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>

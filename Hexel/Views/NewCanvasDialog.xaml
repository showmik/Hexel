<Window x:Class="Hexel.Views.NewCanvasDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Hexel.ViewModels"
        Title="New Canvas"
        Width="380" Height="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Theme.BackgroundBrush}"
        FontFamily="{DynamicResource Theme.MainFont}"
        ShowInTaskbar="False">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="CREATE NEW CANVAS"
                   Style="{StaticResource HeaderStyle}"
                   FontSize="14"
                   Margin="0,0,0,20" />

        <!-- Preset dropdown -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock Text="Preset"
                       Foreground="{DynamicResource Theme.TextMainBrush}"
                       VerticalAlignment="Center"
                       Width="60" />
            <ComboBox Width="220"
                      Height="28"
                      Style="{StaticResource ModernComboBoxStyle}"
                      ItemsSource="{x:Static vm:MainViewModel.DisplayPresets}"
                      SelectedItem="{Binding SelectedPreset}" />
        </StackPanel>

        <!-- Width x Height -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock Text="Size"
                       Foreground="{DynamicResource Theme.TextMainBrush}"
                       VerticalAlignment="Center"
                       Width="60" />
            <TextBox Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}"
                     Width="80" Height="28"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Margin="0,0,8,0" />
            <TextBlock Text="×"
                       Foreground="{DynamicResource Theme.TextMutedBrush}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <TextBox Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}"
                     Width="80" Height="28"
                     Style="{StaticResource ModernTextBoxStyle}" />
            <TextBlock Text="px"
                       Foreground="{DynamicResource Theme.TextMutedBrush}"
                       VerticalAlignment="Center"
                       Margin="6,0,0,0" />
        </StackPanel>

        <!-- Validation error -->
        <TextBlock Grid.Row="3"
                   Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource Theme.DangerBrush}"
                   FontSize="11"
                   Margin="0,0,0,6"
                   TextWrapping="Wrap">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding HasError}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Width="80" Height="30"
                    Style="{StaticResource ModernButtonStyle}"
                    Margin="0,0,8,0"
                    Command="{Binding CancelCommand}" />
            <Button Content="Create"
                    Width="80" Height="30"
                    Style="{StaticResource ModernButtonStyle}"
                    Command="{Binding CreateCommand}"
                    IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>

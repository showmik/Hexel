<Window x:Class="Hexel.Views.ResizeCanvasDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Hexel.ViewModels"
        Title="Resize Canvas"
        Width="400" Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Theme.BackgroundBrush}"
        FontFamily="{DynamicResource Theme.MainFont}"
        ShowInTaskbar="False">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="RESIZE CANVAS"
                   Style="{StaticResource HeaderStyle}"
                   FontSize="14"
                   Margin="0,0,0,16" />

        <!-- Current size -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock Text="Current"
                       Foreground="{DynamicResource Theme.TextMutedBrush}"
                       VerticalAlignment="Center"
                       Width="70" />
            <TextBlock Text="{Binding CurrentSizeText}"
                       Foreground="{DynamicResource Theme.TextMainBrush}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- Preset dropdown -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock Text="Preset"
                       Foreground="{DynamicResource Theme.TextMainBrush}"
                       VerticalAlignment="Center"
                       Width="70" />
            <ComboBox Width="210"
                      Height="28"
                      Style="{StaticResource ModernComboBoxStyle}"
                      ItemsSource="{x:Static vm:MainViewModel.DisplayPresets}"
                      SelectedItem="{Binding SelectedPreset}" />
        </StackPanel>

        <!-- New Width x Height -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock Text="New Size"
                       Foreground="{DynamicResource Theme.TextMainBrush}"
                       VerticalAlignment="Center"
                       Width="70" />
            <TextBox Text="{Binding NewWidth, UpdateSourceTrigger=PropertyChanged}"
                     Width="70" Height="28"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Margin="0,0,8,0" />
            <TextBlock Text="×"
                       Foreground="{DynamicResource Theme.TextMutedBrush}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <TextBox Text="{Binding NewHeight, UpdateSourceTrigger=PropertyChanged}"
                     Width="70" Height="28"
                     Style="{StaticResource ModernTextBoxStyle}" />
            <TextBlock Text="px"
                       Foreground="{DynamicResource Theme.TextMutedBrush}"
                       VerticalAlignment="Center"
                       Margin="6,0,0,0" />
        </StackPanel>

        <!-- Anchor grid -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Anchor"
                       Foreground="{DynamicResource Theme.TextMainBrush}"
                       VerticalAlignment="Center"
                       Width="70" />
            <Border Background="{DynamicResource Theme.PanelBackgroundBrush}"
                    CornerRadius="4"
                    Padding="3"
                    VerticalAlignment="Center"
                    ToolTip="Where existing content is pinned">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <RadioButton Grid.Row="0" Grid.Column="0" GroupName="Anchor"
                                 Style="{StaticResource AnchorDotStyle}"
                                 IsChecked="{Binding SelectedAnchor,
                                     Converter={StaticResource EnumToBoolConverter},
                                     ConverterParameter=TopLeft}" />
                    <RadioButton Grid.Row="0" Grid.Column="1" GroupName="Anchor"
                                 Style="{StaticResource AnchorDotStyle}"
                                 IsChecked="{Binding SelectedAnchor,
                                     Converter={StaticResource EnumToBoolConverter},
                                     ConverterParameter=TopCenter}" />
                    <RadioButton Grid.Row="0" Grid.Column="2" GroupName="Anchor"
                                 Style="{StaticResource AnchorDotStyle}"
                                 IsChecked="{Binding SelectedAnchor,
                                     Converter={StaticResource EnumToBoolConverter},
                                     ConverterParameter=TopRight}" />

                    <RadioButton Grid.Row="1" Grid.Column="0" GroupName="Anchor"
                                 Style="{StaticResource AnchorDotStyle}"
                                 IsChecked="{Binding SelectedAnchor,
                                     Converter={StaticResource EnumToBoolConverter},
                                     ConverterParameter=CenterLeft}" />
                    <RadioButton Grid.Row="1" Grid.Column="1" GroupName="Anchor"
                                 Style="{StaticResource AnchorDotStyle}"
                                 IsChecked="{Binding SelectedAnchor,
                                     Converter={StaticResource EnumToBoolConverter},
                                     ConverterParameter=Center}" />
                    <RadioButton Grid.Row="1" Grid.Column="2" GroupName="Anchor"
                                 Style="{StaticResource AnchorDotStyle}"
                                 IsChecked="{Binding SelectedAnchor,
                                     Converter={StaticResource EnumToBoolConverter},
                                     ConverterParameter=CenterRight}" />

                    <RadioButton Grid.Row="2" Grid.Column="0" GroupName="Anchor"
                                 Style="{StaticResource AnchorDotStyle}"
                                 IsChecked="{Binding SelectedAnchor,
                                     Converter={StaticResource EnumToBoolConverter},
                                     ConverterParameter=BottomLeft}" />
                    <RadioButton Grid.Row="2" Grid.Column="1" GroupName="Anchor"
                                 Style="{StaticResource AnchorDotStyle}"
                                 IsChecked="{Binding SelectedAnchor,
                                     Converter={StaticResource EnumToBoolConverter},
                                     ConverterParameter=BottomCenter}" />
                    <RadioButton Grid.Row="2" Grid.Column="2" GroupName="Anchor"
                                 Style="{StaticResource AnchorDotStyle}"
                                 IsChecked="{Binding SelectedAnchor,
                                     Converter={StaticResource EnumToBoolConverter},
                                     ConverterParameter=BottomRight}" />
                </Grid>
            </Border>
        </StackPanel>

        <!-- Validation error -->
        <TextBlock Grid.Row="5"
                   Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource Theme.DangerBrush}"
                   FontSize="11"
                   Margin="0,0,0,6"
                   TextWrapping="Wrap">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding HasError}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Width="80" Height="30"
                    Style="{StaticResource ModernButtonStyle}"
                    Margin="0,0,8,0"
                    Command="{Binding CancelCommand}" />
            <Button Content="Resize"
                    Width="80" Height="30"
                    Style="{StaticResource ModernButtonStyle}"
                    Command="{Binding ResizeCommand}"
                    IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="Hexel.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Hexel"
        Height="400" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource Theme.PanelBackgroundBrush}"
        Foreground="{DynamicResource Theme.TextMainBrush}"
        FontFamily="{DynamicResource Theme.MainFont}">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextMainBrush}" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="HyperlinkStyle" TargetType="Hyperlink">
            <Setter Property="Foreground" Value="{DynamicResource Theme.PrimaryAccentBrush}" />
            <Setter Property="TextDecorations" Value="None" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="TextDecorations" Value="Underline" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <!-- App Icon/Logo Substitute -->
            <Border Width="64" Height="64" Background="{DynamicResource Theme.PrimaryAccentBrush}" CornerRadius="12" Margin="0,0,20,0">
                <TextBlock Text="H" FontSize="40" FontWeight="Bold" Foreground="White" 
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Hexel" FontSize="36" FontWeight="Bold" Margin="0,0,0,-4" />
                <TextBlock Text="Version 1.0.0" FontSize="14" Foreground="{DynamicResource Theme.TextMutedBrush}" />
            </StackPanel>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Hexel is a powerful sprite editor explicitly tailored for embedded displays, monochromatic OLEDs, and retro pixel art." 
                           FontSize="14" Margin="0,0,0,16"/>

                <TextBlock Text="Credits" FontSize="18" FontWeight="SemiBold" Margin="0,16,0,8" />
                <TextBlock>
                    <Run Text="Developed by "/>
                    <Run Text="The Hexel Team" FontWeight="Bold" />
                </TextBlock>
                <TextBlock>
                    <Run Text="Inspired by standard pixel art tools like Aseprite and Photoshop."/>
                </TextBlock>

                <TextBlock Text="Open Source Libraries" FontSize="18" FontWeight="SemiBold" Margin="0,16,0,8" />
                <TextBlock Text="• CommunityToolkit.Mvvm" />
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="OK" IsDefault="True" Click="BtnOk_Click" Width="80" Style="{StaticResource ModernButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>

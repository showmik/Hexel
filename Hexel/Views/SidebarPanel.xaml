<UserControl x:Class="Hexel.Views.SidebarPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:core="clr-namespace:Hexel.Core"
             xmlns:rendering="clr-namespace:Hexel.Rendering"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="320">

    <Border Background="{DynamicResource Theme.RightSidebarBackgroundBrush}"
            BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
            BorderThickness="1,0,0,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Style="{StaticResource {x:Type ScrollViewer}}">
            <StackPanel>

                <!-- ═══════════════════════════════════════════════════════
                     EXPORT PANEL
                     ═══════════════════════════════════════════════════════ -->
                <Border Background="{DynamicResource Theme.SurfaceOverlayBrush}"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                        BorderThickness="1"
                        Margin="12,12,12,0"
                        Padding="16,20,16,20">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="8" ShadowDepth="2" Direction="270" />
                    </Border.Effect>
                <StackPanel>
                    <TextBlock Text="EXPORT"
                               Style="{StaticResource HeaderStyle}"
                               Margin="0,0,0,16"/>

                    <!-- Format selector -->
                    <TextBlock Text="Format"
                               Foreground="{DynamicResource Theme.TextMutedBrush}"
                               FontSize="11"
                               Margin="0,0,0,4"/>
                    <ComboBox x:Name="CboFormat"
                              Style="{StaticResource ModernComboBoxStyle}"
                              Height="30"
                              Margin="0,0,0,10"
                              SelectedIndex="0"
                              SelectionChanged="CboFormat_SelectionChanged">
                        <ComboBoxItem Content="Adafruit GFX  (PROGMEM, MSB first)"    Tag="AdafruitGfx"/>
                        <ComboBoxItem Content="u8g2 drawBitmap  (U8X8_PROGMEM, MSB)"  Tag="U8g2DrawBitmap"/>
                        <ComboBoxItem Content="u8g2 drawXBM  (PROGMEM, LSB first)"    Tag="U8g2DrawXBM"/>
                        <ComboBoxItem Content="Plain C array  (no PROGMEM)"            Tag="PlainCArray"/>
                        <ComboBoxItem Content="MicroPython bytearray  (MONO_HLSB)"     Tag="MicroPython"/>
                        <ComboBoxItem Content="Raw hex  (no wrapper)"                  Tag="RawHex"/>
                        <ComboBoxItem Content="Raw binary  (no wrapper)"               Tag="RawBinary"/>
                    </ComboBox>

                    <!-- Sprite name -->
                    <TextBlock Text="Variable / sprite name"
                               Foreground="{DynamicResource Theme.TextMutedBrush}"
                               FontSize="11"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtSpriteName"
                             Style="{StaticResource ModernTextBoxStyle}"
                             Height="30"
                             FontFamily="{DynamicResource Theme.CodeFont}"
                             Text="{Binding SpriteName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"
                             ToolTip="Will be sanitised to a valid C/Python identifier"/>

                    <!-- ─── Code structure options (expander) ──────── -->
                    <Border BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                            BorderThickness="0,1,0,0"
                            Margin="0,0,0,16">
                        <Expander Style="{StaticResource ModernExpanderStyle}"
                                  IsExpanded="False"
                                  Margin="0,8,0,0">
                            <Expander.Header>
                                <TextBlock Text="CODE STRUCTURE OPTIONS"
                                           Style="{StaticResource HeaderStyle}"
                                           Margin="0"
                                           VerticalAlignment="Center"/>
                            </Expander.Header>
                            <StackPanel Margin="0,16,0,0">

                                <!-- Checkbox Grid for perfect alignment -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="135"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <CheckBox Grid.Row="0" Grid.Column="0" Content="Usage comment"
                                              IsChecked="{Binding IncludeUsageComment}"
                                              Foreground="{DynamicResource Theme.TextMutedBrush}"
                                              FontSize="12"
                                              Margin="0,0,0,8"/>
                                    <CheckBox Grid.Row="0" Grid.Column="1" Content="Width/height constants"
                                              IsChecked="{Binding IncludeDimensionConstants}"
                                              Foreground="{DynamicResource Theme.TextMutedBrush}"
                                              FontSize="12"
                                              Margin="0,0,0,8"/>

                                    <CheckBox Grid.Row="1" Grid.Column="0" Content="Row comments"
                                              IsChecked="{Binding IncludeRowComments}"
                                              Foreground="{DynamicResource Theme.TextMutedBrush}"
                                              FontSize="12"
                                              Margin="0,0,0,8"/>
                                    <CheckBox Grid.Row="1" Grid.Column="1" Content="Comma separator"
                                              IsChecked="{Binding UseCommaSeparator}"
                                              Foreground="{DynamicResource Theme.TextMutedBrush}"
                                              FontSize="12"
                                              Margin="0,0,0,8"/>

                                    <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Content="Array size"
                                              IsChecked="{Binding IncludeArraySize}"
                                              Foreground="{DynamicResource Theme.TextMutedBrush}"
                                              FontSize="12"/>
                                </Grid>

                                <!-- Bytes per line -->
                                <TextBlock Text="Bytes per line"
                                           Foreground="{DynamicResource Theme.TextMutedBrush}"
                                           FontSize="11"
                                           Margin="0,0,0,5"/>
                                <WrapPanel Margin="0,0,0,12">
                                    <RadioButton x:Name="RbBpl0"
                                                 Content="canvas width"
                                                 GroupName="BytesPerLine"
                                                 Style="{StaticResource ChipButtonStyle}"
                                                 IsChecked="True"
                                                 Checked="BplChip_Checked"
                                                 Tag="0"/>
                                    <RadioButton x:Name="RbBpl4"
                                                 Content="4"
                                                 GroupName="BytesPerLine"
                                                 Style="{StaticResource ChipButtonStyle}"
                                                 Checked="BplChip_Checked"
                                                 Tag="4"/>
                                    <RadioButton x:Name="RbBpl8"
                                                 Content="8"
                                                 GroupName="BytesPerLine"
                                                 Style="{StaticResource ChipButtonStyle}"
                                                 Checked="BplChip_Checked"
                                                 Tag="8"/>
                                    <RadioButton x:Name="RbBpl16"
                                                 Content="16"
                                                 GroupName="BytesPerLine"
                                                 Style="{StaticResource ChipButtonStyle}"
                                                 Checked="BplChip_Checked"
                                                 Tag="16"/>
                                </WrapPanel>

                                <!-- Hex case -->
                                <TextBlock Text="Hex digits"
                                           Foreground="{DynamicResource Theme.TextMutedBrush}"
                                           FontSize="11"
                                           Margin="0,0,0,5"/>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="RbHexUpper"
                                                 Content="0xFF"
                                                 GroupName="HexCase"
                                                 Style="{StaticResource ChipButtonStyle}"
                                                 IsChecked="True"
                                                 Checked="HexCase_Checked"
                                                 Tag="upper"/>
                                    <RadioButton x:Name="RbHexLower"
                                                 Content="0xff"
                                                 GroupName="HexCase"
                                                 Style="{StaticResource ChipButtonStyle}"
                                                 Checked="HexCase_Checked"
                                                 Tag="lower"/>
                                </StackPanel>

                            </StackPanel>
                        </Expander>
                    </Border>

                    <!-- ─── Code output box with header bar ──────── -->
                    <Border Background="{DynamicResource Theme.BackgroundBrush}"
                            CornerRadius="6"
                            BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                            BorderThickness="1"
                            ClipToBounds="True"
                            Height="260">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Output header bar -->
                            <Border Grid.Row="0" Padding="10,6"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                                    Background="{DynamicResource Theme.SurfaceOverlayBrush}">
                                <Grid>
                                    <TextBlock Text="OUTPUT"
                                               Foreground="{DynamicResource Theme.TextMutedBrush}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Opacity="0.8"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Code content -->
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto"
                                          Background="Transparent"
                                          Padding="8">
                                <rendering:SyntaxHighlightBox x:Name="CodeOutputBox"
                                                              FontFamily="{DynamicResource Theme.CodeFont}"
                                                              FontSize="12"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Generate Code + Copy buttons -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="⟳  Generate Code"
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Padding="8,8"
                                FontSize="11.5"
                                Margin="0,0,8,0"
                                Command="{Binding GenerateCodeCommand}"
                                ToolTip="Generate code from current canvas data"/>

                        <Button Grid.Column="1"
                                Content="⎘ Copy"
                                Style="{StaticResource ModernButtonStyle}"
                                Padding="16,8"
                                FontSize="11.5"
                                Command="{Binding CopyExportedCodeCommand}"
                                ToolTip="Copy generated code to clipboard"/>
                    </Grid>

                    <!-- Status and Stats -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Stale indicator -->
                        <TextBlock Grid.Column="0"
                                   Text="⟳ Code is outdated"
                                   Foreground="{DynamicResource Theme.WarningBrush}"
                                   FontSize="10.5"
                                   Opacity="0.85">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Hidden"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCodeStale}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Export Stats -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ExportStats}"
                                   Foreground="{DynamicResource Theme.TextMutedBrush}"
                                   FontSize="10"
                                   FontFamily="{DynamicResource Theme.CodeFont}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Opacity="0.8"/>
                    </Grid>

                </StackPanel>
                </Border>

                <!-- ═══════════════════════════════════════════════════════
                     IMPORT FROM CODE
                     ═══════════════════════════════════════════════════════ -->
                <Border Background="{DynamicResource Theme.SurfaceOverlayBrush}"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                        BorderThickness="1"
                        Margin="12,12,12,0"
                        Padding="16,20,16,20">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="8" ShadowDepth="2" Direction="270" />
                    </Border.Effect>
                <StackPanel>
                    <TextBlock Text="IMPORT"
                               Style="{StaticResource HeaderStyle}"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="Import sprite data from Adafruit GFX, u8g2, plain C array, or raw hex code. Dimensions and variable name are auto-detected."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Theme.TextMutedBrush}"
                               FontSize="11"
                               Margin="0,0,0,16"
                               LineHeight="18"/>
                    <Button Content="Import from Code…"
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Click="ImportFromCode_Click"
                            ToolTip="Open the Import from Code dialog (Ctrl+Shift+I)"
                            Padding="8,8"
                            FontSize="11.5"/>
                </StackPanel>
                </Border>

                <!-- ═══════════════════════════════════════════════════════
                     OLED PREVIEW (collapsible, dynamic size)
                     ═══════════════════════════════════════════════════════ -->
                <Border Background="{DynamicResource Theme.SurfaceOverlayBrush}"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                        BorderThickness="1"
                        Margin="12,12,12,12"
                        Padding="16,20,16,20">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="8" ShadowDepth="2" Direction="270" />
                    </Border.Effect>
                <StackPanel>
                    <Expander Style="{StaticResource ModernExpanderStyle}"
                              IsExpanded="True">
                        <Expander.Header>
                            <TextBlock Text="DISPLAY PREVIEW"
                                       Style="{StaticResource HeaderStyle}"
                                       Margin="0"
                                       VerticalAlignment="Center"/>
                        </Expander.Header>
                        <StackPanel Margin="0,16,0,0">

                            <!-- Display options -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0"
                                          Height="26"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectedIndex="{Binding PreviewDisplayTypeIndex}">
                                    <ComboBoxItem Content="Generic (White)"/>
                                    <ComboBoxItem Content="SSD1306 (Blue)"/>
                                    <ComboBoxItem Content="SSD1306 (Green)"/>
                                    <ComboBoxItem Content="e-Paper"/>
                                </ComboBox>

                                <Border Grid.Column="1"
                                        Background="{DynamicResource Theme.BackgroundBrush}"
                                        BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="8,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="-" Width="24" Height="24" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource Theme.TextMainBrush}" Command="{Binding DecreasePreviewScaleCommand}"/>
                                        <TextBlock Text="{Binding PreviewScale}" VerticalAlignment="Center" Width="24" TextAlignment="Center" Foreground="{DynamicResource Theme.TextMainBrush}"/>
                                        <Button Content="+" Width="24" Height="24" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource Theme.TextMainBrush}" Command="{Binding IncreasePreviewScaleCommand}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Dynamic canvas preview -->
                            <Border BorderBrush="{DynamicResource Theme.BackgroundBrush}"
                                    BorderThickness="3"
                                    CornerRadius="5"
                                    HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"
                                                Value="{DynamicResource Theme.CanvasBackgroundBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDisplayInverted}"
                                                         Value="True">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource Theme.PrimaryAccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource Theme.PreviewBackgroundBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDisplayInverted}"
                                                             Value="True">
                                                    <Setter Property="Background"
                                                            Value="{DynamicResource Theme.PreviewDrawingBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Image Source="{Binding PreviewBitmap}"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                                           Stretch="Fill"
                                           Width="{Binding PreviewWidth}"
                                           Height="{Binding PreviewHeight}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="10"
                                       Foreground="{DynamicResource Theme.TextMutedBrush}">
                                <Run Text="Preview: "/>
                                <Run Text="{Binding SpriteState.Width, Mode=OneWay}"/>
                                <Run Text="×"/>
                                <Run Text="{Binding SpriteState.Height, Mode=OneWay}"/>
                                <Run Text=" px "/>
                                <Run Text="{Binding PreviewScaleText, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Expander>
                </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>

<UserControl x:Class="Hexel.Views.SidebarPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="300">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Style="{StaticResource {x:Type ScrollViewer}}">
        <StackPanel>
            <!-- OLED Preview -->
            <Border Style="{StaticResource PanelStyle}"
                    Padding="16,4,16,16"
                    Margin="0,0,0,15">
                <Expander Style="{StaticResource ModernExpanderStyle}"
                          IsExpanded="True">
                    <Expander.Header>
                        <TextBlock Text="OLED PREVIEW (128×64)"
                                   Style="{StaticResource HeaderStyle}"
                                   VerticalAlignment="Center" />
                    </Expander.Header>
                    <StackPanel Margin="0,12,0,0">
                        <Border x:Name="OledBorder"
                                BorderBrush="{DynamicResource Theme.BackgroundBrush}"
                                BorderThickness="4"
                                Width="256"
                                Height="128"
                                HorizontalAlignment="Left"
                                CornerRadius="6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background"
                                            Value="{DynamicResource Theme.CanvasBackgroundBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDisplayInverted}"
                                                     Value="True">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource Theme.PrimaryAccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid x:Name="PreviewGridContainer">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Background"
                                                Value="{DynamicResource Theme.OledOffBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDisplayInverted}"
                                                         Value="True">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource Theme.OledOnBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Image Source="{Binding PreviewBitmap}"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                       Stretch="Fill"
                                       Width="{Binding PreviewWidth}"
                                       Height="{Binding PreviewHeight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <TextBlock Text="* Sprite shown relative to total 128×64 screen area"
                                   Foreground="{DynamicResource Theme.TextMutedBrush}"
                                   FontSize="11"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Expander>
            </Border>

            <!-- Binary output -->
            <Border Style="{StaticResource PanelStyle}"
                    Padding="16,4,16,16"
                    Margin="0,0,0,15">
                <Expander Style="{StaticResource ModernExpanderStyle}"
                          IsExpanded="True">
                    <Expander.Header>
                        <Grid HorizontalAlignment="Stretch"
                              Margin="0,0,16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="BINARY REPRESENTATION"
                                       Style="{StaticResource HeaderStyle}"
                                       VerticalAlignment="Center" />
                            <CheckBox Grid.Column="1"
                                      Content="Add commas"
                                      IsChecked="{Binding BinaryUseComma}"
                                      Foreground="{DynamicResource Theme.TextMutedBrush}"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Right" />
                        </Grid>
                    </Expander.Header>
                    <Border Background="{DynamicResource Theme.BackgroundBrush}"
                            CornerRadius="6"
                            BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                            BorderThickness="1"
                            Padding="2"
                            Margin="0,12,0,0">
                        <TextBox x:Name="TxtBinary"
                                 Text="{Binding TxtBinary, UpdateSourceTrigger=PropertyChanged, Delay=400}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 FontFamily="{DynamicResource Theme.CodeFont}"
                                 FontSize="13"
                                 Background="Transparent"
                                 Foreground="{DynamicResource Theme.CodeTxtBrush}"
                                 BorderThickness="0"
                                 Padding="10"
                                 VerticalScrollBarVisibility="Auto" />
                    </Border>
                </Expander>
            </Border>

            <!-- HEX output -->
            <Border Style="{StaticResource PanelStyle}"
                    Padding="16,4,16,16">
                <Expander Style="{StaticResource ModernExpanderStyle}"
                          IsExpanded="True">
                    <Expander.Header>
                        <Grid HorizontalAlignment="Stretch"
                              Margin="0,0,16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="HEX REPRESENTATION"
                                       Style="{StaticResource HeaderStyle}"
                                       VerticalAlignment="Center" />
                            <CheckBox Grid.Column="1"
                                      Content="Add commas"
                                      IsChecked="{Binding HexUseComma}"
                                      Foreground="{DynamicResource Theme.TextMutedBrush}"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Right" />
                        </Grid>
                    </Expander.Header>
                    <Border Background="{DynamicResource Theme.BackgroundBrush}"
                            CornerRadius="6"
                            BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                            BorderThickness="1"
                            Padding="2"
                            Margin="0,12,0,0">
                        <TextBox x:Name="TxtHex"
                                 Text="{Binding TxtHex, UpdateSourceTrigger=PropertyChanged, Delay=400}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 FontFamily="{DynamicResource Theme.CodeFont}"
                                 FontSize="13"
                                 Background="Transparent"
                                 Foreground="{DynamicResource Theme.CodeTxtBrush}"
                                 BorderThickness="0"
                                 Padding="10"
                                 VerticalScrollBarVisibility="Auto" />
                    </Border>
                </Expander>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

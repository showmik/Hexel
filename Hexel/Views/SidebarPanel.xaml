<UserControl x:Class="Hexel.Views.SidebarPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:core="clr-namespace:Hexel.Core"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="320">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Style="{StaticResource {x:Type ScrollViewer}}">
        <StackPanel>

            <!-- ═══════════════════════════════════════════════════════
                 EXPORT PANEL
                 ═══════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource PanelStyle}"
                    Padding="16,8,16,16"
                    Margin="0,0,0,12">
                <StackPanel>

                    <!-- Header row -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="EXPORT"
                                   Style="{StaticResource HeaderStyle}"
                                   Margin="0"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Content="⎘  Copy"
                                Style="{StaticResource AccentButtonStyle}"
                                Padding="12,5"
                                FontSize="11"
                                Command="{Binding CopyExportedCodeCommand}"
                                ToolTip="Copy generated code to clipboard"/>
                    </Grid>

                    <!-- Format selector -->
                    <TextBlock Text="Format"
                               Foreground="{DynamicResource Theme.TextMutedBrush}"
                               FontSize="11"
                               Margin="0,0,0,4"/>
                    <ComboBox x:Name="CboFormat"
                              Style="{StaticResource ModernComboBoxStyle}"
                              Height="30"
                              Margin="0,0,0,10"
                              SelectedIndex="0"
                              SelectionChanged="CboFormat_SelectionChanged">
                        <ComboBoxItem Content="Adafruit GFX  (PROGMEM, MSB first)"    Tag="AdafruitGfx"/>
                        <ComboBoxItem Content="u8g2 drawBitmap  (U8X8_PROGMEM, MSB)"  Tag="U8g2DrawBitmap"/>
                        <ComboBoxItem Content="u8g2 drawXBM  (PROGMEM, LSB first)"    Tag="U8g2DrawXBM"/>
                        <ComboBoxItem Content="Plain C array  (no PROGMEM)"            Tag="PlainCArray"/>
                        <ComboBoxItem Content="MicroPython bytearray  (MONO_HLSB)"     Tag="MicroPython"/>
                        <ComboBoxItem Content="Raw hex  (no wrapper)"                  Tag="RawHex"/>
                        <ComboBoxItem Content="Raw binary  (no wrapper)"               Tag="RawBinary"/>
                    </ComboBox>

                    <!-- Sprite name -->
                    <TextBlock Text="Variable / sprite name"
                               Foreground="{DynamicResource Theme.TextMutedBrush}"
                               FontSize="11"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtSpriteName"
                             Style="{StaticResource ModernTextBoxStyle}"
                             Height="30"
                             FontFamily="{DynamicResource Theme.CodeFont}"
                             Text="{Binding SpriteName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"
                             ToolTip="Will be sanitised to a valid C/Python identifier"/>

                    <!-- ─── Code structure options (expander) ──────── -->
                    <Border BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                            BorderThickness="0,1,0,0"
                            Margin="0,0,0,10">
                        <Expander Style="{StaticResource ModernExpanderStyle}"
                                  IsExpanded="False"
                                  Margin="0,4,0,0">
                            <Expander.Header>
                                <TextBlock Text="CODE STRUCTURE OPTIONS"
                                           Style="{StaticResource HeaderStyle}"
                                           Margin="0"
                                           VerticalAlignment="Center"/>
                            </Expander.Header>
                            <StackPanel Margin="0,12,0,0">

                                <!-- Checkboxes row 1 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <CheckBox Content="Usage comment"
                                              IsChecked="{Binding IncludeUsageComment}"
                                              Foreground="{DynamicResource Theme.TextMutedBrush}"
                                              FontSize="12"
                                              Margin="0,0,16,0"/>
                                    <CheckBox Content="Width/height constants"
                                              IsChecked="{Binding IncludeDimensionConstants}"
                                              Foreground="{DynamicResource Theme.TextMutedBrush}"
                                              FontSize="12"/>
                                </StackPanel>

                                <!-- Checkboxes row 2 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <CheckBox Content="Row comments"
                                              IsChecked="{Binding IncludeRowComments}"
                                              Foreground="{DynamicResource Theme.TextMutedBrush}"
                                              FontSize="12"
                                              Margin="0,0,16,0"/>
                                    <CheckBox Content="Comma separator"
                                              IsChecked="{Binding UseCommaSeparator}"
                                              Foreground="{DynamicResource Theme.TextMutedBrush}"
                                              FontSize="12"
                                              Margin="0,0,16,0"/>
                                    <CheckBox Content="Array size"
                                              IsChecked="{Binding IncludeArraySize}"
                                              Foreground="{DynamicResource Theme.TextMutedBrush}"
                                              FontSize="12"/>
                                </StackPanel>

                                <!-- Bytes per line -->
                                <TextBlock Text="Bytes per line"
                                           Foreground="{DynamicResource Theme.TextMutedBrush}"
                                           FontSize="11"
                                           Margin="0,0,0,5"/>
                                <WrapPanel Margin="0,0,0,10">
                                    <RadioButton x:Name="RbBpl0"
                                                 Content="canvas width"
                                                 GroupName="BytesPerLine"
                                                 Style="{StaticResource ChipButtonStyle}"
                                                 IsChecked="True"
                                                 Checked="BplChip_Checked"
                                                 Tag="0"/>
                                    <RadioButton x:Name="RbBpl4"
                                                 Content="4"
                                                 GroupName="BytesPerLine"
                                                 Style="{StaticResource ChipButtonStyle}"
                                                 Checked="BplChip_Checked"
                                                 Tag="4"/>
                                    <RadioButton x:Name="RbBpl8"
                                                 Content="8"
                                                 GroupName="BytesPerLine"
                                                 Style="{StaticResource ChipButtonStyle}"
                                                 Checked="BplChip_Checked"
                                                 Tag="8"/>
                                    <RadioButton x:Name="RbBpl16"
                                                 Content="16"
                                                 GroupName="BytesPerLine"
                                                 Style="{StaticResource ChipButtonStyle}"
                                                 Checked="BplChip_Checked"
                                                 Tag="16"/>
                                </WrapPanel>

                                <!-- Hex case -->
                                <TextBlock Text="Hex digits"
                                           Foreground="{DynamicResource Theme.TextMutedBrush}"
                                           FontSize="11"
                                           Margin="0,0,0,5"/>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="RbHexUpper"
                                                 Content="0xFF"
                                                 GroupName="HexCase"
                                                 Style="{StaticResource ChipButtonStyle}"
                                                 IsChecked="True"
                                                 Checked="HexCase_Checked"
                                                 Tag="upper"/>
                                    <RadioButton x:Name="RbHexLower"
                                                 Content="0xff"
                                                 GroupName="HexCase"
                                                 Style="{StaticResource ChipButtonStyle}"
                                                 Checked="HexCase_Checked"
                                                 Tag="lower"/>
                                </StackPanel>

                            </StackPanel>
                        </Expander>
                    </Border>

                    <!-- ─── Code output box ────────────────────────── -->
                    <Border Background="{DynamicResource Theme.BackgroundBrush}"
                            CornerRadius="6"
                            BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                            BorderThickness="1"
                            Padding="1"
                            Height="260">
                        <RichTextBox x:Name="RtbOutput"
                                     IsReadOnly="True"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontFamily="{DynamicResource Theme.CodeFont}"
                                     FontSize="12"
                                     Padding="8"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     IsDocumentEnabled="False"
                                     AcceptsReturn="False"/>
                    </Border>

                    <!-- Stats + copy row -->
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding ExportStats}"
                                   Foreground="{DynamicResource Theme.TextMutedBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   FontFamily="{DynamicResource Theme.CodeFont}"/>
                        <Button Grid.Column="1"
                                Content="Copy"
                                Style="{StaticResource ModernButtonStyle}"
                                Padding="12,5"
                                FontSize="11"
                                Command="{Binding CopyExportedCodeCommand}"
                                ToolTip="Copy generated code to clipboard"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════
                 IMPORT FROM CODE (collapsible)
                 ═══════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource PanelStyle}"
                    Padding="16,8,16,16"
                    Margin="0,0,0,12">
                <Expander Style="{StaticResource ModernExpanderStyle}"
                          IsExpanded="False">
                    <Expander.Header>
                        <TextBlock Text="IMPORT FROM CODE"
                                   Style="{StaticResource HeaderStyle}"
                                   Margin="0"
                                   VerticalAlignment="Center"/>
                    </Expander.Header>
                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="Paste Adafruit GFX / raw hex / C array code here and click Parse."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource Theme.TextMutedBrush}"
                                   FontSize="11"
                                   Margin="0,0,0,8"/>
                        <Border Background="{DynamicResource Theme.BackgroundBrush}"
                                CornerRadius="6"
                                BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                                BorderThickness="1"
                                Padding="2"
                                Margin="0,0,0,8">
                            <TextBox x:Name="TxtImport"
                                     Text="{Binding ImportCode, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="90"
                                     MaxHeight="160"
                                     FontFamily="{DynamicResource Theme.CodeFont}"
                                     FontSize="12"
                                     Background="Transparent"
                                     Foreground="{DynamicResource Theme.CodeTxtBrush}"
                                     BorderThickness="0"
                                     Padding="8"
                                     VerticalScrollBarVisibility="Auto"/>
                        </Border>
                        <Button Content="Parse &amp; Apply to Canvas"
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Command="{Binding ImportFromCodeCommand}"
                                ToolTip="Parse the pasted code and update the canvas"/>
                        <TextBlock Text="* Canvas dimensions must match the pasted data."
                                   Foreground="{DynamicResource Theme.TextMutedBrush}"
                                   FontSize="10"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Expander>
            </Border>

            <!-- ═══════════════════════════════════════════════════════
                 OLED PREVIEW (collapsible, dynamic size)
                 ═══════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource PanelStyle}"
                    Padding="16,8,16,16">
                <Expander Style="{StaticResource ModernExpanderStyle}"
                          IsExpanded="False">
                    <Expander.Header>
                        <TextBlock Text="DISPLAY PREVIEW"
                                   Style="{StaticResource HeaderStyle}"
                                   Margin="0"
                                   VerticalAlignment="Center"/>
                    </Expander.Header>
                    <StackPanel Margin="0,12,0,0">
                        <!-- Dynamic canvas preview — Width/Height bound to sprite dimensions -->
                        <Border BorderBrush="{DynamicResource Theme.BackgroundBrush}"
                                BorderThickness="3"
                                CornerRadius="5"
                                HorizontalAlignment="Left">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background"
                                            Value="{DynamicResource Theme.CanvasBackgroundBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDisplayInverted}"
                                                     Value="True">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource Theme.PrimaryAccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Background"
                                                Value="{DynamicResource Theme.OledOffBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDisplayInverted}"
                                                         Value="True">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource Theme.OledOnBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <!-- PreviewWidth/Height are pixel-doubled sprite dimensions,
                                     so the preview is always crisp and fills naturally -->
                                <Image Source="{Binding PreviewBitmap}"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                       Stretch="Fill"
                                       Width="{Binding PreviewWidth}"
                                       Height="{Binding PreviewHeight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <TextBlock Margin="0,8,0,0"
                                   FontSize="10"
                                   Foreground="{DynamicResource Theme.TextMutedBrush}">
                            <Run Text="Preview: "/>
                            <Run Text="{Binding SpriteState.Width, Mode=OneWay}"/>
                            <Run Text="×"/>
                            <Run Text="{Binding SpriteState.Height, Mode=OneWay}"/>
                            <Run Text=" px (2× scale)"/>
                        </TextBlock>
                    </StackPanel>
                </Expander>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="Hexprite.Views.ToolSidebarPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="100">
    <Border Background="{DynamicResource Brush.Surface.ToolSidebar}"
            Padding="8,16"
            CornerRadius="8"
            VerticalAlignment="Top">
        <Border.Effect>
            <DropShadowEffect Color="{DynamicResource Palette.Common.Shadow}"
                              BlurRadius="10"
                              Opacity="0.15"
                              Direction="270"
                              ShadowDepth="3" />
        </Border.Effect>
        <StackPanel Orientation="Vertical"
                    HorizontalAlignment="Center">
            <RadioButton x:Name="RbPencil"
                         Style="{StaticResource VerticalToolButtonStyle}"
                         GroupName="Tools"
                         IsChecked="True"
                         Tag="Pencil"
                         Checked="Tool_Checked"
                         Margin="0,0,0,4"
                         ToolTip="Pencil (P)">
                <Path Style="{StaticResource StrokedToolIconStyle}"
                      Data="M3.40979 23.0017V12.4402l5.0521 2.7261 3.53861 -2.5275 3.5386 2.5275 5.0511 -2.7261v10.5615 M3.41949 12.4388 11.1783 1.42699c0.4028 -0.571599 1.2503 -0.571599 1.6531 0l7.7588 11.01181 M8.46191 15.1663v7.8354 M15.5391 15.1663v7.8354 M7.55359 6.57275h8.89381" />
            </RadioButton>
            <RadioButton x:Name="RbLine"
                         Style="{StaticResource VerticalToolButtonStyle}"
                         GroupName="Tools"
                         Tag="Line"
                         Checked="Tool_Checked"
                         Margin="0,0,0,4"
                         ToolTip="Line (L)">
                <Path Style="{StaticResource StrokedToolIconStyle}"
                      Data="M 4,18 L 18,4" />
            </RadioButton>
            <RadioButton x:Name="RbRectangle"
                         Style="{StaticResource VerticalToolButtonStyle}"
                         GroupName="Tools"
                         Tag="Rectangle"
                         Checked="Tool_Checked"
                         Margin="0,0,0,4"
                         ToolTip="Rectangle (R)">
                <Path Style="{StaticResource StrokedToolIconStyle}"
                      Data="M 5,5 H 19 V 19 H 5 Z" />
            </RadioButton>
            <RadioButton x:Name="RbEllipse"
                         Style="{StaticResource VerticalToolButtonStyle}"
                         GroupName="Tools"
                         Tag="Ellipse"
                         Checked="Tool_Checked"
                         Margin="0,0,0,4"
                         ToolTip="Ellipse (E)">
                <Path Style="{StaticResource StrokedToolIconStyle}"
                      Data="M 12,5 C 4,5 2,12 2,12 C 2,12 4,19 12,19 C 20,19 22,12 22,12 C 22,12 20,5 12,5 Z" />
            </RadioButton>
            <RadioButton x:Name="RbFilledRectangle"
                         Style="{StaticResource VerticalToolButtonStyle}"
                         GroupName="Tools"
                         Tag="FilledRectangle"
                         Checked="Tool_Checked"
                         Margin="0,0,0,4"
                         ToolTip="Filled Rectangle (Shift+R)">
                <Path Style="{StaticResource FilledToolIconStyle}"
                      Data="M 5,5 H 19 V 19 H 5 Z" />
            </RadioButton>
            <RadioButton x:Name="RbFilledEllipse"
                         Style="{StaticResource VerticalToolButtonStyle}"
                         GroupName="Tools"
                         Tag="FilledEllipse"
                         Checked="Tool_Checked"
                         Margin="0,0,0,4"
                         ToolTip="Filled Ellipse (Shift+E)">
                <Path Style="{StaticResource FilledToolIconStyle}"
                      Data="M 12,5 C 4,5 2,12 2,12 C 2,12 4,19 12,19 C 20,19 22,12 22,12 C 22,12 20,5 12,5 Z" />
            </RadioButton>
            <RadioButton x:Name="RbFill"
                         Style="{StaticResource VerticalToolButtonStyle}"
                         GroupName="Tools"
                         Tag="Fill"
                         Checked="Tool_Checked"
                         Margin="0,0,0,4"
                         ToolTip="Fill (F)">
                <Path Style="{StaticResource StrokedToolIconStyle}"
                      Data="M 7,6 L 14,13 L 10,17 L 3,10 Z M 13.5,13.5 L 18,9 M 17,16 C 17,14.9 18.3,13.6 19.1,12.8 C 19.5,12.4 20.1,12.4 20.5,12.8 C 21.3,13.6 22.6,14.9 22.6,16 C 22.6,17.4 21.4,18.6 20,18.6 C 18.6,18.6 17,17.4 17,16 Z" />
            </RadioButton>

            <!-- Separator between draw and select tools -->
            <Rectangle Height="1"
                       Style="{StaticResource SeparatorRectangleStyle}"
                       Margin="4,6" />

            <RadioButton x:Name="RbMarquee"
                         Style="{StaticResource VerticalToolButtonStyle}"
                         GroupName="Tools"
                         Tag="Marquee"
                         Checked="Tool_Checked"
                         Margin="0,0,0,4"
                         ToolTip="Marquee Select (M)">
                <Path Style="{StaticResource StrokedToolIconStyle}"
                      StrokeDashArray="2,2"
                      Data="M 2,2 L 16,2 L 16,16 L 2,16 Z" />
            </RadioButton>
            <RadioButton x:Name="RbLasso"
                         Style="{StaticResource VerticalToolButtonStyle}"
                         GroupName="Tools"
                         Tag="Lasso"
                         Checked="Tool_Checked"
                         ToolTip="Lasso Select (S)">
                <Path Style="{StaticResource StrokedToolIconStyle}"
                      StrokeDashArray="2,2"
                      Data="M 6,8 C 8,5 14,5 17,8 C 20,11 19,16 15,18 C 12,20 8,19 6,16 C 4,13 4,10 6,8 Z M 15,18 C 16,19.5 16.5,21 15.2,22.2 C 13.9,23.3 12.4,22.9 11.5,21.8" />
            </RadioButton>
            <RadioButton x:Name="RbMagicWand"
                         Style="{StaticResource VerticalToolButtonStyle}"
                         GroupName="Tools"
                         Tag="MagicWand"
                         Checked="Tool_Checked"
                         ToolTip="Magic Wand (W)">
                <Path Style="{StaticResource StrokedToolIconStyle}"
                      Data="M 6,18 L 18,6 M 4,20 L 2,22 L 4,24 L 6,22 Z M 14,4 L 14,1 M 18,8 L 21,8 M 10,8 L 7,8 M 14,12 L 14,15 M 19,3 L 21,1 M 9,3 L 7,1" />
            </RadioButton>
        </StackPanel>
    </Border>
</UserControl>

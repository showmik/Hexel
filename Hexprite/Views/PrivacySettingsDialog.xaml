<Window x:Class="Hexprite.Views.PrivacySettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:Hexprite.Core"
        Title="Privacy Settings"
        Width="560"
        SizeToContent="Height"
        MinHeight="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Surface.Base}"
        FontFamily="{DynamicResource Font.Primary}"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="False"
        core:WindowChromeHelper.ForceRoundedCorners="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="34"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="5"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border Style="{StaticResource DialogWindowBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource Brush.Surface.MenuBar}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               IsHitTestVisible="False"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Click="CaptionClose_Click" ToolTip="Close" Width="46" Height="34"
                                Style="{StaticResource CaptionCloseButtonStyle}">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Choose what diagnostics can be collected. These settings are stored per-user on this device."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource Brush.Text.Muted}"
                           Margin="0,0,0,14" />

                <CheckBox x:Name="TelemetryEnabledCheckBox"
                          Grid.Row="1"
                          Margin="0,0,0,10"
                          Content="Enable telemetry and report submission" />

                <CheckBox x:Name="AttachLogsDefaultCheckBox"
                          Grid.Row="2"
                          Margin="0,0,0,10"
                          Content="Default to attaching recent logs in bug report/feedback dialogs" />

                <CheckBox x:Name="AllowLogAttachmentsCheckBox"
                          Grid.Row="3"
                          Margin="0,0,0,10"
                          Content="Allow log attachments to be sent at all" />

                <CheckBox x:Name="RedactPersonalDataCheckBox"
                          Grid.Row="4"
                          Margin="0,0,0,10"
                          Content="Redact common personal data (emails and local paths) before telemetry upload" />

                <CheckBox x:Name="AllowContactEmailCheckBox"
                          Grid.Row="5"
                          Margin="0,0,0,10"
                          Content="Allow contact email to be included in telemetry when user consents" />

                <CheckBox x:Name="ShareContactEmailDefaultCheckBox"
                          Grid.Row="6"
                          Margin="0,0,0,10"
                          Content="Default the 'share contact email' checkbox to checked" />

                <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Cancel"
                            Width="90"
                            MinHeight="30"
                            Margin="0,0,8,0"
                            Style="{StaticResource ModernButtonStyle}"
                            IsCancel="True"
                            Click="Cancel_Click"/>
                    <Button Content="Save"
                            Width="110"
                            MinHeight="30"
                            Style="{StaticResource AccentButtonStyle}"
                            IsDefault="True"
                            Click="Save_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>

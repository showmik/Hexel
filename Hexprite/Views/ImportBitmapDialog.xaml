<Window x:Class="Hexprite.Views.ImportBitmapDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:Hexprite.Core"
        Title="Import Bitmap"
        Width="420" Height="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Surface.Base}"
        FontFamily="{DynamicResource Font.Primary}"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="False"
        core:WindowChromeHelper.ForceRoundedCorners="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="34"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="5"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border BorderThickness="{x:Static core:WindowChromeHelper.FallbackBorderThickness}" BorderBrush="{DynamicResource Brush.Border.Base}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource Brush.Surface.MenuBar}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               IsHitTestVisible="False" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Click="CaptionClose_Click"
                                ToolTip="Close"
                                Width="46"
                                Height="34"
                                Style="{StaticResource CaptionCloseButtonStyle}">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="24,24,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="IMPORT BITMAP SETTINGS"
                           Style="{StaticResource HeaderStyle}"
                           FontSize="14"
                           Margin="0,0,0,6" />

                <TextBlock Grid.Row="1"
                           x:Name="TxtSourceFile"
                           Foreground="{DynamicResource Brush.Text.Muted}"
                           Margin="0,0,0,18" />

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Dithering"
                               Width="120"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.Text.Primary}" />
                    <ComboBox x:Name="DitherCombo"
                              Width="220"
                              Height="28"
                              Style="{StaticResource ModernComboBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Threshold"
                               Width="120"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.Text.Primary}" />
                    <TextBox x:Name="TxtThreshold"
                             Width="80"
                             Height="28"
                             Style="{StaticResource ModernTextBoxStyle}"
                             PreviewTextInput="NumberOnly"
                             TextChanged="AnyTextSettingChanged" />
                    <TextBlock Text="(0-255)"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Max size"
                               Width="120"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.Text.Primary}" />
                    <TextBox x:Name="TxtMaxDimension"
                             Width="80"
                             Height="28"
                             Style="{StaticResource ModernTextBoxStyle}"
                             PreviewTextInput="NumberOnly"
                             TextChanged="AnyTextSettingChanged" />
                    <TextBlock Text="px"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Alpha cutoff"
                               Width="120"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.Text.Primary}" />
                    <TextBox x:Name="TxtAlphaThreshold"
                             Width="80"
                             Height="28"
                             Style="{StaticResource ModernTextBoxStyle}"
                             PreviewTextInput="NumberOnly"
                             TextChanged="AnyTextSettingChanged" />
                    <TextBlock Text="(0-255)"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </StackPanel>

                <CheckBox Grid.Row="6"
                          x:Name="ChkInvert"
                          Content="Invert brightness before dithering"
                          Foreground="{DynamicResource Brush.Text.Primary}"
                          Checked="AnySettingChanged"
                          Unchecked="AnySettingChanged" />

                <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel"
                            Width="80"
                            MinHeight="30"
                            Margin="0,0,8,0"
                            Style="{StaticResource ModernButtonStyle}"
                            Click="Cancel_Click" />
                    <Button x:Name="BtnImport"
                            Content="Import"
                            Width="80"
                            MinHeight="30"
                            Style="{StaticResource ModernButtonStyle}"
                            IsDefault="True"
                            Click="Import_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>

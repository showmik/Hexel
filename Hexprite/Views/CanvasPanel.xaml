<UserControl x:Class="Hexprite.Views.CanvasPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Context toolbar -->
        <Border Grid.Row="0"
                Style="{StaticResource PanelStyle}"
                Margin="0,0,0,10"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Contextual Options (all share Column 0) -->

                <!-- 1. Brush options (Pencil only) -->
                <StackPanel Orientation="Horizontal"
                            Grid.Column="0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility"
                                    Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentTool}"
                                             Value="Pencil">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- Brush Shape label -->
                    <TextBlock Text="SHAPE"
                               Style="{StaticResource HeaderStyle}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               FontSize="11" />

                    <!-- Circle shape button -->
                    <RadioButton x:Name="RbBrushCircle" x:FieldModifier="public"
                                 GroupName="BrushShape"
                                 IsChecked="True"
                                 Checked="BrushShape_Checked"
                                 Tag="Circle"
                                 ToolTip="Circle Brush"
                                 Width="28" Height="28"
                                 Margin="0,0,2,0"
                                 Style="{StaticResource VerticalToolButtonStyle}">
                        <Ellipse Width="10" Height="10"
                                 Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
                    </RadioButton>

                    <!-- Square shape button -->
                    <RadioButton x:Name="RbBrushSquare" x:FieldModifier="public"
                                 GroupName="BrushShape"
                                 Checked="BrushShape_Checked"
                                 Tag="Square"
                                 ToolTip="Square Brush"
                                 Width="28" Height="28"
                                 Margin="0,0,2,0"
                                 Style="{StaticResource VerticalToolButtonStyle}">
                        <Rectangle Width="10" Height="10"
                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
                    </RadioButton>

                    <!-- Line shape button -->
                    <RadioButton x:Name="RbBrushLine" x:FieldModifier="public"
                                 GroupName="BrushShape"
                                 Checked="BrushShape_Checked"
                                 Tag="Line"
                                 ToolTip="Line Brush"
                                 Width="28" Height="28"
                                 Margin="0,0,8,0"
                                 Style="{StaticResource VerticalToolButtonStyle}">
                        <Rectangle Width="14" Height="2"
                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
                    </RadioButton>

                    <!-- Separator -->
                    <Rectangle Width="2"
                               Fill="{DynamicResource Brush.Border.Base}"
                               Margin="0,4,8,4"
                               RadiusX="1"
                               RadiusY="1" />

                    <!-- Brush Size label -->
                    <TextBlock Text="SIZE"
                               Style="{StaticResource HeaderStyle}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               FontSize="11" />
                    <Button Content="-"
                            Width="24"
                            Height="24"
                            Margin="0,0,4,0"
                            Style="{StaticResource ModernButtonStyle}"
                            Padding="0"
                            Click="BtnBrushDown_Click" />
                    <Slider x:Name="BrushSizeSlider" x:FieldModifier="public"
                            Width="80"
                            Minimum="1"
                            Maximum="64"
                            Value="{Binding BrushSize}"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            VerticalAlignment="Center"
                            ToolTip="Pencil brush size ([ / ] or Ctrl+Scroll)" />
                    <Button Content="+"
                            Width="24"
                            Height="24"
                            Margin="4,0,4,0"
                            Style="{StaticResource ModernButtonStyle}"
                            Padding="0"
                            Click="BtnBrushUp_Click" />
                    <TextBox x:Name="BrushSizeTextBox" x:FieldModifier="public"
                             Text="{Binding BrushSize, UpdateSourceTrigger=LostFocus}"
                             Width="36"
                             Padding="0,2"
                             VerticalAlignment="Center"
                             HorizontalContentAlignment="Center"
                             VerticalContentAlignment="Center"
                             FontSize="12"
                             FontWeight="Bold"
                             Foreground="{DynamicResource Brush.Accent.Base}"
                             Background="{DynamicResource Brush.Surface.Base}"
                             BorderBrush="{DynamicResource Brush.Border.Base}"
                             BorderThickness="1"
                             PreviewTextInput="NumericTextBox_PreviewTextInput"
                             LostFocus="BrushSizeTextBox_LostFocus"
                             ToolTip="Brush size (1-64)" />
                    <TextBlock Text="px"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               VerticalAlignment="Center"
                               Margin="3,0,0,0"
                               FontSize="11" />

                    <CheckBox Content="Pixel-Perfect"
                              IsChecked="{Binding IsPixelPerfectEnabled}"
                              Foreground="{DynamicResource Brush.Text.Muted}"
                              VerticalAlignment="Center"
                              Margin="10,0,0,0"
                              ToolTip="Remove staircase corners while freehand drawing with a 1px pencil.">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding CurrentTool}" Value="Pencil" />
                                            <Condition Binding="{Binding BrushSize}" Value="1" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>

                    <!-- Rotation controls (only for Square and Line) -->
                    <StackPanel x:Name="RotationPanel" x:FieldModifier="public"
                                Orientation="Horizontal"
                                Margin="8,0,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BrushShape}" Value="Square">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BrushShape}" Value="Line">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <Rectangle Width="2"
                                   Fill="{DynamicResource Brush.Border.Base}"
                                   Margin="0,4,8,4"
                                   RadiusX="1"
                                   RadiusY="1" />

                        <TextBlock Text="ANGLE"
                                   Style="{StaticResource HeaderStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontSize="11" />
                        <Slider x:Name="BrushAngleSlider" x:FieldModifier="public"
                                Width="80"
                                Minimum="0"
                                Maximum="359"
                                Value="{Binding BrushAngle}"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"
                                ToolTip="Brush rotation angle (0-359°)" />
                        <TextBox x:Name="BrushAngleTextBox" x:FieldModifier="public"
                                 Text="{Binding BrushAngle, UpdateSourceTrigger=LostFocus}"
                                 Width="36"
                                 Padding="0,2"
                                 VerticalAlignment="Center"
                                 Margin="4,0,0,0"
                                 HorizontalContentAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 FontSize="12"
                                 FontWeight="Bold"
                                 Foreground="{DynamicResource Brush.Accent.Base}"
                                 Background="{DynamicResource Brush.Surface.Base}"
                                 BorderBrush="{DynamicResource Brush.Border.Base}"
                                 BorderThickness="1"
                                 PreviewTextInput="NumericTextBox_PreviewTextInput"
                                 LostFocus="BrushAngleTextBox_LostFocus"
                                 ToolTip="Brush angle (0-359°)" />
                        <TextBlock Text="°"
                                   Foreground="{DynamicResource Brush.Text.Muted}"
                                   VerticalAlignment="Center"
                                   Margin="3,0,0,0"
                                   FontSize="12" />
                    </StackPanel>
                </StackPanel>

                <!-- 2. Shape hints (Line, Rectangle, Ellipse) -->
                <StackPanel Orientation="Horizontal"
                            Grid.Column="0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility"
                                    Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentTool}"
                                             Value="Line">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentTool}"
                                             Value="Rectangle">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentTool}"
                                             Value="Ellipse">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentTool}"
                                             Value="FilledRectangle">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentTool}"
                                             Value="FilledEllipse">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="&#xE9A6;"
                               FontFamily="Segoe MDL2 Assets"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBlock Text="Shift + Drag to constrain proportions or angle"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               VerticalAlignment="Center"
                               FontStyle="Italic" />
                </StackPanel>

                <!-- 3. Fill hint -->
                <StackPanel Orientation="Horizontal"
                            Grid.Column="0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility"
                                    Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentTool}"
                                             Value="Fill">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="&#xE946;"
                               FontFamily="Segoe MDL2 Assets"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBlock Text="Click to flood fill contiguous pixels"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               VerticalAlignment="Center"
                               FontStyle="Italic" />
                </StackPanel>

                <!-- 4. Selection hints (Marquee, Lasso, MagicWand) -->
                <StackPanel Orientation="Horizontal"
                            Grid.Column="0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility"
                                    Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentTool}"
                                             Value="Marquee">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentTool}"
                                             Value="Lasso">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentTool}"
                                             Value="MagicWand">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- Transform button (context-aware: enabled only when a selection exists) -->
                    <Button Command="{Binding BeginSelectionTransformCommand}"
                            Style="{StaticResource ModernButtonStyle}"
                            Height="28"
                            Padding="10,0"
                            Margin="0,0,10,0"
                            ToolTip="Transform selection (Ctrl+T) — drag handles to scale">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE740;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />
                            <TextBlock Text="Transform"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Rectangle Width="2"
                               Fill="{DynamicResource Brush.Border.Base}"
                               Margin="0,4,10,4"
                               RadiusX="1"
                               RadiusY="1" />

                    <TextBlock Text="&#xE9A6;"
                               FontFamily="Segoe MDL2 Assets"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBlock Text="Del to erase selection • Esc to clear selection • Shift/Alt/Ctrl to combine"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               VerticalAlignment="Center"
                               FontStyle="Italic" />
                </StackPanel>




                <Rectangle Grid.Column="3"
                           Width="2"
                           Fill="{DynamicResource Brush.Border.Base}"
                           Margin="12,4"
                           RadiusX="1"
                           RadiusY="1" />

                <!-- Zoom -->
                <StackPanel Orientation="Horizontal"
                            Grid.Column="4">
                    <TextBlock Text="ZOOM"
                               Style="{StaticResource HeaderStyle}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               FontSize="11" />
                    <Button Content="-"
                            Width="28"
                            Height="28"
                            Margin="0,0,8,0"
                            Style="{StaticResource ModernButtonStyle}"
                            Click="BtnZoomOut_Click"
                            Padding="0" />
                    <Slider x:Name="ZoomSlider" x:FieldModifier="public"
                            Width="100"
                            Minimum="0.1"
                            Maximum="20.0"
                            Value="{Binding ZoomLevel}"
                            TickFrequency="0.1"
                            IsSnapToTickEnabled="True"
                            VerticalAlignment="Center"
                            ToolTip="Zoom Canvas (Scroll / Ctrl+Plus/Minus)" />
                    <Button Content="+"
                            Width="28"
                            Height="28"
                            Margin="8,0,8,0"
                            Style="{StaticResource ModernButtonStyle}"
                            Click="BtnZoomIn_Click"
                            Padding="0" />
                    <Button Content="Reset"
                            Height="28"
                            Padding="12,0"
                            Margin="5,0,0,0"
                            Style="{StaticResource ModernButtonStyle}"
                            Click="BtnZoomReset_Click" />
                    <TextBlock Text="{Binding ZoomLevel, StringFormat={}{0:F1}x}"
                               Foreground="{DynamicResource Brush.Accent.Base}"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               Width="35" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Canvas -->
        <Border Grid.Row="1"
                Style="{StaticResource PanelStyle}"
                Padding="0"
                ClipToBounds="True">
            <ScrollViewer x:Name="MainScrollViewer" x:FieldModifier="public"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="{DynamicResource Brush.Surface.Base}">
                <Grid Background="Transparent">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2000" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="2000" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2000" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="2000" />
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Row="1" Grid.Column="1"
                            Background="{DynamicResource Brush.Canvas.Base}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Border.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding ZoomLevel}"
                                            ScaleY="{Binding ZoomLevel}" />
                        </Border.LayoutTransform>

                        <Grid x:Name="PixelGridContainer" x:FieldModifier="public"
                              Width="{Binding CanvasDisplayWidth}"
                              Height="{Binding CanvasDisplayHeight}">

                        <!-- Pixel bitmap -->
                        <Image x:Name="CanvasImage" x:FieldModifier="public"
                               Source="{Binding CanvasBitmap}"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                               Stretch="Fill"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch" />

                        <!-- Grid lines overlay -->
                        <Rectangle IsHitTestVisible="False">
                            <Rectangle.Style>
                                <Style TargetType="Rectangle">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowGridLines}"
                                                     Value="False">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Rectangle.Style>
                            <Rectangle.Fill>
                                <DrawingBrush Viewport="{Binding GridViewport}"
                                              ViewportUnits="Absolute"
                                              TileMode="Tile">
                                    <DrawingBrush.Drawing>
                                        <GeometryDrawing>
                                            <GeometryDrawing.Geometry>
                                                <RectangleGeometry Rect="{Binding GridViewport}" />
                                            </GeometryDrawing.Geometry>
                                            <GeometryDrawing.Pen>
                                                <Pen Brush="{DynamicResource Brush.Canvas.Grid}"
                                                     Thickness="{Binding DynamicStrokeThickness}" />
                                            </GeometryDrawing.Pen>
                                        </GeometryDrawing>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Selection overlays -->
                        <Canvas IsHitTestVisible="False"
                                ClipToBounds="False"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch">

                            <Rectangle x:Name="MarqueeOverlay" x:FieldModifier="public"
                                       Stroke="{DynamicResource Brush.Accent.PreviewBorder}"
                                       StrokeThickness="{Binding SelectionStrokeThickness}"
                                       StrokeDashArray="4,4"
                                       Visibility="Hidden"
                                       IsHitTestVisible="False" />

                            <!-- Light transparent yellow fill shows the lasso interior -->
                            <Path x:Name="LassoOverlay" x:FieldModifier="public"
                                  Stroke="{DynamicResource Brush.Accent.PreviewBorder}"
                                  StrokeThickness="{Binding SelectionStrokeThickness}"
                                  StrokeDashArray="4,4"
                                  Fill="{DynamicResource Brush.Common.LassoFill}"
                                  Visibility="Hidden"
                                  IsHitTestVisible="False" />

                            <!-- Transform handles (decorative; hit-testing is in MainWindow) -->
                            <Canvas x:Name="TransformHandlesLayer" x:FieldModifier="public"
                                    IsHitTestVisible="False"
                                    ClipToBounds="False"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch" />

                            <!-- Brush cursor overlay (pixel-accurate bitmap) -->
                            <Image x:Name="BrushCursorOverlay" x:FieldModifier="public"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Stretch="Fill"
                                   Visibility="Hidden"
                                   IsHitTestVisible="False" />

                            <!-- Crosshair lines (follow mouse smoothly) -->
                            <Line x:Name="CrosshairH" x:FieldModifier="public"
                                  StrokeThickness="0.5"
                                  Visibility="Hidden"
                                  IsHitTestVisible="False"
                                  SnapsToDevicePixels="True" />
                            <Line x:Name="CrosshairV" x:FieldModifier="public"
                                  StrokeThickness="0.5"
                                  Visibility="Hidden"
                                  IsHitTestVisible="False"
                                  SnapsToDevicePixels="True" />
                        </Canvas>
                    </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- Bottom action bar -->
        <Border Grid.Row="2"
                Style="{StaticResource PanelStyle}"
                Margin="0,15,0,0"
                Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- History & Actions -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal">
                    
                    <!-- Undo / Redo -->
                    <Button Command="{Binding UndoCommand}"
                            ToolTip="Undo (Ctrl+Z)"
                            Style="{StaticResource CompactIconButtonStyle}"
                            Margin="0,0,4,0">
                        <TextBlock Text="&#xE10E;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" />
                    </Button>
                    <Button Command="{Binding RedoCommand}"
                            ToolTip="Redo (Ctrl+Y)"
                            Style="{StaticResource CompactIconButtonStyle}">
                        <TextBlock Text="&#xE10D;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" />
                    </Button>

                    <Rectangle Width="2"
                               Fill="{DynamicResource Brush.Border.Base}"
                               Margin="12,4"
                               RadiusX="1"
                               RadiusY="1" />

                    <!-- Canvas Actions -->
                    <Button Command="{Binding InvertCommand}"
                            ToolTip="Invert Canvas"
                            Style="{StaticResource CompactIconButtonStyle}"
                            Margin="0,0,4,0">
                        <TextBlock Text="&#xE8D5;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" />
                    </Button>
                    <Button Command="{Binding ClearCommand}"
                            ToolTip="Clear Canvas"
                            Style="{StaticResource CompactIconButtonStyle}">
                        <TextBlock Text="&#xE74D;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" />
                    </Button>
                </StackPanel>

                <!-- View Options -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0">
                    <CheckBox Content="Show Grid"
                              IsChecked="{Binding ShowGridLines}"
                              Foreground="{DynamicResource Brush.Text.Muted}"
                              ToolTip="Toggle Grid Preview"
                              VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

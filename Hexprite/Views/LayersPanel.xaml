<UserControl x:Class="Hexprite.Views.LayersPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="360">
    <Border Background="Transparent"
            Padding="10,8,4,10">
        <Border Background="{DynamicResource Brush.Surface.Overlay}"
                BorderBrush="{DynamicResource Brush.Border.Base}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10,8,10,10">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource Palette.Common.Shadow}"
                                  Opacity="0.15"
                                  BlurRadius="10"
                                  ShadowDepth="2"
                                  Direction="270" />
            </Border.Effect>
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top"
                           Text="LAYERS"
                           Style="{StaticResource HeaderStyle}"
                           Margin="0,0,0,8" />

                <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="+ Add"
                            Style="{StaticResource ModernButtonStyle}"
                            Margin="0,0,6,0"
                            Command="{Binding AddLayerCommand}" />
                    <Button Grid.Column="1"
                            Content="- Delete"
                            Style="{StaticResource ModernButtonStyle}"
                            Margin="6,0,0,0"
                            Command="{Binding DeleteLayerCommand}" />
                </Grid>
                <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="Duplicate"
                            Style="{StaticResource ModernButtonStyle}"
                            Margin="0,0,4,0"
                            Command="{Binding DuplicateLayerCommand}" />
                    <Button Grid.Column="1"
                            Content="Move Up"
                            Style="{StaticResource ModernButtonStyle}"
                            Margin="4,0,4,0"
                            Command="{Binding MoveLayerUpCommand}" />
                    <Button Grid.Column="2"
                            Content="Move Down"
                            Style="{StaticResource ModernButtonStyle}"
                            Margin="4,0,0,0"
                            Command="{Binding MoveLayerDownCommand}" />
                </Grid>

                <ListBox x:Name="LayerList"
                         ItemsSource="{Binding Layers}"
                         SelectedIndex="{Binding SelectedLayerIndex, Mode=TwoWay}"
                         Background="{DynamicResource Brush.Surface.Panel}"
                         BorderBrush="{DynamicResource Brush.Border.Base}"
                         BorderThickness="1"
                         AllowDrop="True"
                         PreviewMouseLeftButtonDown="LayerList_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="LayerList_PreviewMouseMove"
                         Drop="LayerList_Drop"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,2" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="RowBg"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="RowBg" Property="Background" Value="{DynamicResource Brush.Surface.Hover}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="RowBg" Property="Background" Value="{DynamicResource Brush.Surface.Active}" />
                                                <Setter TargetName="RowBg" Property="BorderBrush" Value="{DynamicResource Brush.Border.Separator}" />
                                                <Setter TargetName="RowBg" Property="BorderThickness" Value="1" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,3,4,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="≡"
                                           Margin="2,0,6,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.Text.Muted}" />
                                <CheckBox Grid.Column="1"
                                          Margin="0,0,6,0"
                                          IsChecked="{Binding IsVisible}"
                                          Checked="LayerVisible_CheckedChanged"
                                          Unchecked="LayerVisible_CheckedChanged"
                                          ToolTip="Toggle visibility" />
                                <TextBox Grid.Column="2"
                                         Text="{Binding Name}"
                                         Style="{StaticResource ModernTextBoxStyle}"
                                         Height="24"
                                         Margin="0,0,6,0"
                                         KeyDown="LayerName_KeyDown"
                                         LostFocus="LayerName_LostFocus" />
                                <CheckBox Grid.Column="3"
                                          Margin="0,0,2,0"
                                          IsChecked="{Binding IsLocked}"
                                          Checked="LayerLocked_CheckedChanged"
                                          Unchecked="LayerLocked_CheckedChanged"
                                          ToolTip="Toggle lock" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Border>
</UserControl>

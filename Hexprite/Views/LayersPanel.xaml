<UserControl x:Class="Hexprite.Views.LayersPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="360">
    <Border Background="Transparent"
            Padding="10,8,4,10">
        <Border Background="{DynamicResource Brush.Surface.Overlay}"
                BorderBrush="{DynamicResource Brush.Border.Base}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10,8,10,10">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource Palette.Common.Shadow}"
                                  Opacity="0.15"
                                  BlurRadius="10"
                                  ShadowDepth="2"
                                  Direction="270" />
            </Border.Effect>
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top"
                           Text="LAYERS"
                           Style="{StaticResource HeaderStyle}"
                           Margin="0,0,0,8" />

                <StackPanel DockPanel.Dock="Bottom"
                            Orientation="Horizontal"
                            Margin="0,10,0,0">
                    <Button Command="{Binding AddLayerCommand}"
                            ToolTip="Add layer"
                            AutomationProperties.Name="Add layer"
                            Style="{StaticResource CompactIconButtonStyle}"
                            Margin="0,0,4,0">
                        <TextBlock Text="&#xE710;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Foreground="{DynamicResource Brush.Accent.Base}" />
                    </Button>
                    <Button Command="{Binding DeleteLayerCommand}"
                            ToolTip="Delete layer"
                            AutomationProperties.Name="Delete layer"
                            Style="{StaticResource CompactIconButtonStyle}"
                            Margin="0,0,4,0">
                        <TextBlock Text="&#xE74D;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" />
                    </Button>

                    <Rectangle Width="2"
                               Fill="{DynamicResource Brush.Border.Base}"
                               Margin="8,4"
                               RadiusX="1"
                               RadiusY="1" />

                    <Button Command="{Binding DuplicateLayerCommand}"
                            ToolTip="Duplicate layer"
                            AutomationProperties.Name="Duplicate layer"
                            Style="{StaticResource CompactIconButtonStyle}"
                            Margin="0,0,4,0">
                        <TextBlock Text="&#xE8C8;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" />
                    </Button>
                    <Button Command="{Binding MoveLayerUpCommand}"
                            ToolTip="Move layer up"
                            AutomationProperties.Name="Move layer up"
                            Style="{StaticResource CompactIconButtonStyle}"
                            Margin="0,0,4,0">
                        <TextBlock Text="&#xE74A;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" />
                    </Button>
                    <Button Command="{Binding MoveLayerDownCommand}"
                            ToolTip="Move layer down"
                            AutomationProperties.Name="Move layer down"
                            Style="{StaticResource CompactIconButtonStyle}">
                        <TextBlock Text="&#xE74B;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" />
                    </Button>
                </StackPanel>

                <Grid x:Name="LayerListClipHost"
                      ClipToBounds="True">
                    <ListBox x:Name="LayerList"
                             ItemsSource="{Binding Layers}"
                             SelectedIndex="{Binding SelectedLayerIndex, Mode=TwoWay}"
                             Background="{DynamicResource Brush.Surface.Panel}"
                             BorderBrush="{DynamicResource Brush.Border.Base}"
                             BorderThickness="1"
                             AllowDrop="True"
                             PreviewMouseMove="LayerList_PreviewMouseMove_ArmDrag"
                             PreviewMouseLeftButtonUp="LayerList_PreviewMouseLeftButtonUp_ArmDrag"
                             PreviewDragOver="LayerList_PreviewDragOver"
                             DragLeave="LayerList_DragLeave"
                             PreviewKeyDown="LayerList_PreviewKeyDown"
                             Drop="LayerList_Drop"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,2" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="RowBg"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="RowBg" Property="Background" Value="{DynamicResource Brush.Surface.Hover}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="RowBg" Property="Background" Value="{DynamicResource Brush.Surface.Active}" />
                                                <Setter TargetName="RowBg" Property="BorderBrush" Value="{DynamicResource Brush.Border.Separator}" />
                                                <Setter TargetName="RowBg" Property="BorderThickness" Value="1" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,3,4,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Margin="0,0,4,0"
                                        Padding="2,6,6,6"
                                        Background="Transparent"
                                        Cursor="SizeAll"
                                        ToolTip="Drag to reorder layers"
                                        PreviewMouseLeftButtonDown="LayerGrip_PreviewMouseLeftButtonDown">
                                    <TextBlock Text="≡"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Brush.Text.Muted}" />
                                </Border>
                                <CheckBox Grid.Column="1"
                                          Margin="0,0,6,0"
                                          IsChecked="{Binding IsVisible}"
                                          Checked="LayerVisible_CheckedChanged"
                                          Unchecked="LayerVisible_CheckedChanged"
                                          ToolTip="Toggle visibility" />
                                <Grid Grid.Column="2"
                                      Margin="0,0,6,0"
                                      Background="Transparent"
                                      PreviewMouseDown="LayerDisplayName_PreviewMouseDown"
                                      ToolTip="Double-click to rename">
                                    <TextBlock Text="{Binding Name}"
                                               Padding="8,5,8,5"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Brush.Text.Primary}" />
                                    <TextBox Text="{Binding Name}"
                                             Height="24"
                                             VerticalAlignment="Center"
                                             KeyDown="LayerName_KeyDown"
                                             LostFocus="LayerName_LostFocus"
                                             IsVisibleChanged="LayerName_TextBox_IsVisibleChanged">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource ModernTextBoxStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                                <CheckBox Grid.Column="3"
                                          Margin="0,0,2,0"
                                          IsChecked="{Binding IsLocked}"
                                          Checked="LayerLocked_CheckedChanged"
                                          Unchecked="LayerLocked_CheckedChanged"
                                          ToolTip="Toggle lock" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    </ListBox>
                    <Border x:Name="LayerInsertionGuide"
                            Height="3"
                            Margin="6,0"
                            CornerRadius="1"
                            Opacity="0.92"
                            Background="{DynamicResource Brush.Canvas.Drawing}"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Stretch"
                            Visibility="Collapsed"
                            IsHitTestVisible="False"
                            Panel.ZIndex="1" />
                </Grid>
            </DockPanel>
        </Border>
    </Border>
</UserControl>

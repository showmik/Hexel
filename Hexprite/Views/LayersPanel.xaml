<UserControl x:Class="Hexprite.Views.LayersPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="360">
    <Border Background="Transparent"
            Padding="10,8,10,10">
        <Border Background="{DynamicResource Brush.Surface.Overlay}"
                BorderBrush="{DynamicResource Brush.Border.Base}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10,8,10,10">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource Palette.Common.Shadow}"
                                  Opacity="0.15"
                                  BlurRadius="10"
                                  ShadowDepth="2"
                                  Direction="270" />
            </Border.Effect>
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top"
                           Text="LAYERS"
                           Style="{StaticResource HeaderStyle}"
                           Margin="0,0,0,8" />

                <StackPanel DockPanel.Dock="Bottom"
                            Orientation="Horizontal"
                            Margin="0,10,0,0">
                    <Button Command="{Binding AddLayerCommand}"
                            ToolTip="Add layer"
                            AutomationProperties.Name="Add layer"
                            Style="{StaticResource CompactIconButtonStyle}"
                            Margin="0,0,4,0">
                        <TextBlock Text="&#xE710;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Foreground="{DynamicResource Brush.Accent.Base}" />
                    </Button>
                    <Button Command="{Binding DeleteLayerCommand}"
                            ToolTip="Delete layer"
                            AutomationProperties.Name="Delete layer"
                            Style="{StaticResource CompactIconButtonStyle}"
                            Margin="0,0,4,0">
                        <TextBlock Text="&#xE74D;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" />
                    </Button>

                    <Rectangle Width="2"
                               Fill="{DynamicResource Brush.Border.Base}"
                               Margin="8,4"
                               RadiusX="1"
                               RadiusY="1" />

                    <Button Command="{Binding DuplicateLayerCommand}"
                            ToolTip="Duplicate layer"
                            AutomationProperties.Name="Duplicate layer"
                            Style="{StaticResource CompactIconButtonStyle}"
                            Margin="0,0,4,0">
                        <TextBlock Text="&#xE8C8;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" />
                    </Button>
                    <Button Command="{Binding MoveLayerUpCommand}"
                            ToolTip="Move layer up"
                            AutomationProperties.Name="Move layer up"
                            Style="{StaticResource CompactIconButtonStyle}"
                            Margin="0,0,4,0">
                        <TextBlock Text="&#xE74A;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" />
                    </Button>
                    <Button Command="{Binding MoveLayerDownCommand}"
                            ToolTip="Move layer down"
                            AutomationProperties.Name="Move layer down"
                            Style="{StaticResource CompactIconButtonStyle}">
                        <TextBlock Text="&#xE74B;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" />
                    </Button>
                </StackPanel>

                <Grid x:Name="LayerListClipHost"
                      ClipToBounds="True">
                    <ListBox x:Name="LayerList"
                             ItemsSource="{Binding Layers}"
                             SelectedIndex="{Binding SelectedLayerIndex, Mode=TwoWay}"
                             Background="{DynamicResource Brush.Surface.Panel}"
                             BorderBrush="{DynamicResource Brush.Border.Base}"
                             BorderThickness="1"
                             AllowDrop="True"
                             PreviewMouseMove="LayerList_PreviewMouseMove_ArmDrag"
                             PreviewMouseLeftButtonUp="LayerList_PreviewMouseLeftButtonUp_ArmDrag"
                             PreviewDragOver="LayerList_PreviewDragOver"
                             DragLeave="LayerList_DragLeave"
                             PreviewKeyDown="LayerList_PreviewKeyDown"
                             Drop="LayerList_Drop"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource LayerListItemStyle}" />
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,3,4,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Margin="0,0,4,0"
                                        Padding="2,6,6,6"
                                        Background="Transparent"
                                        Cursor="SizeAll"
                                        ToolTip="Drag to reorder layers"
                                        PreviewMouseLeftButtonDown="LayerGrip_PreviewMouseLeftButtonDown">
                                    <TextBlock Text="≡"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Brush.Text.Muted}" />
                                </Border>
                                <ToggleButton Grid.Column="1"
                                              Margin="0,0,6,0"
                                              Style="{StaticResource LayerToggleIconButtonStyle}"
                                              IsChecked="{Binding IsVisible}"
                                              Checked="LayerVisible_CheckedChanged"
                                              Unchecked="LayerVisible_CheckedChanged"
                                              AutomationProperties.Name="Layer visibility">
                                    <ToggleButton.ToolTip>
                                        <ToolTip DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"
                                                                Value="Show layer" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsVisible}"
                                                                         Value="True">
                                                                <Setter Property="Text"
                                                                        Value="Hide layer" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </ToolTip>
                                    </ToggleButton.ToolTip>
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"
                                                        Value="&#xED1A;" />
                                                <Setter Property="Foreground"
                                                        Value="{DynamicResource Brush.Text.Muted}" />
                                                <Setter Property="Opacity"
                                                        Value="0.4" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsVisible}"
                                                                 Value="True">
                                                        <Setter Property="Text"
                                                                Value="&#xE7B3;" />
                                                        <Setter Property="Foreground"
                                                                Value="{DynamicResource Brush.Text.Primary}" />
                                                        <Setter Property="Opacity"
                                                                Value="1" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </ToggleButton>
                                <Grid Grid.Column="2"
                                      Margin="0,0,6,0"
                                      Background="Transparent"
                                      PreviewMouseDown="LayerDisplayName_PreviewMouseDown"
                                      ToolTip="Double-click to rename">
                                    <TextBlock Text="{Binding Name}"
                                               Padding="8,5,8,5"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Brush.Text.Primary}" />
                                    <TextBox Text="{Binding Name}"
                                             Height="24"
                                             VerticalAlignment="Center"
                                             KeyDown="LayerName_KeyDown"
                                             LostFocus="LayerName_LostFocus"
                                             IsVisibleChanged="LayerName_TextBox_IsVisibleChanged">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource ModernTextBoxStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                                <ToggleButton Grid.Column="3"
                                              Margin="0,0,2,0"
                                              Style="{StaticResource LayerToggleIconButtonStyle}"
                                              IsChecked="{Binding IsLocked}"
                                              Checked="LayerLocked_CheckedChanged"
                                              Unchecked="LayerLocked_CheckedChanged"
                                              AutomationProperties.Name="Layer lock">
                                    <ToggleButton.ToolTip>
                                        <ToolTip DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"
                                                                Value="Lock layer" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLocked}"
                                                                         Value="True">
                                                                <Setter Property="Text"
                                                                        Value="Unlock layer" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </ToolTip>
                                    </ToggleButton.ToolTip>
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"
                                                        Value="&#xE785;" />
                                                <Setter Property="Foreground"
                                                        Value="{DynamicResource Brush.Text.Muted}" />
                                                <Setter Property="FontWeight"
                                                        Value="Normal" />
                                                <Setter Property="FontSize"
                                                        Value="14" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLocked}"
                                                                 Value="True">
                                                        <Setter Property="Text"
                                                                Value="&#xE72E;" />
                                                        <Setter Property="Foreground"
                                                                Value="{DynamicResource Brush.Text.Primary}" />
                                                        <Setter Property="FontWeight"
                                                                Value="SemiBold" />
                                                        <Setter Property="FontSize"
                                                                Value="15.5" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </ToggleButton>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    </ListBox>
                    <Border x:Name="LayerInsertionGuide"
                            Height="3"
                            Margin="6,0"
                            CornerRadius="1"
                            Opacity="0.92"
                            Background="{DynamicResource Brush.Canvas.Drawing}"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Stretch"
                            Visibility="Collapsed"
                            IsHitTestVisible="False"
                            Panel.ZIndex="1" />
                </Grid>
            </DockPanel>
        </Border>
    </Border>
</UserControl>

<Window x:Class="Hexprite.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:Hexprite.Core"
        Title="About Hexprite"
        Width="420" SizeToContent="Height" MinHeight="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Theme.BackgroundBrush}"
        FontFamily="{DynamicResource Theme.MainFont}"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="False"
        core:WindowChromeHelper.ForceRoundedCorners="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="34"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="5"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderThickness="{x:Static core:WindowChromeHelper.FallbackBorderThickness}" BorderBrush="{DynamicResource Theme.PanelBorderBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Border Grid.Row="0" Background="{DynamicResource Theme.MenuBarBackgroundBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                               Foreground="{DynamicResource Theme.TextMutedBrush}"
                               FontSize="12" VerticalAlignment="Center"
                               Margin="12,0,0,0" IsHitTestVisible="False"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Click="CaptionClose_Click" ToolTip="Close" Width="46" Height="34"
                                Style="{StaticResource CaptionCloseButtonStyle}">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- App icon + name -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Border Width="48" Height="48"
                    CornerRadius="10"
                    Margin="0,0,14,0">
                <Border.Background>
                    <ImageBrush ImageSource="pack://application:,,,/Assets/AppIcon.png" Stretch="UniformToFill" />
                </Border.Background>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Hexprite"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{DynamicResource Theme.TextMainBrush}" />
                <TextBlock x:Name="TxtVersion"
                           Text="Version 1.0.0"
                           FontSize="12"
                           Foreground="{DynamicResource Theme.TextMutedBrush}"
                           Margin="0,2,0,0" />
            </StackPanel>
        </StackPanel>

        <!-- Separator -->
        <Border Grid.Row="1"
                Height="1"
                Background="{DynamicResource Theme.SeparatorBrush}"
                Margin="0,4,0,14" />

        <!-- Description -->
        <TextBlock Grid.Row="2"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource Theme.TextMainBrush}"
                   FontSize="13"
                   LineHeight="20"
                   Margin="0,0,0,14">
            Hexprite is a monochrome pixel art editor designed for embedded displays 
            and OLED screens. Create sprites, icons, and graphics with instant 
            binary and hex code export for microcontroller projects.
        </TextBlock>

        <!-- Details -->
        <StackPanel Grid.Row="3" Margin="0,0,0,8">
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Framework"
                           Foreground="{DynamicResource Theme.TextMutedBrush}"
                           FontSize="12" />
                <TextBlock Grid.Column="1"
                           Text="WPF (.NET)"
                           Foreground="{DynamicResource Theme.TextMainBrush}"
                           FontSize="12" />
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="License"
                           Foreground="{DynamicResource Theme.TextMutedBrush}"
                           FontSize="12" />
                <TextBlock Grid.Column="1"
                           Text="MIT License"
                           Foreground="{DynamicResource Theme.TextMainBrush}"
                           FontSize="12" />
            </Grid>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Website"
                           Foreground="{DynamicResource Theme.TextMutedBrush}"
                           FontSize="12" />
                <TextBlock Grid.Column="1"
                           FontSize="12">
                    <Hyperlink x:Name="WebsiteLink"
                               NavigateUri="https://hexprite.com"
                               RequestNavigate="Hyperlink_RequestNavigate">
                        <Hyperlink.Style>
                            <Style TargetType="Hyperlink">
                                <Setter Property="Foreground" Value="{DynamicResource Theme.PrimaryAccentBrush}" />
                            </Style>
                        </Hyperlink.Style>
                        https://hexprite.com
                    </Hyperlink>
                </TextBlock>
            </Grid>
        </StackPanel>

        <!-- Copyright -->
        <TextBlock Grid.Row="4"
                           Text="© 2026 Intisar Bin Naim — All rights reserved."
                   Foreground="{DynamicResource Theme.TextMutedBrush}"
                   FontSize="11"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,8" />

        <!-- Close button -->
        <StackPanel Grid.Row="5"
                    HorizontalAlignment="Right">
            <Button Content="Close"
                    Width="80" Height="30"
                    Style="{StaticResource ModernButtonStyle}"
                    Click="Close_Click"
                    IsDefault="True"
                    IsCancel="True" />
        </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>

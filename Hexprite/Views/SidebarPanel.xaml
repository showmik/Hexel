<UserControl x:Class="Hexprite.Views.SidebarPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:core="clr-namespace:Hexprite.Core"
             xmlns:rendering="clr-namespace:Hexprite.Rendering"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="320">

    <Border Background="{DynamicResource Brush.Surface.RightSidebar}"
            BorderBrush="{DynamicResource Brush.Border.Base}"
            BorderThickness="1,0,0,0">
        <DockPanel LastChildFill="True">

            <ScrollViewer x:Name="MainScroll"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Style="{StaticResource {x:Type ScrollViewer}}">
                <StackPanel>

                <Border Background="{DynamicResource Brush.Surface.Overlay}"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource Brush.Border.Base}"
                        BorderThickness="1"
                        Margin="10,10,10,0"
                        Padding="12,10,12,12">
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource Palette.Common.Shadow}" Opacity="0.15" BlurRadius="8" ShadowDepth="2" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="LAYERS"
                               Style="{StaticResource HeaderStyle}"
                               Margin="0,0,0,8"/>
                    <ListBox x:Name="LayerList"
                             ItemsSource="{Binding Layers}"
                             SelectedIndex="{Binding SelectedLayerIndex, Mode=TwoWay}"
                             Background="{DynamicResource Brush.Surface.Base}"
                             BorderBrush="{DynamicResource Brush.Border.Base}"
                             BorderThickness="1"
                             AllowDrop="True"
                             PreviewMouseLeftButtonDown="LayerList_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="LayerList_PreviewMouseMove"
                             Drop="LayerList_Drop"
                             MinHeight="120"
                             MaxHeight="220">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              Margin="4,0,6,0"
                                              IsChecked="{Binding IsVisible}"
                                              Checked="LayerVisible_CheckedChanged"
                                              Unchecked="LayerVisible_CheckedChanged"
                                              ToolTip="Toggle visibility"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Name}"
                                             Margin="0,2,6,2"
                                             LostFocus="LayerName_LostFocus"/>
                                    <CheckBox Grid.Column="2"
                                              Margin="0,0,4,0"
                                              IsChecked="{Binding IsLocked}"
                                              Checked="LayerLocked_CheckedChanged"
                                              Unchecked="LayerLocked_CheckedChanged"
                                              ToolTip="Toggle lock"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="+ Add Layer"
                                Style="{StaticResource ModernButtonStyle}"
                                Margin="0,0,4,0"
                                Command="{Binding AddLayerCommand}"/>
                        <Button Grid.Column="1"
                                Content="- Delete Layer"
                                Style="{StaticResource ModernButtonStyle}"
                                Margin="4,0,0,0"
                                Command="{Binding DeleteLayerCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

                <!-- ═══════════════════════════════════════════════════════
                     OLED PREVIEW (collapsible, dynamic size)
                     ═══════════════════════════════════════════════════════ -->
                <Border Background="{DynamicResource Brush.Surface.Overlay}"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource Brush.Border.Base}"
                        BorderThickness="1"
                        Margin="10,10,10,0"
                        Padding="12,10,12,12">
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource Palette.Common.Shadow}" Opacity="0.15" BlurRadius="8" ShadowDepth="2" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <Expander Style="{StaticResource ModernExpanderStyle}"
                              IsExpanded="True">
                        <Expander.Header>
                            <TextBlock Text="DISPLAY PREVIEW"
                                       Style="{StaticResource HeaderStyle}"
                                       Margin="0"
                                       VerticalAlignment="Center"/>
                        </Expander.Header>
                        <StackPanel Margin="0,12,0,0">

                            <!-- Display options -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0"
                                          Height="26"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectedIndex="{Binding PreviewDisplayTypeIndex}">
                                    <ComboBoxItem Content="Generic (White)"/>
                                    <ComboBoxItem Content="SSD1306 (Blue)"/>
                                    <ComboBoxItem Content="SSD1306 (Green)"/>
                                    <ComboBoxItem Content="e-Paper"/>
                                </ComboBox>

                                <Border Grid.Column="1"
                                        Background="{DynamicResource Brush.Surface.Base}"
                                        BorderBrush="{DynamicResource Brush.Border.Base}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="8,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="-" Width="24" Height="24" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource Brush.Text.Primary}" Command="{Binding DecreasePreviewScaleCommand}"/>
                                        <TextBlock Text="{Binding PreviewScale}" VerticalAlignment="Center" Width="24" TextAlignment="Center" Foreground="{DynamicResource Brush.Text.Primary}"/>
                                        <Button Content="+" Width="24" Height="24" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource Brush.Text.Primary}" Command="{Binding IncreasePreviewScaleCommand}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Dynamic canvas preview -->
                            <Grid MinHeight="140">
                                <Border BorderBrush="{DynamicResource Brush.Surface.Base}"
                                        BorderThickness="3"
                                        CornerRadius="5"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource Brush.Canvas.Base}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDisplayInverted}"
                                                             Value="True">
                                                    <Setter Property="Background"
                                                            Value="{DynamicResource Brush.Accent.Base}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource Brush.Preview.Base}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDisplayInverted}"
                                                                 Value="True">
                                                        <Setter Property="Background"
                                                                Value="{DynamicResource Brush.Preview.Drawing}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Image Source="{Binding PreviewBitmap}"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                                               Stretch="Fill"
                                               Width="{Binding PreviewWidth}"
                                               Height="{Binding PreviewHeight}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </Grid>
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="10"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource Brush.Text.Muted}">
                                <Run Text="Preview: "/>
                                <Run Text="{Binding SpriteState.Width, Mode=OneWay}"/>
                                <Run Text="×"/>
                                <Run Text="{Binding SpriteState.Height, Mode=OneWay}"/>
                                <Run Text=" px "/>
                                <Run Text="{Binding PreviewScaleText, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Border>

                <!-- ═══════════════════════════════════════════════════════
                     EXPORT PANEL
                     ═══════════════════════════════════════════════════════ -->
                <Border Background="{DynamicResource Brush.Surface.Overlay}"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource Brush.Border.Base}"
                        BorderThickness="1"
                        Margin="10,10,10,0"
                        Padding="12,14,12,14">
                    <Border.Effect>
                        <DropShadowEffect Color="{DynamicResource Palette.Common.Shadow}" Opacity="0.15" BlurRadius="8" ShadowDepth="2" Direction="270" />
                    </Border.Effect>
                <StackPanel>
                    <TextBlock Text="EXPORT"
                               Style="{StaticResource HeaderStyle}"
                               Margin="0,0,0,16"/>

                    <!-- Format selector -->
                    <TextBlock Text="Format"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               FontSize="11"
                               Margin="0,0,0,4"/>
                    <ComboBox x:Name="CboFormat"
                              Style="{StaticResource ModernComboBoxStyle}"
                              Height="30"
                              Margin="0,0,0,16"
                              SelectedIndex="0"
                              SelectionChanged="CboFormat_SelectionChanged">
                        <ComboBoxItem Content="Adafruit GFX  (PROGMEM, MSB first)"    Tag="AdafruitGfx"/>
                        <ComboBoxItem Content="u8g2 drawBitmap  (U8X8_PROGMEM, MSB)"  Tag="U8g2DrawBitmap"/>
                        <ComboBoxItem Content="u8g2 drawXBM  (PROGMEM, LSB first)"    Tag="U8g2DrawXBM"/>
                        <ComboBoxItem Content="Plain C array  (no PROGMEM)"            Tag="PlainCArray"/>
                        <ComboBoxItem Content="MicroPython bytearray  (MONO_HLSB)"     Tag="MicroPython"/>
                        <ComboBoxItem Content="Raw hex  (no wrapper)"                  Tag="RawHex"/>
                        <ComboBoxItem Content="Raw binary  (no wrapper)"               Tag="RawBinary"/>
                    </ComboBox>

                    <!-- Sprite name -->
                    <TextBlock Text="Variable / sprite name"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               FontSize="11"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtSpriteName"
                             Style="{StaticResource ModernTextBoxStyle}"
                             Height="30"
                             FontFamily="{DynamicResource Font.Code}"
                             Text="{Binding SpriteName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"
                             ToolTip="Will be sanitised to a valid C/Python identifier"/>

                    <!-- ─── Code structure options (expander) ──────── -->
                    <Border BorderBrush="{DynamicResource Brush.Border.Base}"
                            BorderThickness="0,1,0,0"
                            Margin="0,0,0,16">
                        <Expander Style="{StaticResource ModernExpanderStyle}"
                                  IsExpanded="False"
                                  Margin="0,8,0,0">
                            <Expander.Header>
                                <TextBlock Text="CODE STRUCTURE OPTIONS"
                                           Style="{StaticResource HeaderStyle}"
                                           Margin="0"
                                           VerticalAlignment="Center"/>
                            </Expander.Header>
                            <StackPanel Margin="0,16,0,0">

                                <!-- Checkbox Grid for perfect alignment -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="145"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <CheckBox Grid.Row="0" Grid.Column="0" Content="Usage comment"
                                              IsChecked="{Binding IncludeUsageComment}"
                                              Foreground="{DynamicResource Brush.Text.Muted}"
                                              FontSize="12"
                                              Margin="0,0,0,8"/>
                                    <CheckBox Grid.Row="0" Grid.Column="1" Content="Width/height constants"
                                              IsChecked="{Binding IncludeDimensionConstants}"
                                              Foreground="{DynamicResource Brush.Text.Muted}"
                                              FontSize="12"
                                              Margin="0,0,0,8"/>

                                    <CheckBox Grid.Row="1" Grid.Column="0" Content="Row comments"
                                              IsChecked="{Binding IncludeRowComments}"
                                              Foreground="{DynamicResource Brush.Text.Muted}"
                                              FontSize="12"
                                              Margin="0,0,0,8"/>
                                    <CheckBox Grid.Row="1" Grid.Column="1" Content="Comma separator"
                                              IsChecked="{Binding UseCommaSeparator}"
                                              IsEnabled="{Binding IsCommaSeparatorEnabled}"
                                              Foreground="{DynamicResource Brush.Text.Muted}"
                                              FontSize="12"
                                              Margin="0,0,0,8"/>

                                    <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Content="Array size"
                                              IsChecked="{Binding IncludeArraySize}"
                                              Foreground="{DynamicResource Brush.Text.Muted}"
                                              FontSize="12"/>
                                </Grid>

                                <!-- Bytes per line -->
                                <TextBlock Text="Bytes per line"
                                           Foreground="{DynamicResource Brush.Text.Muted}"
                                           FontSize="11"
                                           Margin="0,0,0,4"/>
                                <WrapPanel Margin="0,0,0,12">
                                    <RadioButton x:Name="RbBpl0"
                                                 Content="canvas width"
                                                 GroupName="BytesPerLine"
                                                 Style="{StaticResource ChipButtonStyle}"
                                                 IsChecked="True"
                                                 Checked="BplChip_Checked"
                                                 Tag="0"
                                                 Margin="0,0,8,0"/>
                                    <RadioButton x:Name="RbBpl4"
                                                 Content="4"
                                                 GroupName="BytesPerLine"
                                                 Style="{StaticResource ChipButtonStyle}"
                                                 Checked="BplChip_Checked"
                                                 Tag="4"
                                                 Margin="0,0,8,0"/>
                                    <RadioButton x:Name="RbBpl8"
                                                 Content="8"
                                                 GroupName="BytesPerLine"
                                                 Style="{StaticResource ChipButtonStyle}"
                                                 Checked="BplChip_Checked"
                                                 Tag="8"
                                                 Margin="0,0,8,0"/>
                                    <RadioButton x:Name="RbBpl16"
                                                 Content="16"
                                                 GroupName="BytesPerLine"
                                                 Style="{StaticResource ChipButtonStyle}"
                                                 Checked="BplChip_Checked"
                                                 Tag="16"/>
                                </WrapPanel>

                                <!-- Hex case -->
                                <TextBlock Text="Hex digits"
                                           Foreground="{DynamicResource Brush.Text.Muted}"
                                           FontSize="11"
                                           Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="RbHexUpper"
                                                 Content="0xFF"
                                                 GroupName="HexCase"
                                                 Style="{StaticResource ChipButtonStyle}"
                                                 IsChecked="True"
                                                 Checked="HexCase_Checked"
                                                 Tag="upper"
                                                 Margin="0,0,8,0"/>
                                    <RadioButton x:Name="RbHexLower"
                                                 Content="0xff"
                                                 GroupName="HexCase"
                                                 Style="{StaticResource ChipButtonStyle}"
                                                 Checked="HexCase_Checked"
                                                 Tag="lower"/>
                                </StackPanel>

                            </StackPanel>
                        </Expander>
                    </Border>

                    <!-- ─── Code output box with header bar ──────── -->
                    <Border Background="{DynamicResource Brush.Surface.Base}"
                            CornerRadius="6"
                            BorderBrush="{DynamicResource Brush.Border.Base}"
                            BorderThickness="1"
                            ClipToBounds="True"
                            Height="240">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Output header bar -->
                            <Border Grid.Row="0" Padding="10,6"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource Brush.Border.Base}"
                                    Background="{DynamicResource Brush.Surface.Overlay}">
                                <Grid>
                                    <TextBlock Text="OUTPUT"
                                               Foreground="{DynamicResource Brush.Text.Muted}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Opacity="0.8"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Code content -->
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto"
                                          Background="Transparent">
                                <rendering:SyntaxHighlightBox x:Name="CodeOutputBox"
                                                              FontFamily="{DynamicResource Font.Code}"
                                                              FontSize="12"
                                                              Margin="8"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Generate Code + Copy buttons -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="⟳  Generate Code"
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Padding="8,8"
                                FontSize="11.5"
                                Margin="0,0,8,0"
                                Command="{Binding GenerateCodeCommand}"
                                ToolTip="Generate code from current canvas data"/>

                        <Button Grid.Column="1"
                                Content="⎘ Copy"
                                Style="{StaticResource ModernButtonStyle}"
                                Padding="16,8"
                                FontSize="11.5"
                                Command="{Binding CopyExportedCodeCommand}"
                                ToolTip="Copy generated code to clipboard"/>
                    </Grid>

                    <!-- Status and Stats -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Stale indicator -->
                        <TextBlock Grid.Column="0"
                                   Text="⟳ Code is outdated"
                                   Foreground="{DynamicResource Brush.Status.Warning}"
                                   FontSize="10.5"
                                   Opacity="0.85">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Hidden"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCodeStale}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Export Stats -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ExportStats}"
                                   Foreground="{DynamicResource Brush.Text.Muted}"
                                   FontSize="10"
                                   FontFamily="{DynamicResource Font.Code}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Opacity="0.8"/>
                    </Grid>

                </StackPanel>
                </Border>

                <!-- ═══════════════════════════════════════════════════════
                     IMPORT FROM CODE
                     ═══════════════════════════════════════════════════════ -->
                <Border Background="{DynamicResource Brush.Surface.Overlay}"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource Brush.Border.Base}"
                        BorderThickness="1"
                        Margin="10,10,10,10"
                        Padding="12,14,12,14">
                    <Border.Effect>
                        <DropShadowEffect Color="{DynamicResource Palette.Common.Shadow}" Opacity="0.15" BlurRadius="8" ShadowDepth="2" Direction="270" />
                    </Border.Effect>
                <StackPanel>
                    <TextBlock Text="IMPORT"
                               Style="{StaticResource HeaderStyle}"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="Import sprite data from Adafruit GFX, u8g2, plain C array, or raw hex code. Dimensions and variable name are auto-detected."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               FontSize="11"
                               Margin="0,0,0,16"
                               LineHeight="18"/>
                    <Button Content="Import from Code…"
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Click="ImportFromCode_Click"
                            ToolTip="Open the Import from Code dialog (Ctrl+Shift+I)"
                            Padding="8,8"
                            FontSize="11.5"/>
                    <Button Content="Import Bitmap…"
                            Style="{StaticResource ModernButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Click="ImportBitmap_Click"
                            Padding="8,8"
                            FontSize="11.5"
                            Margin="0,8,0,0"/>
                </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>


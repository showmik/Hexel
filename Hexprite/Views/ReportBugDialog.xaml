<Window x:Class="Hexprite.Views.ReportBugDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:Hexprite.Core"
        Title="Report a Bug"
        Width="560"
        SizeToContent="Height"
        MinHeight="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Surface.Base}"
        FontFamily="{DynamicResource Font.Primary}"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="False"
        core:WindowChromeHelper.ForceRoundedCorners="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="34"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="5"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border Style="{StaticResource DialogWindowBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource Brush.Surface.MenuBar}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               IsHitTestVisible="False"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Click="CaptionClose_Click" ToolTip="Close" Width="46" Height="34"
                                Style="{StaticResource CaptionCloseButtonStyle}">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Tell us what happened and we'll send this report to help improve Hexprite."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource Brush.Text.Muted}"
                           Margin="0,0,0,14" />

                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                    <TextBlock Text="Summary" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text.Primary}"/>
                    <TextBox x:Name="SummaryTextBox" MinHeight="32" MaxLength="200" Style="{StaticResource ModernTextBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,0,0,10">
                    <TextBlock Text="Steps to reproduce" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text.Primary}"/>
                    <TextBox x:Name="StepsTextBox" Height="78" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Style="{StaticResource ModernTextBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="0,0,0,10">
                    <TextBlock Text="Expected behavior" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text.Primary}"/>
                    <TextBox x:Name="ExpectedTextBox" Height="56" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Style="{StaticResource ModernTextBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="4" Margin="0,0,0,10">
                    <TextBlock Text="Actual behavior" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text.Primary}"/>
                    <TextBox x:Name="ActualTextBox" Height="56" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Style="{StaticResource ModernTextBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="5" Margin="0,0,0,8">
                    <TextBlock Text="Contact email (optional)" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text.Primary}"/>
                    <TextBox x:Name="EmailTextBox" MinHeight="32" MaxLength="200" Style="{StaticResource ModernTextBoxStyle}" />
                    <CheckBox x:Name="ShareEmailCheckBox"
                              Margin="0,6,0,0"
                              Content="Include this email in the report so we can contact you"
                              Foreground="{DynamicResource Brush.Text.Primary}" />
                    <CheckBox x:Name="IncludeLogsCheckBox"
                              Margin="0,10,0,4"
                              IsChecked="True"
                              Content="Include recent local logs to help diagnose the issue"
                              Foreground="{DynamicResource Brush.Text.Primary}" />
                    <TextBlock Text="Only include logs if you are comfortable sharing their contents."
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               FontSize="11"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Cancel"
                            Width="90"
                            MinHeight="30"
                            Margin="0,0,8,0"
                            Style="{StaticResource ModernButtonStyle}"
                            IsCancel="True"
                            Click="Cancel_Click"/>
                    <Button Content="Submit Report"
                            Width="130"
                            MinHeight="30"
                            Style="{StaticResource AccentButtonStyle}"
                            IsDefault="True"
                            Click="Submit_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>

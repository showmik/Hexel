<UserControl x:Class="Hexprite.Views.TimelinePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="170" d:DesignWidth="900">
    <Border Background="Transparent"
            Padding="0">
        <Grid>
            <Border Grid.Column="0"
                    Background="{DynamicResource Brush.Surface.Overlay}"
                    BorderBrush="{DynamicResource Brush.Border.Base}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10,8,10,10">
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource Palette.Common.Shadow}"
                                      Opacity="0.15"
                                      BlurRadius="10"
                                      ShadowDepth="2"
                                      Direction="270" />
                </Border.Effect>
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="FRAMES"
                                   Style="{StaticResource HeaderStyle}" />
                        <TextBlock Grid.Column="1"
                                   Text="(timeline area reserved for animation frames)"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.Text.Muted}"
                                   FontSize="11" />
                    </Grid>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="{DynamicResource Brush.Surface.Base}">
                        <Grid MinWidth="700" MinHeight="120" Margin="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="24" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Margin="1" BorderBrush="{DynamicResource Brush.Border.Base}" BorderThickness="1" Background="{DynamicResource Brush.Surface.Panel}">
                                <TextBlock Text="Layer/Frame" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{DynamicResource Brush.Text.Muted}" FontSize="10" />
                            </Border>
                            <Border Grid.Row="0" Grid.Column="1" Margin="1" BorderBrush="{DynamicResource Brush.Border.Base}" BorderThickness="1" />
                            <Border Grid.Row="0" Grid.Column="2" Margin="1" BorderBrush="{DynamicResource Brush.Border.Base}" BorderThickness="1" />
                            <Border Grid.Row="0" Grid.Column="3" Margin="1" BorderBrush="{DynamicResource Brush.Border.Base}" BorderThickness="1" />
                            <Border Grid.Row="0" Grid.Column="4" Margin="1" BorderBrush="{DynamicResource Brush.Border.Base}" BorderThickness="1" />
                            <Border Grid.Row="0" Grid.Column="5" Margin="1" BorderBrush="{DynamicResource Brush.Border.Base}" BorderThickness="1" />
                            <Border Grid.Row="0" Grid.Column="6" Margin="1" BorderBrush="{DynamicResource Brush.Border.Base}" BorderThickness="1" />
                            <Border Grid.Row="0" Grid.Column="7" Margin="1" BorderBrush="{DynamicResource Brush.Border.Base}" BorderThickness="1" />

                            <Border Grid.Row="1" Grid.ColumnSpan="8" Margin="1" BorderBrush="{DynamicResource Brush.Border.Base}" BorderThickness="1">
                                <TextBlock Text="Frame timeline scaffold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.Text.Muted}" />
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>

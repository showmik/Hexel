<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════════════════
         PALETTE (Colors) - FLIPPER ZERO THEME
         ═══════════════════════════════════════════════════════════ -->

    <!-- Surfaces & Backgrounds (Sleek Matte Black & Dark Grays) -->
    <Color x:Key="Palette.Surface.Base">#0A0A0A</Color>
    <!-- Slightly lighter pitch black for better contrast -->
    <Color x:Key="Palette.Surface.MenuBar">#0A0A0A</Color>
    <Color x:Key="Palette.Surface.StatusBar">#0A0A0A</Color>

    <Color x:Key="Palette.Surface.ToolSidebar">#121212</Color>
    <!-- More distinct raised surface -->
    <Color x:Key="Palette.Surface.RightSidebar">#121212</Color>

    <Color x:Key="Palette.Surface.Panel">#1A1A1A</Color>
    <!-- Standard dark panels with better hierarchy -->
    <Color x:Key="Palette.Surface.Toolbar">#242424</Color>
    <Color x:Key="Palette.Surface.Overlay">#2D2D2D</Color>
    <!-- Floating dropdowns -->

    <!-- Interaction States -->
    <Color x:Key="Palette.Surface.Hover">#333333</Color>
    <!-- Better contrast hover state -->
    <Color x:Key="Palette.Surface.Active">#404040</Color>

    <!-- Borders & Separators -->
    <Color x:Key="Palette.Border.Base">#404040</Color>
    <!-- More visible borders -->
    <Color x:Key="Palette.Border.Separator">#2D2D2D</Color>
    <Color x:Key="Palette.Border.StatusBar">#2D2D2D</Color>
    <Color x:Key="Palette.Border.Focus">#FF8200</Color>
    <!-- Flipper Orange focus ring -->

    <!-- Typography (Highly legible White/Gray with Black on Accents) -->
    <Color x:Key="Palette.Text.Primary">#F5F5F5</Color>
    <!-- Crisp White -->
    <Color x:Key="Palette.Text.Muted">#A3A3A3</Color>
    <!-- Better contrast medium gray -->
    <Color x:Key="Palette.Text.Inverse">#000000</Color>
    <Color x:Key="Palette.Text.OnAccent">#000000</Color>
    <!-- Black text on Orange looks amazing -->
    <Color x:Key="Palette.Text.Code">#E0E0E0</Color>

    <!-- Accent & Selection -->
    <Color x:Key="Palette.Accent.Base">#FF8200</Color>
    <!-- Iconic Flipper Orange -->
    <Color x:Key="Palette.Accent.Selection">#663400</Color>
    <!-- Dark burned orange for text highlight -->
    <Color x:Key="Palette.Accent.PreviewBorder">#FF8200</Color>
    <Color x:Key="Palette.Accent.GradientStart">#FF8200</Color>
    <Color x:Key="Palette.Accent.GradientEnd">#FF3300</Color>
    <!-- Orange to deep Red-Orange -->

    <!-- Status & Feedback -->
    <Color x:Key="Palette.Status.Success">#32D74B</Color>
    <!-- Bright Terminal Green -->
    <Color x:Key="Palette.Status.Warning">#FFD60A</Color>
    <!-- Vivid Yellow -->
    <Color x:Key="Palette.Status.Danger">#FF453A</Color>
    <!-- Bright Red -->

    <!-- Canvas & Drawing (High Contrast Revision) -->
    <Color x:Key="Palette.Canvas.Base">#1A1A1A</Color>
    <!-- Elevated dark gray "bezel" clearly visible against the #0A0A0A workspace -->
    <Color x:Key="Palette.Canvas.Pixel">#0A0A0A</Color>
    <!-- Better contrast drawing cells -->
    <Color x:Key="Palette.Canvas.Drawing">#FF8200</Color>
    <!-- Flipper Orange ink -->
    <Color x:Key="Palette.Canvas.Grid">#333333</Color>
    <!-- More visible etched grid lines -->
    <Color x:Key="Palette.Canvas.Crosshair">#80FFFFFF</Color>
    <!-- Clear translucent white -->

    <!-- Common Elements -->
    <Color x:Key="Palette.Common.Shadow">#000000</Color>
    <Color x:Key="Palette.Common.LassoFill">#33FF8200</Color>
    <!-- 20% Flipper Orange -->
    <Color x:Key="Palette.Common.BrushEdge">#DDFFFFFF</Color>
    <!-- White brush bounds for visibility -->
    <Color x:Key="Palette.Common.BrushFill">#40FF8200</Color>
    <!-- Orange brush fill -->

    <!-- Controls -->
    <Color x:Key="Palette.Control.Background">#242424</Color>
    <!-- Better contrast control background -->
    <Color x:Key="Palette.Control.Thumb">#4A4A4A</Color>
    <!-- More visible scrollbar thumb -->
    <Color x:Key="Palette.Control.ScrollBar">#121212</Color>
    <Color x:Key="Palette.Control.TextBox">#1A1A1A</Color>
    <!-- Better contrast input boxes -->
    <Color x:Key="Palette.Control.CheckBoxBorder">#4A4A4A</Color>

    <!-- Code / Syntax (Hacker / Terminal styling) -->
    <Color x:Key="Palette.Code.Keyword">#FF8200</Color>
    <!-- Flipper Orange -->
    <Color x:Key="Palette.Code.Literal">#32D74B</Color>
    <!-- Terminal Green -->
    <Color x:Key="Palette.Code.Comment">#808080</Color>
    <!-- Better contrast gray -->
    <Color x:Key="Palette.Code.Identifier">#F5F5F5</Color>
    <!-- Pure White -->
    <Color x:Key="Palette.Code.Punctuation">#B3B3B3</Color>

    <!-- Hardware Previews -->
    <Color x:Key="Palette.Preview.Base">#000000</Color>
    <Color x:Key="Palette.Preview.Drawing">#FF8200</Color>
    <!-- Simulates drawing orange on black -->
    <Color x:Key="Palette.Preview.OLED.Blue.BG">#000A1A</Color>
    <Color x:Key="Palette.Preview.OLED.Blue.FG">#40C4FF</Color>
    <Color x:Key="Palette.Preview.OLED.Green.BG">#001100</Color>
    <Color x:Key="Palette.Preview.OLED.Green.FG">#32D74B</Color>
    <Color x:Key="Palette.Preview.EPaper.BG">#D3D3D3</Color>
    <Color x:Key="Palette.Preview.EPaper.FG">#1A1A1A</Color>

    <!-- Flipper Zero (native palette) -->
    <Color x:Key="Palette.Preview.FlipperZero.BG">#000000</Color>
    <Color x:Key="Palette.Preview.FlipperZero.FG">#FF8200</Color>

    <!-- ═══════════════════════════════════════════════════════════
         BRUSHES
         ═══════════════════════════════════════════════════════════ -->

    <!-- Surfaces -->
    <SolidColorBrush x:Key="Brush.Surface.Base"
                     Color="{DynamicResource Palette.Surface.Base}" />
    <SolidColorBrush x:Key="Brush.Surface.Panel"
                     Color="{DynamicResource Palette.Surface.Panel}" />
    <SolidColorBrush x:Key="Brush.Surface.Overlay"
                     Color="{DynamicResource Palette.Surface.Overlay}" />
    <SolidColorBrush x:Key="Brush.Surface.MenuBar"
                     Color="{DynamicResource Palette.Surface.MenuBar}" />
    <SolidColorBrush x:Key="Brush.Surface.Toolbar"
                     Color="{DynamicResource Palette.Surface.Toolbar}" />
    <SolidColorBrush x:Key="Brush.Surface.StatusBar"
                     Color="{DynamicResource Palette.Surface.StatusBar}" />
    <SolidColorBrush x:Key="Brush.Surface.ToolSidebar"
                     Color="{DynamicResource Palette.Surface.ToolSidebar}" />
    <SolidColorBrush x:Key="Brush.Surface.Active"
                     Color="{DynamicResource Palette.Surface.Active}" />
    <SolidColorBrush x:Key="Brush.Surface.Hover"
                     Color="{DynamicResource Palette.Surface.Hover}" />
    <SolidColorBrush x:Key="Brush.Surface.RightSidebar"
                     Color="{DynamicResource Palette.Surface.RightSidebar}" />

    <!-- Borders -->
    <SolidColorBrush x:Key="Brush.Border.Base"
                     Color="{DynamicResource Palette.Border.Base}" />
    <SolidColorBrush x:Key="Brush.Border.Separator"
                     Color="{DynamicResource Palette.Border.Separator}" />
    <SolidColorBrush x:Key="Brush.Border.StatusBar"
                     Color="{DynamicResource Palette.Border.StatusBar}" />
    <SolidColorBrush x:Key="Brush.Border.Focus"
                     Color="{DynamicResource Palette.Border.Focus}" />

    <!-- Typography -->
    <SolidColorBrush x:Key="Brush.Text.Primary"
                     Color="{DynamicResource Palette.Text.Primary}" />
    <SolidColorBrush x:Key="Brush.Text.Muted"
                     Color="{DynamicResource Palette.Text.Muted}" />
    <SolidColorBrush x:Key="Brush.Text.Inverse"
                     Color="{DynamicResource Palette.Text.Inverse}" />
    <SolidColorBrush x:Key="Brush.Text.OnAccent"
                     Color="{DynamicResource Palette.Text.OnAccent}" />
    <SolidColorBrush x:Key="Brush.Text.Code"
                     Color="{DynamicResource Palette.Text.Code}" />

    <!-- Accent -->
    <SolidColorBrush x:Key="Brush.Accent.Base"
                     Color="{DynamicResource Palette.Accent.Base}" />
    <SolidColorBrush x:Key="Brush.Accent.Selection"
                     Color="{DynamicResource Palette.Accent.Selection}" />
    <SolidColorBrush x:Key="Brush.Accent.PreviewBorder"
                     Color="{DynamicResource Palette.Accent.PreviewBorder}" />

    <!-- Status -->
    <SolidColorBrush x:Key="Brush.Status.Success"
                     Color="{DynamicResource Palette.Status.Success}" />
    <SolidColorBrush x:Key="Brush.Status.Warning"
                     Color="{DynamicResource Palette.Status.Warning}" />
    <SolidColorBrush x:Key="Brush.Status.Danger"
                     Color="{DynamicResource Palette.Status.Danger}" />

    <!-- Canvas -->
    <SolidColorBrush x:Key="Brush.Canvas.Base"
                     Color="{DynamicResource Palette.Canvas.Base}" />
    <SolidColorBrush x:Key="Brush.Canvas.Pixel"
                     Color="{DynamicResource Palette.Canvas.Pixel}" />
    <SolidColorBrush x:Key="Brush.Canvas.Drawing"
                     Color="{DynamicResource Palette.Canvas.Drawing}" />
    <SolidColorBrush x:Key="Brush.Canvas.Grid"
                     Color="{DynamicResource Palette.Canvas.Grid}" />
    <SolidColorBrush x:Key="Brush.Canvas.Crosshair"
                     Color="{DynamicResource Palette.Canvas.Crosshair}" />

    <!-- Common -->
    <SolidColorBrush x:Key="Brush.Common.Shadow"
                     Color="{DynamicResource Palette.Common.Shadow}" />
    <SolidColorBrush x:Key="Brush.Common.LassoFill"
                     Color="{DynamicResource Palette.Common.LassoFill}" />

    <!-- Controls -->
    <SolidColorBrush x:Key="Brush.Control.Background"
                     Color="{DynamicResource Palette.Control.Background}" />
    <SolidColorBrush x:Key="Brush.Control.Thumb"
                     Color="{DynamicResource Palette.Control.Thumb}" />
    <SolidColorBrush x:Key="Brush.Control.ScrollBar"
                     Color="{DynamicResource Palette.Control.ScrollBar}" />
    <SolidColorBrush x:Key="Brush.Control.TextBox"
                     Color="{DynamicResource Palette.Control.TextBox}" />
    <SolidColorBrush x:Key="Brush.Control.CheckBoxBorder"
                     Color="{DynamicResource Palette.Control.CheckBoxBorder}" />

    <!-- Code / Syntax -->
    <SolidColorBrush x:Key="Brush.Code.Keyword"
                     Color="{DynamicResource Palette.Code.Keyword}" />
    <SolidColorBrush x:Key="Brush.Code.Literal"
                     Color="{DynamicResource Palette.Code.Literal}" />
    <SolidColorBrush x:Key="Brush.Code.Comment"
                     Color="{DynamicResource Palette.Code.Comment}" />
    <SolidColorBrush x:Key="Brush.Code.Identifier"
                     Color="{DynamicResource Palette.Code.Identifier}" />
    <SolidColorBrush x:Key="Brush.Code.Punctuation"
                     Color="{DynamicResource Palette.Code.Punctuation}" />

    <!-- Hardware Preview Brushes -->
    <SolidColorBrush x:Key="Brush.Preview.Base"
                     Color="{DynamicResource Palette.Preview.Base}" />
    <SolidColorBrush x:Key="Brush.Preview.Drawing"
                     Color="{DynamicResource Palette.Preview.Drawing}" />

    <!-- Display preview frame (bezel) -->
    <SolidColorBrush x:Key="Brush.DisplayPreview.FrameOuterBg" Color="#2B2B2B" />
    <SolidColorBrush x:Key="Brush.DisplayPreview.FrameOuterBorder" Color="#404040" />
    <SolidColorBrush x:Key="Brush.DisplayPreview.FrameInnerBg" Color="#1D1D1D" />
    <SolidColorBrush x:Key="Brush.DisplayPreview.FrameInnerBorder" Color="#585858" />
    <SolidColorBrush x:Key="Brush.DisplayPreview.FrameHighlight" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="Brush.DisplayPreview.FrameShadowColor" Color="#000000" />
    <sys:Double x:Key="DisplayPreview.FrameShadowOpacity">0.40</sys:Double>
    <sys:Double x:Key="DisplayPreview.FrameShadowBlur">18</sys:Double>
    <sys:Double x:Key="DisplayPreview.FrameShadowDepth">4</sys:Double>

</ResourceDictionary>
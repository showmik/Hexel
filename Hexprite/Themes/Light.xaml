<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         PALETTE (Colors)
         ═══════════════════════════════════════════════════════════ -->

    <!-- Surfaces & Backgrounds -->
    <Color x:Key="Palette.Surface.Base">#F5F5F5</Color>
    <Color x:Key="Palette.Surface.Panel">#FFFFFF</Color>
    <Color x:Key="Palette.Surface.Overlay">#FFFFFF</Color>
    <Color x:Key="Palette.Surface.MenuBar">#FFFFFF</Color>
    <Color x:Key="Palette.Surface.Toolbar">#F8F8F8</Color>
    <Color x:Key="Palette.Surface.StatusBar">#F0F0F0</Color>
    <Color x:Key="Palette.Surface.ToolSidebar">#F0F0F0</Color>
    <Color x:Key="Palette.Surface.Active">#E0E0E0</Color>
    <Color x:Key="Palette.Surface.Hover">#E0E0E0</Color>

    <!-- Borders & Separators -->
    <Color x:Key="Palette.Border.Base">#D1D5DB</Color>
    <Color x:Key="Palette.Border.Separator">#D1D5DB</Color>
    <Color x:Key="Palette.Border.StatusBar">#D1D5DB</Color>
    <Color x:Key="Palette.Border.Focus">#2563EB</Color>

    <!-- Typography -->
    <Color x:Key="Palette.Text.Primary">#111827</Color>
    <Color x:Key="Palette.Text.Muted">#6B7280</Color>
    <Color x:Key="Palette.Text.Inverse">#F9FAFB</Color>
    <Color x:Key="Palette.Text.OnAccent">#F9FAFB</Color>
    <Color x:Key="Palette.Text.Code">#6B7280</Color>

    <!-- Accent & Selection -->
    <Color x:Key="Palette.Accent.Base">#2563EB</Color>
    <Color x:Key="Palette.Accent.Selection">#2563EB</Color>
    <Color x:Key="Palette.Accent.PreviewBorder">#D97706</Color>
    <Color x:Key="Palette.Accent.GradientStart">#2563EB</Color>
    <Color x:Key="Palette.Accent.GradientEnd">#7C3AED</Color>

    <!-- Status & Feedback -->
    <Color x:Key="Palette.Status.Success">#16A34A</Color>
    <Color x:Key="Palette.Status.Warning">#D97706</Color>
    <Color x:Key="Palette.Status.Danger">#DC2626</Color>

    <!-- Canvas & Drawing -->
    <Color x:Key="Palette.Canvas.Base">#FFFFFF</Color>
    <Color x:Key="Palette.Canvas.Pixel">#FFFFFF</Color>
    <Color x:Key="Palette.Canvas.Drawing">#2563EB</Color>
    <Color x:Key="Palette.Canvas.Grid">#E5E7EB</Color>
    <Color x:Key="Palette.Canvas.Crosshair">#CC000000</Color>

    <!-- Common Elements -->
    <Color x:Key="Palette.Common.Shadow">#3D3D3D</Color>
    <Color x:Key="Palette.Common.LassoFill">#40D97706</Color>
    <Color x:Key="Palette.Common.BrushEdge">#DD000000</Color>
    <Color x:Key="Palette.Common.BrushFill">#40000000</Color>

    <!-- Controls -->
    <Color x:Key="Palette.Control.Background">#FFFFFF</Color>
    <Color x:Key="Palette.Control.Thumb">#C5C0B8</Color>
    <Color x:Key="Palette.Control.ScrollBar">#E4DFD7</Color>
    <Color x:Key="Palette.Control.TextBox">#FFFFFF</Color>
    <Color x:Key="Palette.Control.CheckBoxBorder">#9CA3AF</Color>

    <!-- Code / Syntax -->
    <Color x:Key="Palette.Code.Keyword">#2563EB</Color>
    <Color x:Key="Palette.Code.Literal">#059669</Color>
    <Color x:Key="Palette.Code.Comment">#64748B</Color>
    <Color x:Key="Palette.Code.Identifier">#0F766E</Color>
    <Color x:Key="Palette.Code.Punctuation">#334155</Color>

    <!-- Hardware Previews -->
    <Color x:Key="Palette.Preview.Base">#FFFFFF</Color>
    <Color x:Key="Palette.Preview.Drawing">#2563EB</Color>
    <Color x:Key="Palette.Preview.OLED.Blue.BG">#000A1A</Color>
    <Color x:Key="Palette.Preview.OLED.Blue.FG">#82C9FF</Color>
    <Color x:Key="Palette.Preview.OLED.Green.BG">#051105</Color>
    <Color x:Key="Palette.Preview.OLED.Green.FG">#72FF72</Color>
    <Color x:Key="Palette.Preview.EPaper.BG">#D3D3D3</Color>
    <Color x:Key="Palette.Preview.EPaper.FG">#1A1A1A</Color>

    <!-- ═══════════════════════════════════════════════════════════
         BRUSHES
         ═══════════════════════════════════════════════════════════ -->

    <!-- Surfaces -->
    <SolidColorBrush x:Key="Brush.Surface.Base" Color="{StaticResource Palette.Surface.Base}" />
    <SolidColorBrush x:Key="Brush.Surface.Panel" Color="{StaticResource Palette.Surface.Panel}" />
    <SolidColorBrush x:Key="Brush.Surface.Overlay" Color="{StaticResource Palette.Surface.Overlay}" />
    <SolidColorBrush x:Key="Brush.Surface.MenuBar" Color="{StaticResource Palette.Surface.MenuBar}" />
    <SolidColorBrush x:Key="Brush.Surface.Toolbar" Color="{StaticResource Palette.Surface.Toolbar}" />
    <SolidColorBrush x:Key="Brush.Surface.StatusBar" Color="{StaticResource Palette.Surface.StatusBar}" />
    <SolidColorBrush x:Key="Brush.Surface.ToolSidebar" Color="{StaticResource Palette.Surface.ToolSidebar}" />
    <SolidColorBrush x:Key="Brush.Surface.Active" Color="{StaticResource Palette.Surface.Active}" />
    <SolidColorBrush x:Key="Brush.Surface.Hover" Color="{StaticResource Palette.Surface.Hover}" />
    <LinearGradientBrush x:Key="Brush.Surface.RightSidebar" StartPoint="0,0" EndPoint="0.8,1">
        <GradientStop Color="{StaticResource Palette.Surface.StatusBar}" Offset="0" />
        <GradientStop Color="{StaticResource Palette.Surface.StatusBar}" Offset="1" />
    </LinearGradientBrush>

    <!-- Borders -->
    <SolidColorBrush x:Key="Brush.Border.Base" Color="{StaticResource Palette.Border.Base}" />
    <SolidColorBrush x:Key="Brush.Border.Separator" Color="{StaticResource Palette.Border.Separator}" />
    <SolidColorBrush x:Key="Brush.Border.StatusBar" Color="{StaticResource Palette.Border.StatusBar}" />
    <SolidColorBrush x:Key="Brush.Border.Focus" Color="{StaticResource Palette.Border.Focus}" />

    <!-- Typography -->
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Palette.Text.Primary}" />
    <SolidColorBrush x:Key="Brush.Text.Muted" Color="{StaticResource Palette.Text.Muted}" />
    <SolidColorBrush x:Key="Brush.Text.Inverse" Color="{StaticResource Palette.Text.Inverse}" />
    <SolidColorBrush x:Key="Brush.Text.OnAccent" Color="{StaticResource Palette.Text.OnAccent}" />
    <SolidColorBrush x:Key="Brush.Text.Code" Color="{StaticResource Palette.Text.Code}" />

    <!-- Accent -->
    <SolidColorBrush x:Key="Brush.Accent.Base" Color="{StaticResource Palette.Accent.Base}" />
    <SolidColorBrush x:Key="Brush.Accent.Selection" Color="{StaticResource Palette.Accent.Selection}" />
    <SolidColorBrush x:Key="Brush.Accent.PreviewBorder" Color="{StaticResource Palette.Accent.PreviewBorder}" />

    <!-- Status -->
    <SolidColorBrush x:Key="Brush.Status.Success" Color="{StaticResource Palette.Status.Success}" />
    <SolidColorBrush x:Key="Brush.Status.Warning" Color="{StaticResource Palette.Status.Warning}" />
    <SolidColorBrush x:Key="Brush.Status.Danger" Color="{StaticResource Palette.Status.Danger}" />

    <!-- Canvas -->
    <SolidColorBrush x:Key="Brush.Canvas.Base" Color="{StaticResource Palette.Canvas.Base}" />
    <SolidColorBrush x:Key="Brush.Canvas.Pixel" Color="{StaticResource Palette.Canvas.Pixel}" />
    <SolidColorBrush x:Key="Brush.Canvas.Drawing" Color="{StaticResource Palette.Canvas.Drawing}" />
    <SolidColorBrush x:Key="Brush.Canvas.Grid" Color="{StaticResource Palette.Canvas.Grid}" />
    <SolidColorBrush x:Key="Brush.Canvas.Crosshair" Color="{StaticResource Palette.Canvas.Crosshair}" />

    <!-- Common -->
    <SolidColorBrush x:Key="Brush.Common.Shadow" Color="{StaticResource Palette.Common.Shadow}" />
    <SolidColorBrush x:Key="Brush.Common.LassoFill" Color="{StaticResource Palette.Common.LassoFill}" />

    <!-- Controls -->
    <SolidColorBrush x:Key="Brush.Control.Background" Color="{StaticResource Palette.Control.Background}" />
    <SolidColorBrush x:Key="Brush.Control.Thumb" Color="{StaticResource Palette.Control.Thumb}" />
    <SolidColorBrush x:Key="Brush.Control.ScrollBar" Color="{StaticResource Palette.Control.ScrollBar}" />
    <SolidColorBrush x:Key="Brush.Control.TextBox" Color="{StaticResource Palette.Control.TextBox}" />
    <SolidColorBrush x:Key="Brush.Control.CheckBoxBorder" Color="{StaticResource Palette.Control.CheckBoxBorder}" />

    <!-- Code / Syntax -->
    <SolidColorBrush x:Key="Brush.Code.Keyword" Color="{StaticResource Palette.Code.Keyword}" />
    <SolidColorBrush x:Key="Brush.Code.Literal" Color="{StaticResource Palette.Code.Literal}" />
    <SolidColorBrush x:Key="Brush.Code.Comment" Color="{StaticResource Palette.Code.Comment}" />
    <SolidColorBrush x:Key="Brush.Code.Identifier" Color="{StaticResource Palette.Code.Identifier}" />
    <SolidColorBrush x:Key="Brush.Code.Punctuation" Color="{StaticResource Palette.Code.Punctuation}" />

    <!-- Hardware Preview Brushes -->
    <SolidColorBrush x:Key="Brush.Preview.Base" Color="{StaticResource Palette.Preview.Base}" />
    <SolidColorBrush x:Key="Brush.Preview.Drawing" Color="{StaticResource Palette.Preview.Drawing}" />

</ResourceDictionary>

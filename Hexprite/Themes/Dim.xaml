<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         PALETTE (Colors)
         ═══════════════════════════════════════════════════════════ -->

    <!-- Surfaces & Backgrounds -->
    <Color x:Key="Palette.Surface.Base">#2D333B</Color>
    <Color x:Key="Palette.Surface.Panel">#22272E</Color>
    <Color x:Key="Palette.Surface.Overlay">#22272E</Color>
    <Color x:Key="Palette.Surface.MenuBar">#22272E</Color>
    <Color x:Key="Palette.Surface.Toolbar">#1C2128</Color>
    <Color x:Key="Palette.Surface.StatusBar">#1C2128</Color>
    <Color x:Key="Palette.Surface.ToolSidebar">#1C2128</Color>
    <Color x:Key="Palette.Surface.Active">#373E47</Color>
    <Color x:Key="Palette.Surface.Hover">#373E47</Color>
    <Color x:Key="Palette.Surface.RightSidebar">#2D333B</Color>

    <!-- Borders & Separators -->
    <Color x:Key="Palette.Border.Base">#444C56</Color>
    <Color x:Key="Palette.Border.Separator">#444C56</Color>
    <Color x:Key="Palette.Border.StatusBar">#444C56</Color>
    <Color x:Key="Palette.Border.Focus">#316DCA</Color>

    <!-- Typography -->
    <Color x:Key="Palette.Text.Primary">#ADBAC7</Color>
    <Color x:Key="Palette.Text.Muted">#768390</Color>
    <Color x:Key="Palette.Text.Inverse">#1C2128</Color>
    <Color x:Key="Palette.Text.OnAccent">#FFFFFF</Color>
    <Color x:Key="Palette.Text.Code">#768390</Color>

    <!-- Accent & Selection -->
    <Color x:Key="Palette.Accent.Base">#316DCA</Color>
    <Color x:Key="Palette.Accent.Selection">#316DCA</Color>
    <Color x:Key="Palette.Accent.PreviewBorder">#AE7313</Color>
    <Color x:Key="Palette.Accent.GradientStart">#316DCA</Color>
    <Color x:Key="Palette.Accent.GradientEnd">#8250DF</Color>

    <!-- Status & Feedback -->
    <Color x:Key="Palette.Status.Success">#57AB5A</Color>
    <Color x:Key="Palette.Status.Warning">#AE7313</Color>
    <Color x:Key="Palette.Status.Danger">#E5534B</Color>

    <!-- Canvas & Drawing -->
    <Color x:Key="Palette.Canvas.Base">#171B22</Color>
    <Color x:Key="Palette.Canvas.Pixel">#1C2128</Color>
    <Color x:Key="Palette.Canvas.Drawing">#79C0FF</Color>
    <Color x:Key="Palette.Canvas.Grid">#2D333B</Color>
    <Color x:Key="Palette.Canvas.Crosshair">#CCFFFFFF</Color>

    <!-- Common Elements -->
    <Color x:Key="Palette.Common.Shadow">#15191E</Color>
    <Color x:Key="Palette.Common.LassoFill">#40AE7313</Color>
    <Color x:Key="Palette.Common.BrushEdge">#DDFFFFFF</Color>
    <Color x:Key="Palette.Common.BrushFill">#40FFFFFF</Color>

    <!-- Controls -->
    <Color x:Key="Palette.Control.Background">#2D333B</Color>
    <Color x:Key="Palette.Control.Thumb">#4A5261</Color>
    <Color x:Key="Palette.Control.ScrollBar">#252C34</Color>
    <Color x:Key="Palette.Control.TextBox">#1C2128</Color>
    <Color x:Key="Palette.Control.CheckBoxBorder">#545D68</Color>

    <!-- Code / Syntax -->
    <Color x:Key="Palette.Code.Keyword">#79C0FF</Color>
    <Color x:Key="Palette.Code.Literal">#7EE787</Color>
    <Color x:Key="Palette.Code.Comment">#8B949E</Color>
    <Color x:Key="Palette.Code.Identifier">#D2A8FF</Color>
    <Color x:Key="Palette.Code.Punctuation">#C9D1D9</Color>

    <!-- Hardware Previews -->
    <Color x:Key="Palette.Preview.Base">#1C2128</Color>
    <Color x:Key="Palette.Preview.Drawing">#316DCA</Color>
    <Color x:Key="Palette.Preview.OLED.Blue.BG">#000A1A</Color>
    <Color x:Key="Palette.Preview.OLED.Blue.FG">#82C9FF</Color>
    <Color x:Key="Palette.Preview.OLED.Green.BG">#051105</Color>
    <Color x:Key="Palette.Preview.OLED.Green.FG">#72FF72</Color>
    <Color x:Key="Palette.Preview.EPaper.BG">#D3D3D3</Color>
    <Color x:Key="Palette.Preview.EPaper.FG">#1A1A1A</Color>

    <!-- ═══════════════════════════════════════════════════════════
         BRUSHES
         ═══════════════════════════════════════════════════════════ -->

    <!-- Surfaces -->
    <SolidColorBrush x:Key="Brush.Surface.Base" Color="{DynamicResource Palette.Surface.Base}" />
    <SolidColorBrush x:Key="Brush.Surface.Panel" Color="{DynamicResource Palette.Surface.Panel}" />
    <SolidColorBrush x:Key="Brush.Surface.Overlay" Color="{DynamicResource Palette.Surface.Overlay}" />
    <SolidColorBrush x:Key="Brush.Surface.MenuBar" Color="{DynamicResource Palette.Surface.MenuBar}" />
    <SolidColorBrush x:Key="Brush.Surface.Toolbar" Color="{DynamicResource Palette.Surface.Toolbar}" />
    <SolidColorBrush x:Key="Brush.Surface.StatusBar" Color="{DynamicResource Palette.Surface.StatusBar}" />
    <SolidColorBrush x:Key="Brush.Surface.ToolSidebar" Color="{DynamicResource Palette.Surface.ToolSidebar}" />
    <SolidColorBrush x:Key="Brush.Surface.Active" Color="{DynamicResource Palette.Surface.Active}" />
    <SolidColorBrush x:Key="Brush.Surface.Hover" Color="{DynamicResource Palette.Surface.Hover}" />
    <SolidColorBrush x:Key="Brush.Surface.RightSidebar" Color="{DynamicResource Palette.Surface.RightSidebar}" />

    <!-- Borders -->
    <SolidColorBrush x:Key="Brush.Border.Base" Color="{DynamicResource Palette.Border.Base}" />
    <SolidColorBrush x:Key="Brush.Border.Separator" Color="{DynamicResource Palette.Border.Separator}" />
    <SolidColorBrush x:Key="Brush.Border.StatusBar" Color="{DynamicResource Palette.Border.StatusBar}" />
    <SolidColorBrush x:Key="Brush.Border.Focus" Color="{DynamicResource Palette.Border.Focus}" />

    <!-- Typography -->
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{DynamicResource Palette.Text.Primary}" />
    <SolidColorBrush x:Key="Brush.Text.Muted" Color="{DynamicResource Palette.Text.Muted}" />
    <SolidColorBrush x:Key="Brush.Text.Inverse" Color="{DynamicResource Palette.Text.Inverse}" />
    <SolidColorBrush x:Key="Brush.Text.OnAccent" Color="{DynamicResource Palette.Text.OnAccent}" />
    <SolidColorBrush x:Key="Brush.Text.Code" Color="{DynamicResource Palette.Text.Code}" />

    <!-- Accent -->
    <SolidColorBrush x:Key="Brush.Accent.Base" Color="{DynamicResource Palette.Accent.Base}" />
    <SolidColorBrush x:Key="Brush.Accent.Selection" Color="{DynamicResource Palette.Accent.Selection}" />
    <SolidColorBrush x:Key="Brush.Accent.PreviewBorder" Color="{DynamicResource Palette.Accent.PreviewBorder}" />

    <!-- Status -->
    <SolidColorBrush x:Key="Brush.Status.Success" Color="{DynamicResource Palette.Status.Success}" />
    <SolidColorBrush x:Key="Brush.Status.Warning" Color="{DynamicResource Palette.Status.Warning}" />
    <SolidColorBrush x:Key="Brush.Status.Danger" Color="{DynamicResource Palette.Status.Danger}" />

    <!-- Canvas -->
    <SolidColorBrush x:Key="Brush.Canvas.Base" Color="{DynamicResource Palette.Canvas.Base}" />
    <SolidColorBrush x:Key="Brush.Canvas.Pixel" Color="{DynamicResource Palette.Canvas.Pixel}" />
    <SolidColorBrush x:Key="Brush.Canvas.Drawing" Color="{DynamicResource Palette.Canvas.Drawing}" />
    <SolidColorBrush x:Key="Brush.Canvas.Grid" Color="{DynamicResource Palette.Canvas.Grid}" />
    <SolidColorBrush x:Key="Brush.Canvas.Crosshair" Color="{DynamicResource Palette.Canvas.Crosshair}" />

    <!-- Common -->
    <SolidColorBrush x:Key="Brush.Common.Shadow" Color="{DynamicResource Palette.Common.Shadow}" />
    <SolidColorBrush x:Key="Brush.Common.LassoFill" Color="{DynamicResource Palette.Common.LassoFill}" />

    <!-- Controls -->
    <SolidColorBrush x:Key="Brush.Control.Background" Color="{DynamicResource Palette.Control.Background}" />
    <SolidColorBrush x:Key="Brush.Control.Thumb" Color="{DynamicResource Palette.Control.Thumb}" />
    <SolidColorBrush x:Key="Brush.Control.ScrollBar" Color="{DynamicResource Palette.Control.ScrollBar}" />
    <SolidColorBrush x:Key="Brush.Control.TextBox" Color="{DynamicResource Palette.Control.TextBox}" />
    <SolidColorBrush x:Key="Brush.Control.CheckBoxBorder" Color="{DynamicResource Palette.Control.CheckBoxBorder}" />

    <!-- Code / Syntax -->
    <SolidColorBrush x:Key="Brush.Code.Keyword" Color="{DynamicResource Palette.Code.Keyword}" />
    <SolidColorBrush x:Key="Brush.Code.Literal" Color="{DynamicResource Palette.Code.Literal}" />
    <SolidColorBrush x:Key="Brush.Code.Comment" Color="{DynamicResource Palette.Code.Comment}" />
    <SolidColorBrush x:Key="Brush.Code.Identifier" Color="{DynamicResource Palette.Code.Identifier}" />
    <SolidColorBrush x:Key="Brush.Code.Punctuation" Color="{DynamicResource Palette.Code.Punctuation}" />

    <!-- Hardware Preview Brushes -->
    <SolidColorBrush x:Key="Brush.Preview.Base" Color="{DynamicResource Palette.Preview.Base}" />
    <SolidColorBrush x:Key="Brush.Preview.Drawing" Color="{DynamicResource Palette.Preview.Drawing}" />

</ResourceDictionary>

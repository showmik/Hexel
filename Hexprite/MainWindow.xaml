<Window x:Class="Hexprite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:Hexprite.Core"
        xmlns:vm="clr-namespace:Hexprite.ViewModels"
        xmlns:views="clr-namespace:Hexprite.Views"
        Title="Hexprite"
        MinHeight="650"
        MinWidth="950"
        Height="780"
        Width="1150"
        Background="{DynamicResource Theme.BackgroundBrush}"
        FontFamily="{DynamicResource Theme.MainFont}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        core:WindowChromeHelper.ForceRoundedCorners="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="34"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="5"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="Z"
                    Modifiers="Ctrl"
                    Command="{Binding ActiveDocument.UndoCommand}" />
        <KeyBinding Key="Y"
                    Modifiers="Ctrl"
                    Command="{Binding ActiveDocument.RedoCommand}" />
        <KeyBinding Key="S"
                    Modifiers="Ctrl"
                    Command="{Binding SaveCommand}" />
        <KeyBinding Key="S"
                    Modifiers="Ctrl+Shift"
                    Command="{Binding SaveAsCommand}" />
        <KeyBinding Key="N"
                    Modifiers="Ctrl"
                    Command="{Binding NewCanvasCommand}" />
        <KeyBinding Key="O"
                    Modifiers="Ctrl"
                    Command="{Binding OpenCommand}" />
        <KeyBinding Key="W"
                    Modifiers="Ctrl"
                    Command="{Binding CloseTabCommand}" />
        <KeyBinding Key="OemPlus"
                    Modifiers="Ctrl"
                    Command="{x:Static NavigationCommands.IncreaseZoom}" />
        <KeyBinding Key="OemMinus"
                    Modifiers="Ctrl"
                    Command="{x:Static NavigationCommands.DecreaseZoom}" />
        <KeyBinding Key="D0"
                    Modifiers="Ctrl"
                    Command="{x:Static NavigationCommands.Zoom}" />
        <KeyBinding Key="F1"
                    Command="{Binding OpenDocumentationCommand}" />
        <KeyBinding Key="C"
                    Modifiers="Ctrl"
                    Command="{Binding ActiveDocument.CopySelectionCommand}" />
        <KeyBinding Key="X"
                    Modifiers="Ctrl"
                    Command="{Binding ActiveDocument.CutSelectionCommand}" />
        <KeyBinding Key="V"
                    Modifiers="Ctrl"
                    Command="{Binding ActiveDocument.PasteCommand}" />
        <KeyBinding Key="D"
                    Modifiers="Ctrl"
                    Command="{Binding ActiveDocument.DeselectCommand}" />
        <KeyBinding Key="I"
                    Modifiers="Ctrl+Shift"
                    Command="{Binding ImportFromCodeMenuCommand}" />
    </Window.InputBindings>

    <Border BorderThickness="{x:Static core:WindowChromeHelper.FallbackBorderThickness}" BorderBrush="{DynamicResource Theme.PanelBorderBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             CUSTOM TITLE BAR (menu + caption buttons)
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource Theme.MenuBarBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App icon -->
                <Border Grid.Column="0" Margin="8,0,4,0"
                        Width="22" Height="22" CornerRadius="5"
                        VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Border.Background>
                        <ImageBrush ImageSource="pack://application:,,,/Assets/AppIcon.png" Stretch="UniformToFill" />
                    </Border.Background>
                </Border>

                <!-- Menu bar -->
                <Menu Grid.Column="1" WindowChrome.IsHitTestVisibleInChrome="True"
                      VerticalAlignment="Center">
                    <MenuItem Header="_File">
                        <MenuItem Header="_New Canvas" Command="{Binding NewCanvasCommand}" InputGestureText="Ctrl+N"/>
                        <MenuItem Header="_Open" Command="{Binding OpenCommand}" InputGestureText="Ctrl+O"/>
                        <MenuItem Header="_Import from Code…" Command="{Binding ImportFromCodeMenuCommand}" InputGestureText="Ctrl+Shift+I"/>
                        <Separator Style="{StaticResource MenuSeparatorStyle}"/>
                        <MenuItem Header="_Save" Command="{Binding SaveCommand}" InputGestureText="Ctrl+S"/>
                        <MenuItem Header="Save _As..." Command="{Binding SaveAsCommand}" InputGestureText="Ctrl+Shift+S"/>
                        <MenuItem Header="Copy _Export Code" Command="{Binding CopyExportCodeMenuCommand}"/>
                        <Separator Style="{StaticResource MenuSeparatorStyle}"/>
                        <MenuItem Header="_Close Tab" Command="{Binding CloseTabCommand}" InputGestureText="Ctrl+W"/>
                    </MenuItem>
                    <MenuItem Header="_Edit">
                        <MenuItem Header="_Undo" Command="{Binding ActiveDocument.UndoCommand}" InputGestureText="Ctrl+Z"/>
                        <MenuItem Header="_Redo" Command="{Binding ActiveDocument.RedoCommand}" InputGestureText="Ctrl+Y"/>
                        <Separator Style="{StaticResource MenuSeparatorStyle}"/>
                        <MenuItem Header="_Invert" Command="{Binding ActiveDocument.InvertCommand}"/>
                        <MenuItem Header="_Clear Canvas" Command="{Binding ActiveDocument.ClearCommand}"/>
                        <Separator Style="{StaticResource MenuSeparatorStyle}"/>
                        <MenuItem Header="Cu_t" Command="{Binding ActiveDocument.CutSelectionCommand}" InputGestureText="Ctrl+X"/>
                        <MenuItem Header="_Copy" Command="{Binding ActiveDocument.CopySelectionCommand}" InputGestureText="Ctrl+C"/>
                        <MenuItem Header="_Paste" Command="{Binding ActiveDocument.PasteCommand}" InputGestureText="Ctrl+V"/>
                    </MenuItem>
                    <MenuItem Header="_Image">
                        <MenuItem Header="Canvas _Size..." Command="{Binding ResizeCanvasCommand}"/>
                    </MenuItem>
                    <MenuItem Header="_View">
                        <MenuItem Header="Show _Grid" IsCheckable="True" IsChecked="{Binding ActiveDocument.ShowGridLines}"/>
                        <Separator Style="{StaticResource MenuSeparatorStyle}"/>
                        <MenuItem Header="Zoom _In" Command="{x:Static NavigationCommands.IncreaseZoom}" InputGestureText="Ctrl++"/>
                        <MenuItem Header="Zoom _Out" Command="{x:Static NavigationCommands.DecreaseZoom}" InputGestureText="Ctrl+-"/>
                        <MenuItem Header="_Reset Zoom" Command="{x:Static NavigationCommands.Zoom}" InputGestureText="Ctrl+0"/>
                        <Separator Style="{StaticResource MenuSeparatorStyle}"/>
                        <MenuItem Header="_Theme">
                            <MenuItem Header="_Dark" IsCheckable="True" IsChecked="{Binding IsDarkTheme, Mode=OneWay}"
                                      Command="{Binding SwitchThemeCommand}" CommandParameter="Dark"/>
                            <MenuItem Header="_Dim" IsCheckable="True" IsChecked="{Binding IsDimTheme, Mode=OneWay}"
                                      Command="{Binding SwitchThemeCommand}" CommandParameter="Dim"/>
                            <MenuItem Header="_Light" IsCheckable="True" IsChecked="{Binding IsLightTheme, Mode=OneWay}"
                                      Command="{Binding SwitchThemeCommand}" CommandParameter="Light"/>
                        </MenuItem>
                    </MenuItem>
                    <MenuItem Header="_Selection">
                        <MenuItem Header="Cu_t" Command="{Binding ActiveDocument.CutSelectionCommand}" InputGestureText="Ctrl+X"/>
                        <MenuItem Header="_Copy" Command="{Binding ActiveDocument.CopySelectionCommand}" InputGestureText="Ctrl+C"/>
                        <MenuItem Header="_Paste" Command="{Binding ActiveDocument.PasteCommand}" InputGestureText="Ctrl+V"/>
                        <Separator Style="{StaticResource MenuSeparatorStyle}"/>
                        <MenuItem Header="_Delete Selection" Command="{Binding ActiveDocument.DeleteSelectionCommand}" InputGestureText="Del"/>
                        <Separator Style="{StaticResource MenuSeparatorStyle}"/>
                        <MenuItem Header="D_eselect" Command="{Binding ActiveDocument.DeselectCommand}" InputGestureText="Ctrl+D"/>
                    </MenuItem>
                    <MenuItem Header="_Help">
                        <MenuItem Header="_Documentation" Command="{Binding OpenDocumentationCommand}" InputGestureText="F1"/>
                        <Separator Style="{StaticResource MenuSeparatorStyle}"/>
                        <MenuItem Header="_About Hexprite" Command="{Binding ShowAboutCommand}"/>
                    </MenuItem>
                </Menu>

                <!-- Title -->
                <TextBlock Grid.Column="2" Text="Hexprite"
                           Foreground="{DynamicResource Theme.TextMutedBrush}"
                           FontSize="12" VerticalAlignment="Center"
                           HorizontalAlignment="Center" IsHitTestVisible="False"/>

                <!-- Caption buttons -->
                <StackPanel Grid.Column="3" Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Click="CaptionMinimize_Click" ToolTip="Minimize" Width="46" Height="34"
                            Style="{StaticResource CaptionButtonStyle}">
                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                    <Button Click="CaptionMaximize_Click" ToolTip="Maximize" Width="46" Height="34"
                            Style="{StaticResource CaptionButtonStyle}">
                        <TextBlock x:Name="MaximizeIcon" Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                    <Button Click="CaptionClose_Click" ToolTip="Close" Width="46" Height="34"
                            Style="{StaticResource CaptionCloseButtonStyle}">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             TAB BAR
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{DynamicResource Theme.MenuBarBackgroundBrush}"
                BorderBrush="{DynamicResource Theme.SeparatorBrush}"
                BorderThickness="0,0,0,1"
                Padding="4,0">
            <StackPanel Orientation="Horizontal">
                <ItemsControl ItemsSource="{Binding OpenDocuments}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="TabBorder"
                                    Margin="0,4,2,4"
                                    CornerRadius="6"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="Tab_MouseLeftButtonDown">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource Theme.ToolSidebarActiveBrush}" />
                                            </DataTrigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsMouseOver" Value="True" />
                                                </MultiTrigger.Conditions>
                                                <Setter Property="Background" Value="{DynamicResource Theme.MenuItemHoverBrush}" />
                                            </MultiTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,6,10,4">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{DynamicResource Theme.TextMainBrush}"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   Margin="0,0,8,0" />
                                        <Button x:Name="CloseBtn"
                                                Content="✕"
                                                FontSize="10"
                                                Padding="2,0"
                                                MinWidth="16" MinHeight="16"
                                                VerticalAlignment="Center"
                                                Cursor="Hand"
                                                Click="TabClose_Click"
                                                Tag="{Binding}"
                                                Opacity="0">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="Foreground" Value="{DynamicResource Theme.TextMutedBrush}" />
                                                    <Setter Property="BorderThickness" Value="0" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        CornerRadius="3"
                                                                        Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center" />
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Theme.DangerBrush}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource Theme.TextOnAccentBrush}" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                    <!-- Active tab accent indicator -->
                                    <Border x:Name="ActiveIndicator" Grid.Row="1"
                                            Height="2" CornerRadius="1"
                                            Margin="6,0,6,2"
                                            Opacity="0"
                                            Background="{DynamicResource Theme.PrimaryAccentBrush}"/>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter TargetName="ActiveIndicator" Property="Opacity" Value="1"/>
                                    <Setter TargetName="CloseBtn" Property="Opacity" Value="1"/>
                                </DataTrigger>
                                <Trigger SourceName="TabBorder" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CloseBtn" Property="Opacity" Value="1"/>
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- New tab button -->
                <Button Content="+"
                        FontSize="14"
                        FontWeight="Bold"
                        Padding="8,4"
                        Margin="4,4"
                        VerticalAlignment="Center"
                        Command="{Binding NewCanvasCommand}"
                        ToolTip="New canvas (Ctrl+N)">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{DynamicResource Theme.TextMutedBrush}" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Theme.MenuItemHoverBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource Theme.TextMainBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT AREA
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2"
              DataContext="{Binding ActiveDocument}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="2" />
                <ColumnDefinition Width="400"
                                  MinWidth="300"
                                  MaxWidth="600" />
            </Grid.ColumnDefinitions>

            <views:ToolSidebarPanel x:Name="ToolSidebar" Grid.Column="0" />

            <views:CanvasPanel x:Name="Canvas" Grid.Column="1" 
                               Margin="15,20,20,20"
                               ZoomInClicked="BtnZoomIn_Click"
                               ZoomOutClicked="BtnZoomOut_Click"
                               ZoomResetClicked="BtnZoomReset_Click" />

            <GridSplitter Grid.Column="2"
                          Width="2"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource Theme.PanelBackgroundBrush}"
                          Cursor="SizeWE" />

            <views:SidebarPanel Grid.Column="3" Margin="0" />
        </Grid>
        <!-- /Main content -->

        <views:StatusBarPanel Grid.Row="3" DataContext="{Binding ActiveDocument}" />

        <!-- ═══════════════════════════════════════════════════════════════
             WELCOME SCREEN (shown when no documents are open)
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Grid.RowSpan="2">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasOpenDocument}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        MaxWidth="460">
                <!-- App branding -->
                <Border Width="72" Height="72"
                        CornerRadius="18"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,20">
                    <Border.Background>
                        <ImageBrush ImageSource="pack://application:,,,/Assets/AppIcon.png" Stretch="UniformToFill" />
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="{DynamicResource Color.BrandGradientStart}" BlurRadius="20" Opacity="0.3"
                                          Direction="270" ShadowDepth="4"/>
                    </Border.Effect>
                </Border>
                <TextBlock Text="Welcome to Hexprite" 
                           FontSize="26" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource Theme.TextMainBrush}" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,6" />
                <TextBlock Text="Monochrome pixel art editor for embedded displays" 
                           FontSize="13"
                           Foreground="{DynamicResource Theme.TextMutedBrush}" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32" />

                <!-- Quick-start presets -->
                <TextBlock Text="QUICK START"
                           Style="{StaticResource HeaderStyle}"
                           HorizontalAlignment="Center"
                           FontSize="11"
                           Margin="0,0,0,12"/>
                <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Button Content="8 × 8" 
                            Command="{Binding NewCanvasCommand}"
                            CommandParameter="8x8"
                            Margin="4" Padding="20,10" 
                            Style="{StaticResource ModernButtonStyle}"
                            ToolTip="Create 8×8 canvas" />
                    <Button Content="16 × 16" 
                            Command="{Binding NewCanvasCommand}"
                            CommandParameter="16x16"
                            Margin="4" Padding="20,10" 
                            Style="{StaticResource ModernButtonStyle}"
                            ToolTip="Create 16×16 canvas" />
                    <Button Content="32 × 32" 
                            Command="{Binding NewCanvasCommand}"
                            CommandParameter="32x32"
                            Margin="4" Padding="20,10" 
                            Style="{StaticResource ModernButtonStyle}"
                            ToolTip="Create 32×32 canvas" />
                    <Button Content="64 × 64" 
                            Command="{Binding NewCanvasCommand}"
                            CommandParameter="64x64"
                            Margin="4" Padding="20,10" 
                            Style="{StaticResource ModernButtonStyle}"
                            ToolTip="Create 64×64 canvas" />
                    <Button Content="128 × 64" 
                            Command="{Binding NewCanvasCommand}"
                            CommandParameter="128x64"
                            Margin="4" Padding="20,10" 
                            Style="{StaticResource ModernButtonStyle}"
                            ToolTip="Create 128×64 canvas (SSD1306)" />
                </WrapPanel>
                
                <!-- Divider -->
                <Border Height="1" 
                        Background="{DynamicResource Theme.SeparatorBrush}" 
                        Margin="40,8,40,16"/>

                <!-- Actions -->
                <StackPanel HorizontalAlignment="Center">
                    <Button Content="✦  Custom Size…" 
                            Command="{Binding NewCanvasCommand}" 
                            HorizontalAlignment="Center" 
                            Padding="28,10" 
                            Style="{StaticResource AccentButtonStyle}"
                            Margin="0,0,0,10" />
                    <Button Content="Open File…" 
                            Command="{Binding OpenCommand}" 
                            HorizontalAlignment="Center" 
                            Padding="28,10" 
                            Style="{StaticResource ModernButtonStyle}"
                            Margin="0,0,0,20" />
                </StackPanel>

                <!-- Shortcut hints -->
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Foreground="{DynamicResource Theme.TextMutedBrush}" 
                               FontSize="11" Margin="0,0,16,0">
                        <Run Text="Ctrl+N" FontWeight="SemiBold" Foreground="{DynamicResource Theme.PrimaryAccentBrush}"/>
                        <Run Text=" New"/>
                    </TextBlock>
                    <TextBlock Foreground="{DynamicResource Theme.TextMutedBrush}" 
                               FontSize="11" Margin="0,0,16,0">
                        <Run Text="Ctrl+O" FontWeight="SemiBold" Foreground="{DynamicResource Theme.PrimaryAccentBrush}"/>
                        <Run Text=" Open"/>
                    </TextBlock>
                    <TextBlock Foreground="{DynamicResource Theme.TextMutedBrush}" 
                               FontSize="11">
                        <Run Text="Ctrl+Shift+I" FontWeight="SemiBold" Foreground="{DynamicResource Theme.PrimaryAccentBrush}"/>
                        <Run Text=" Import"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Grid>

        </Grid>
    </Border>
</Window>
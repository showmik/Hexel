<Application x:Class="Hexprite.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Hexprite">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Index 0: Color theme (swapped at runtime by ThemeService) -->
                <ResourceDictionary Source="Themes/Dark.xaml" />
                <!-- Index 1: Styles (shared across all themes) -->
                <ResourceDictionary Source="Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ═══════════════════════════════════════════════════════════
                 Fonts
                 ═══════════════════════════════════════════════════════════ -->
            <FontFamily x:Key="Font.Primary">Inter, Segoe UI, Helvetica Neue, sans-serif</FontFamily>
            <FontFamily x:Key="Font.Code">Cascadia Code, Consolas, Courier New, monospace</FontFamily>

        </ResourceDictionary>
    </Application.Resources>
</Application>
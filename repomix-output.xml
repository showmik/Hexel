        public (string Binary, string Hex) GenerateExportStrings(bool isFloating, bool[,] floatingPixels, int floatX, int floatY, int floatW, int floatH)
        {
            return _codeGen.GenerateExportStrings(SpriteState, isFloating, floatingPixels, floatX, floatY, floatW, floatH, BinaryUseComma, HexUseComma);
        }

        public async System.Threading.Tasks.Task UpdateTextOutputsAsync()
        {
            if (_isUpdatingProgrammatically) return;
            _isUpdatingProgrammatically = true;

            var (binary, hex) = await _codeGen.GenerateExportStringsAsync(
                SpriteState, IsFloating, FloatingPixels, FloatingX, FloatingY, FloatingWidth, FloatingHeight, BinaryUseComma, HexUseComma);

            // Marshal back to the UI thread generically
            _uiContext.Post(_ =>
            {
                _txtBinary = binary;
                _txtHex = hex;
                OnPropertyChanged(nameof(TxtBinary));
                OnPropertyChanged(nameof(TxtHex));
                _isUpdatingProgrammatically = false; // Safe to release now
            }, null);

            _isUpdatingProgrammatically = false;
        }

        // Backwards-compatible synchronous wrapper
        public void UpdateTextOutputs()
        {
            // Fire-and-forget is now safe because the inner method explicitly handles UI thread marshaling
            _ = UpdateTextOutputsAsync();
        }

        public void SyncFloatingState(bool isFloating, bool[,] pixels, int x, int y, int w, int h)
        {
            IsFloating = isFloating;
            FloatingPixels = pixels;
            FloatingX = x;
            FloatingY = y;
            FloatingWidth = w;
            FloatingHeight = h;
        }

        public void SetSelectionBounds(bool hasSelection, int minX, int maxX, int minY, int maxY, bool[,] mask = null)
        {
            HasActiveSelection = hasSelection;
            SelMinX = minX;
            SelMaxX = maxX;
            SelMinY = minY;
            SelMaxY = maxY;
            SelectionMask = mask;
        }

        public void CancelCurrentOperation()
        {
            IsDrawingLine = false;
            IsDrawingRectangle = false;
            IsDrawingEllipse = false;
            _lineStartIdx = -1;
            _lineCurrentIdx = -1;
            _lastClickedIndex = -1;
            if (IsFloating)
            {
                SyncFloatingState(false, null, 0, 0, 0, 0);
            }
            SetSelectionBounds(false, -1, -1, -1, -1, null);
        }

        private void RestoreState(SpriteState state)
        {
            if (state == null || state == SpriteState) return;
            CancelCurrentOperation();

            if (InputWidth != state.Width || InputHeight != state.Height)
            {
                InputWidth = state.Width;
                InputHeight = state.Height;
                InitializeGrid(InputWidth, InputHeight);
            }

            SpriteState = state;
            RedrawGridFromMemory();
            UpdateTextOutputs();
            HistoryRestored?.Invoke(this, EventArgs.Empty);
        }

        #endregion

        #region Private Methods
        private void DeleteSelection()
        {
            if ((CurrentTool == ToolMode.Marquee || CurrentTool == ToolMode.Lasso) && HasActiveSelection)
            {
                SaveStateForUndo();
                if (IsFloating)
                {
                    SyncFloatingState(false, null, 0, 0, 0, 0);
                }
                else
                {
                    int w = SpriteState.Width;
                    for (int i = 0; i < SpriteState.Pixels.Length; i++)
                    {
                        int x = i % w;
                        int y = i / w;
                        if (x >= SelMinX && x <= SelMaxX && y >= SelMinY && y <= SelMaxY)
                        {
                            if (SelectionMask != null)
                            {
                                if (SelectionMask[x - SelMinX, y - SelMinY])
                                    SpriteState.Pixels[i] = false;
                            }
                            else
                            {
                                SpriteState.Pixels[i] = false;
                            }
                        }
                    }
                }
                RedrawGridFromMemory();
                UpdateTextOutputs();
            }
        }
        #endregion
    }
}
</file>

<file path="Hexel/MainWindow.xaml">
<Window x:Class="Hexel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ESP32 Sprite Studio"
        MinHeight="650"
        MinWidth="950"
        Height="780"
        Width="1150"
        Background="{DynamicResource Theme.BackgroundBrush}"
        FontFamily="{DynamicResource Theme.MainFont}"
        WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <KeyBinding Key="Z"
                    Modifiers="Ctrl"
                    Command="{Binding UndoCommand}" />
        <KeyBinding Key="Y"
                    Modifiers="Ctrl"
                    Command="{Binding RedoCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2" />
            <ColumnDefinition Width="400"
                              MinWidth="300"
                              MaxWidth="600" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0"
              Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource PanelStyle}"
                    Margin="0,0,0,15"
                    Padding="20,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                Grid.Column="0">
                        <TextBlock Text="FILE"
                                   Style="{StaticResource HeaderStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   FontSize="11" />
                        <Button Content="Save"
                                Width="60"
                                Margin="0,0,8,0"
                                Style="{StaticResource ModernButtonStyle}"
                                Command="{Binding SaveCommand}"
                                Padding="8,4" />
                        <Button Content="Load"
                                Width="60"
                                Style="{StaticResource ModernButtonStyle}"
                                Command="{Binding LoadCommand}"
                                Padding="8,4" />
                    </StackPanel>

                    <Rectangle Grid.Column="1"
                               Width="2"
                               Fill="{DynamicResource Theme.PanelBorderBrush}"
                               Margin="20,4,20,4"
                               RadiusX="1"
                               RadiusY="1" />

                    <StackPanel Orientation="Horizontal"
                                Grid.Column="2">
                        <TextBlock Text="CANVAS"
                                   Style="{StaticResource HeaderStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   FontSize="11" />
                        <TextBox Text="{Binding InputWidth}"
                                 Width="40"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Margin="0,0,5,0"
                                 TextAlignment="Center" />
                        <TextBlock Text="x"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Theme.TextMutedBrush}"
                                   Margin="0,0,5,0" />
                        <TextBox Text="{Binding InputHeight}"
                                 Width="40"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Margin="0,0,10,0"
                                 TextAlignment="Center" />
                        <Button Content="New Canvas"
                                Command="{Binding NewCanvasCommand}"
                                Style="{StaticResource ModernButtonStyle}"
                                Padding="8,4" />
                        <CheckBox Content="Show Grid"
                                  IsChecked="{Binding ShowGridLines}"
                                  Foreground="{DynamicResource Theme.TextMutedBrush}"
                                  VerticalAlignment="Center"
                                  Margin="15,0,0,0" />
                    </StackPanel>

                    <Rectangle Grid.Column="3"
                               Width="2"
                               Fill="{DynamicResource Theme.PanelBorderBrush}"
                               Margin="20,4,20,4"
                               RadiusX="1"
                               RadiusY="1" />

                    <StackPanel Orientation="Horizontal"
                                Grid.Column="4">
                        <TextBlock Text="TOOLS"
                                   Style="{StaticResource HeaderStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   FontSize="11" />
                        <RadioButton x:Name="RbPencil"
                                     Style="{StaticResource IconToolButtonStyle}"
                                     GroupName="Tools"
                                     IsChecked="True"
                                     Checked="Tool_Checked"
                                     Tag="Pencil"
                                     ToolTip="Pencil Tool (P)">
                            <RadioButton.Content>
                                <Path Style="{StaticResource StrokedToolIconStyle}"
                                      Data="M3.40979 23.0017V12.4402l5.0521 2.7261 3.53861 -2.5275 3.5386 2.5275 5.0511 -2.7261v10.5615 M3.41949 12.4388 11.1783 1.42699c0.4028 -0.571599 1.2503 -0.571599 1.6531 0l7.7588 11.01181 M8.46191 15.1663v7.8354 M15.5391 15.1663v7.8354 M7.55359 6.57275h8.89381" />
                            </RadioButton.Content>
                        </RadioButton>
                        <RadioButton x:Name="RbLine"
                                     Style="{StaticResource IconToolButtonStyle}"
                                     GroupName="Tools"
                                     Checked="Tool_Checked"
                                     Tag="Line"
                                     ToolTip="Line Tool (L)">
                            <RadioButton.Content>
                                <Path Style="{StaticResource StrokedToolIconStyle}"
                                      Data="M4 14L14 4" />
                            </RadioButton.Content>
                        </RadioButton>
                        <RadioButton x:Name="RbRectangle"
                                     Style="{StaticResource IconToolButtonStyle}"
                                     GroupName="Tools"
                                     Checked="Tool_Checked"
                                     Tag="Rectangle"
                                     ToolTip="Rectangle Tool (R)">
                            <RadioButton.Content>
                                <Path Style="{StaticResource StrokedToolIconStyle}"
                                      Data="M 5,5 H 19 V 19 H 5 Z" />
                            </RadioButton.Content>
                        </RadioButton>
                        <RadioButton x:Name="RbEllipse"
                                     Style="{StaticResource IconToolButtonStyle}"
                                     GroupName="Tools"
                                     Checked="Tool_Checked"
                                     Tag="Ellipse"
                                     ToolTip="Ellipse Tool (E)">
                            <RadioButton.Content>
                                <Path Style="{StaticResource StrokedToolIconStyle}"
                                      Data="M 12,5 C 4,5 2,12 2,12 C 2,12 4,19 12,19 C 20,19 22,12 22,12 C 22,12 20,5 12,5 Z" />
                            </RadioButton.Content>
                        </RadioButton>
                        <RadioButton x:Name="RbFill"
                                     Style="{StaticResource IconToolButtonStyle}"
                                     GroupName="Tools"
                                     Checked="Tool_Checked"
                                     Tag="Fill"
                                     ToolTip="Fill Bucket (F)">
                            <RadioButton.Content>
                                <Path Style="{StaticResource StrokedToolIconStyle}"
                                      Data="M45 39.3999c0 3.0928 -2.2386 5.6 -5 5.6s-5 -2.5072 -5 -5.6c0 -2.8526 2.3065 -5.7051 3.7864 -7.2418 0.6738 -0.6997 1.7534 -0.6997 2.4272 0C42.6935 33.6948 45 36.5473 45 39.3999Z M4.61826 9.7989c0.54387 -0.77989 1.54378 -0.98039 2.45947 -0.72608C9.9592 9.87308 16.6614 11.789 23.008 14.0004c1.436 0.5003 2.3292 1.9896 1.9345 3.4582 -0.3947 1.4687 -1.9151 2.3131 -3.4095 2.0306 -6.6053 -1.2489 -13.37034 -2.931 -16.26708 -3.6744 -0.92053 -0.2363 -1.68594 -0.9084 -1.76585 -1.855 -0.05162 -0.6113 -0.03039 -1.3674 0.18788 -2.1796 0.21827 -0.8122 0.57907 -1.4776 0.93031 -1.9813Z M9.49611 16.867c-1.69888 2.1041 -3.50226 4.3976 -5.33812 6.8245 -1.51733 2.0058 -1.56961 4.7519 0.00334 6.7144 1.16214 1.45 2.68002 3.2177 4.44771 4.9854 1.76766 1.7677 3.53536 3.2856 4.98536 4.4477 1.9625 1.573 4.7085 1.5207 6.7143 0.0034 8.3622 -6.3258 15.1404 -12.2659 18.0434 -14.8746 0.8424 -0.757 0.8624 -2.0546 0.0616 -2.8555L21.8879 5.58631c-0.8009 -0.80084 -2.0985 -0.78085 -2.8555 0.06155 -1.0907 1.21386 -2.7639 3.10521 -4.8042 5.50654" />
                            </RadioButton.Content>
                        </RadioButton>
                        <RadioButton x:Name="RbMarquee"
                                     Style="{StaticResource IconToolButtonStyle}"
                                     GroupName="Tools"
                                     Checked="Tool_Checked"
                                     Tag="Marquee"
                                     ToolTip="Marquee Select (M)">
                            <RadioButton.Content>
                                <Path Style="{StaticResource StrokedToolIconStyle}"
                                      StrokeDashArray="2,2"
                                      Data="M 2,2 L 16,2 L 16,16 L 2,16 Z" />
                            </RadioButton.Content>
                        </RadioButton>
                        <RadioButton x:Name="RbLasso"
                                     Style="{StaticResource IconToolButtonStyle}"
                                     GroupName="Tools"
                                     Checked="Tool_Checked"
                                     Tag="Lasso"
                                     ToolTip="Lasso Select (S)">
                            <RadioButton.Content>
                                <Path Style="{StaticResource StrokedToolIconStyle}"
                                      StrokeDashArray="2,2"
                                      Height="22"
                                      Width="22"
                                      Data="{StaticResource Icon.Lasso}" />
                            </RadioButton.Content>
                        </RadioButton>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Grid.Column="6">
                        <TextBlock Text="ZOOM"
                                   Style="{StaticResource HeaderStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   FontSize="11" />
                        <Button Content="-"
                                Width="28"
                                Height="28"
                                Margin="0,0,8,0"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="BtnZoomOut_Click"
                                Padding="0" />
                        <Slider x:Name="ZoomSlider"
                                Width="100"
                                Minimum="0.5"
                                Maximum="5.0"
                                Value="1.0"
                                TickFrequency="0.1"
                                IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"
                                ToolTip="Zoom Canvas (Ctrl+Scroll)" />
                        <Button Content="+"
                                Width="28"
                                Height="28"
                                Margin="8,0,8,0"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="BtnZoomIn_Click"
                                Padding="0" />
                        <Button Content="Reset"
                                Height="28"
                                Padding="12,0"
                                Margin="5,0,0,0"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="BtnZoomReset_Click" />
                        <TextBlock Text="{Binding Value, ElementName=ZoomSlider, StringFormat={}{0:F1}x}"
                                   Foreground="{DynamicResource Theme.PrimaryAccentBrush}"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   Width="35" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource PanelStyle}"
                    Padding="0"
                    ClipToBounds="True">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Background="{DynamicResource Theme.BackgroundBrush}"
                              PreviewMouseWheel="ScrollViewer_PreviewMouseWheel"
                              PreviewMouseDown="ScrollViewer_PreviewMouseDown"
                              PreviewMouseMove="ScrollViewer_PreviewMouseMove"
                              PreviewMouseUp="ScrollViewer_PreviewMouseUp">
                    <Border BorderBrush="{DynamicResource Theme.PanelBackgroundBrush}"
                            BorderThickness="4"
                            Background="{DynamicResource Theme.CanvasBackgroundBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            CornerRadius="4">
                        <Border.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding Value, ElementName=ZoomSlider}"
                                            ScaleY="{Binding Value, ElementName=ZoomSlider}" />
                        </Border.LayoutTransform>

                        <Grid Width="{Binding CanvasDisplayWidth}"
                              Height="{Binding CanvasDisplayHeight}"
                              x:Name="PixelGridContainer">

                            <Image x:Name="CanvasImage"
                                   Source="{Binding CanvasBitmap}"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Stretch="Fill"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   MouseDown="CanvasImage_MouseDown"
                                   MouseMove="CanvasImage_MouseMove" />

                            <Rectangle IsHitTestVisible="False">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Setter Property="Visibility"
                                                Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowGridLines}"
                                                         Value="False">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                                <Rectangle.Fill>
                                    <DrawingBrush Viewport="{Binding GridViewport}"
                                                  ViewportUnits="Absolute"
                                                  TileMode="Tile">
                                        <DrawingBrush.Drawing>
                                            <GeometryDrawing>
                                                <GeometryDrawing.Geometry>
                                                    <RectangleGeometry Rect="{Binding GridViewport}" />
                                                </GeometryDrawing.Geometry>
                                                <GeometryDrawing.Pen>
                                                    <Pen Brush="{DynamicResource Theme.BackgroundBrush}"
                                                         Thickness="1" />
                                                </GeometryDrawing.Pen>
                                            </GeometryDrawing>
                                        </DrawingBrush.Drawing>
                                    </DrawingBrush>
                                </Rectangle.Fill>
                            </Rectangle>

                            <Canvas IsHitTestVisible="False"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch">

                                <Rectangle x:Name="MarqueeOverlay"
                                           Stroke="{DynamicResource Theme.WarningBrush}"
                                           StrokeThickness="2"
                                           StrokeDashArray="4,4"
                                           Visibility="Hidden"
                                           IsHitTestVisible="False" />

                                <Path x:Name="LassoOverlay"
                                         Stroke="{DynamicResource Theme.WarningBrush}"
                                         StrokeThickness="2"
                                         StrokeDashArray="4,4"
                                         Visibility="Hidden"
                                         IsHitTestVisible="False"
                                         Fill="#40F2E94E" />
                                <!-- Light transparent yellow to show the inner selection area -->
                            </Canvas>
                        </Grid>
                    </Border>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource PanelStyle}"
                    Margin="0,15,0,0"
                    Padding="12">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding UndoCommand}"
                                ToolTip="Undo"
                                Width="40"
                                Height="40"
                                Style="{StaticResource ModernButtonStyle}"
                                Padding="0"
                                Margin="0,0,6,0">
                            <TextBlock Text="&#xE10E;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" />
                        </Button>
                        <Button Command="{Binding RedoCommand}"
                                ToolTip="Redo"
                                Width="40"
                                Height="40"
                                Style="{StaticResource ModernButtonStyle}"
                                Padding="0">
                            <TextBlock Text="&#xE10D;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" />
                        </Button>
                    </StackPanel>

                    <Rectangle Width="2"
                               Fill="{DynamicResource Theme.PanelBorderBrush}"
                               Margin="15,4"
                               RadiusX="1"
                               RadiusY="1" />

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Invert"
                                Command="{Binding InvertCommand}"
                                ToolTip="Invert Grid"
                                Width="90"
                                Height="40"
                                Style="{StaticResource ModernButtonStyle}"
                                Padding="10 0"
                                Margin="0,0,10,0"
                                Background="{DynamicResource Theme.InvertButtonBackgroundBrush}">
                        </Button>
                        <Button Content="Clear Canvas" Command="{Binding ClearCommand}"
                                ToolTip="Clear Grid"
                                Width="90"
                                Height="40"
                                Style="{StaticResource ModernButtonStyle}"
                                Padding="10 0"
                                Background="{DynamicResource Theme.ClearButtonBackgroundBrush}">
                        </Button>
                    </StackPanel>

                    <Rectangle Width="2"
                               Fill="{DynamicResource Theme.PanelBorderBrush}"
                               Margin="15,4"
                               RadiusX="1"
                               RadiusY="1" />

                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding CopyHexCommand}"
                                ToolTip="Copy HEX to Clipboard"
                                Height="40"
                                Style="{StaticResource ModernButtonStyle}"
                                Padding="12,0"
                                Background="{DynamicResource Theme.CopyButtonBackgroundBrush}"
                                Foreground="{DynamicResource Theme.TextInverseBrush}">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="&#xE8C8;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Copy HEX"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>

        <GridSplitter Grid.Column="1"
                      Width="2"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource Theme.PanelBackgroundBrush}"
                      Cursor="SizeWE" />

        <Grid Grid.Column="2"
              Margin="15,20,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="15" />
                <RowDefinition Height="*" />
                <RowDefinition Height="15" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="OLED PREVIEW (128x64)"
                               Style="{StaticResource HeaderStyle}" />
                    <Border x:Name="OledBorder"
                            BorderBrush="{DynamicResource Theme.BackgroundBrush}"
                            BorderThickness="4"
                            Width="256"
                            Height="128"
                            HorizontalAlignment="Left"
                            CornerRadius="6">

                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"
                                        Value="{DynamicResource Theme.CanvasBackgroundBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDisplayInverted}"
                                                 Value="True">
                                        <Setter Property="Background"
                                                Value="{DynamicResource Theme.PrimaryAccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid x:Name="PreviewGridContainer">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Background"
                                            Value="{DynamicResource Theme.OledOffBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDisplayInverted}"
                                                     Value="True">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource Theme.OledOnBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Image Source="{Binding PreviewBitmap}"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Stretch="Fill"
                                   Width="{Binding PreviewWidth}"
                                   Height="{Binding PreviewHeight}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <TextBlock Text="*Sprite size shown relative to total screen area"
                               Foreground="{DynamicResource Theme.TextMutedBrush}"
                               FontSize="11"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Binary Representation"
                                   Style="{StaticResource HeaderStyle}"
                                   VerticalAlignment="Center" />
                        <CheckBox Grid.Column="1"
                                  Content="Add commas"
                                  IsChecked="{Binding BinaryUseComma}"
                                  Foreground="{DynamicResource Theme.TextMutedBrush}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,0,8" />
                    </Grid>

                    <Border Grid.Row="1"
                            Background="{DynamicResource Theme.BackgroundBrush}"
                            CornerRadius="6"
                            BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                            BorderThickness="1"
                            Padding="2">
                        <TextBox x:Name="TxtBinary"
                                 Text="{Binding TxtBinary, UpdateSourceTrigger=PropertyChanged, Delay=400}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 FontFamily="{DynamicResource Theme.CodeFont}"
                                 FontSize="13"
                                 Background="Transparent"
                                 Foreground="{DynamicResource Theme.CodeTxtBrush}"
                                 BorderThickness="0"
                                 Padding="10"
                                 VerticalScrollBarVisibility="Auto" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="4"
                    Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="HEX Representation"
                                   Style="{StaticResource HeaderStyle}"
                                   VerticalAlignment="Center" />
                        <CheckBox Grid.Column="1"
                                  Content="Add commas"
                                  IsChecked="{Binding HexUseComma}"
                                  Foreground="{DynamicResource Theme.TextMutedBrush}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,0,8" />
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,0,0,12"
                            Background="{DynamicResource Theme.BackgroundBrush}"
                            CornerRadius="6"
                            BorderBrush="{DynamicResource Theme.PanelBorderBrush}"
                            BorderThickness="1"
                            Padding="2">
                        <TextBox x:Name="TxtHex"
                                 Text="{Binding TxtHex, UpdateSourceTrigger=PropertyChanged, Delay=400}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 FontFamily="{DynamicResource Theme.CodeFont}"
                                 FontSize="13"
                                 Background="Transparent"
                                 Foreground="{DynamicResource Theme.CodeTxtBrush}"
                                 BorderThickness="0"
                                 Padding="10"
                                 VerticalScrollBarVisibility="Auto" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
